---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTASection from '../../components/CTASection.astro';
import { getArticles } from '../../lib/supabase';

const articles = await getArticles();

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'בלוג' },
];
---

<BaseLayout
  title="בלוג משכנתאות - טיפים ומדריכים | יועץ משכנתאות"
  description="מאמרים ומדריכים בנושא משכנתאות, מימון נדל״ן, השקעות והחלטות פיננסיות. מידע מקצועי ועדכני."
>
  <section class="py-12 md:py-16 bg-gradient-to-b from-brand-50 to-white">
    <div class="container max-w-5xl mx-auto px-4">
      <Breadcrumbs items={breadcrumbs} />

      <h1 class="text-3xl md:text-4xl font-bold text-brand-800 mb-4">
        בלוג משכנתאות
      </h1>
      <p class="text-lg text-gray-600 max-w-3xl">
        מאמרים, טיפים ומדריכים מקצועיים בנושא משכנתאות, מימון נדל"ן והשקעות.
        כל מה שצריך לדעת כדי לקבל החלטות פיננסיות חכמות.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="container max-w-5xl mx-auto px-4">
      {articles.length === 0 ? (
        <p class="text-center text-gray-500 py-8">
          בקרוב יעלו מאמרים חדשים. הישארו מעודכנים!
        </p>
      ) : (
        <div class="grid gap-8 md:grid-cols-2">
          {articles.map((article) => (
            <article class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
              <a href={`/blog/${article.slug}/`} class="block p-6">
                <h2 class="text-xl font-bold text-brand-800 mb-3 hover:text-accent-600 transition-colors">
                  {article.title}
                </h2>
                {article.featured_snippet && (
                  <p class="text-gray-600 line-clamp-3">
                    {article.featured_snippet}
                  </p>
                )}
                <div class="mt-4 flex items-center text-sm text-gray-500">
                  <time datetime={article.created_at}>
                    {new Date(article.created_at).toLocaleDateString('he-IL', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                </div>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <CTASection />
</BaseLayout>
