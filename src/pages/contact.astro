---
import BaseLayout from '../layouts/BaseLayout.astro';

// Placeholder - will be updated when user provides
const phone = '050-0000000';
const email = 'info@yoetz-mashkanta.co.il';
const address = 'קרן היסוד 7, קריית ביאליק';
---

<BaseLayout
  title="צור קשר"
  description="צרו קשר עם איתי אנצל - יועץ משכנתאות. פגישת ייעוץ ראשונית ללא עלות. משרד בקריית ביאליק, שירות בכל אזור חיפה והקריות."
>
  <!-- Hero -->
  <section class="bg-surface py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-dark mb-4">צור קשר</h1>
        <p class="text-lg text-gray-600">מוזמנים לפנות בכל שאלה - אשמח לעזור</p>
      </div>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold text-dark mb-6">פרטי התקשרות</h2>

          <div class="space-y-6 mb-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-brand-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">כתובת המשרד</h3>
                <p class="text-gray-600">{address}</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-brand-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">טלפון</h3>
                <a href={`tel:${phone}`} class="text-brand-600 hover:text-brand-700">{phone}</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-brand-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">אימייל</h3>
                <a href={`mailto:${email}`} class="text-brand-600 hover:text-brand-700">{email}</a>
              </div>
            </div>
          </div>

          <!-- Map placeholder -->
          <div class="bg-surface rounded-xl h-64 flex items-center justify-center">
            <p class="text-gray-500">מפה תתווסף בקרוב</p>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-surface rounded-2xl p-6 md:p-8">
          <h2 class="text-2xl font-bold text-dark mb-2">השאירו פרטים</h2>
          <p class="text-gray-500 text-sm mb-6">אחזור אליכם בהקדם האפשרי</p>

          <form
            id="contact-form"
            class="space-y-4"
            data-webhook="https://n8n.almush.co.il/webhook/yoetz-mashkanta"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">
                שם מלא <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="הזינו שם מלא"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg text-dark placeholder-gray-400 focus:ring-2 focus:ring-accent-500 focus:ring-offset-2 focus:border-accent-500 transition-colors"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">
                טלפון <span class="text-red-500">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                placeholder="050-0000000"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg text-dark placeholder-gray-400 focus:ring-2 focus:ring-accent-500 focus:ring-offset-2 focus:border-accent-500 transition-colors"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
                אימייל
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="your@email.com"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg text-dark placeholder-gray-400 focus:ring-2 focus:ring-accent-500 focus:ring-offset-2 focus:border-accent-500 transition-colors"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">
                הודעה
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                placeholder="ספרו לי במה אוכל לעזור..."
                class="w-full px-4 py-3 border border-gray-300 rounded-lg text-dark placeholder-gray-400 focus:ring-2 focus:ring-accent-500 focus:ring-offset-2 focus:border-accent-500 transition-colors resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full px-6 py-3.5 bg-accent-600 text-white font-semibold rounded-lg hover:bg-accent-700 transition-all shadow-md hover:shadow-lg text-lg focus:ring-2 focus:ring-accent-500 focus:ring-offset-2"
            >
              שלחו הודעה
            </button>

            <div id="form-success" class="hidden text-center p-4 bg-green-50 text-green-700 rounded-lg text-sm font-medium">
              תודה! ניצור קשר בהקדם.
            </div>

            <div id="form-error" class="hidden text-center p-4 bg-red-50 text-red-700 rounded-lg text-sm font-medium">
              אירעה שגיאה. אנא נסו שוב.
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const successDiv = document.getElementById('form-success');
      const errorDiv = document.getElementById('form-error');

      submitBtn.disabled = true;
      submitBtn.textContent = 'שולח...';
      successDiv?.classList.add('hidden');
      errorDiv?.classList.add('hidden');

      const formData = new FormData(form);
      const data: Record<string, any> = Object.fromEntries(formData.entries());
      data['page-title'] = 'צור קשר';

      const webhookUrl = form.dataset.webhook || '/api/contact';

      try {
        const response = await fetch(webhookUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          form.reset();
          successDiv?.classList.remove('hidden');
        } else {
          throw new Error('Submit failed');
        }
      } catch {
        errorDiv?.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'שלחו הודעה';
      }
    });
  }
</script>
