---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';

const faqItems = [
  {
    question: 'מה עושה יועץ משכנתאות?',
    answer: 'יועץ משכנתאות מלווה אתכם בכל תהליך קבלת המשכנתא - מבדיקת כדאיות ראשונית, דרך השוואת הצעות מבנקים שונים, בניית תמהיל אופטימלי, ועד ליווי בחתימת ההסכם. היועץ פועל לטובתכם ולא לטובת הבנק.',
  },
  {
    question: 'כמה עולה יועץ משכנתאות?',
    answer: 'עלות הייעוץ משתנה בהתאם למורכבות העסקה ונעה בדרך כלל בין 3,000-8,000 ש"ח. בפגישת הייעוץ הראשונה נסביר את עלות השירות עבורכם. חשוב לזכור - השקעה ביועץ מקצועי יכולה לחסוך לכם עשרות ואף מאות אלפי שקלים לאורך חיי המשכנתא.',
  },
  {
    question: 'למה לקחת יועץ ולא ללכת ישר לבנק?',
    answer: 'הבנק מייצג את האינטרסים שלו ולא שלכם. יועץ משכנתאות עובד עבורכם, משווה הצעות ממספר בנקים, מנהל משא ומתן לתנאים טובים יותר, ודואג שהתמהיל יתאים לצרכים שלכם ולא לרווחי הבנק.',
  },
  {
    question: 'כמה הון עצמי צריך למשכנתא?',
    answer: 'לדירה ראשונה נדרש הון עצמי של לפחות 25% משווי הנכס. לדירה שנייה ומעלה - 50%. ישנם מקרים מיוחדים (כמו זוגות צעירים או מסלולים ייעודיים) שבהם ניתן להקטין את אחוז ההון העצמי.',
  },
  {
    question: 'מה זה תמהיל משכנתא?',
    answer: 'תמהיל משכנתא הוא השילוב של מסלולי ההלוואה השונים שמרכיבים את המשכנתא - ריבית קבועה, ריבית משתנה, פריים ועוד. תמהיל נכון מאזן בין סיכון לבין גמישות ומותאם לצרכים האישיים שלכם.',
  },
  {
    question: 'מתי כדאי למחזר משכנתא?',
    answer: 'מחזור משכנתא יכול להיות כדאי כאשר הריביות בשוק ירדו משמעותית, כאשר השתפרה ההכנסה שלכם, או כאשר רוצים לשנות את מבנה התמהיל. בדיקת כדאיות מחזור היא שירות שאנו מציעים ללא התחייבות.',
  },
  {
    question: 'מה קורה אם נדחיתי למשכנתא בבנק?',
    answer: 'סירוב בבנק אחד לא אומר שלא תקבלו משכנתא. לכל בנק קריטריונים שונים. יועץ משכנתאות יכול לבחון את הסיבות לסירוב, להציע דרכים לשפר את התנאים, ולמצוא בנק שיאשר את הבקשה.',
  },
  {
    question: 'כמה זמן לוקח לקבל משכנתא?',
    answer: 'תהליך קבלת משכנתא אורך בדרך כלל 3-6 שבועות מרגע הגשת הבקשה ועד קבלת האישור. הזמן תלוי במורכבות העסקה, בזמינות המסמכים, ובעומס בבנק.',
  },
  {
    question: 'מה ההבדל בין ריבית פריים לריבית קבועה?',
    answer: 'ריבית פריים צמודה לריבית בנק ישראל ויכולה לעלות או לרדת לאורך זמן. ריבית קבועה נשארת זהה לכל תקופת ההלוואה. לכל אחת יתרונות וחסרונות - תמהיל נכון משלב בין השתיים.',
  },
  {
    question: 'האם אפשר לסגור משכנתא לפני הזמן?',
    answer: 'כן, ניתן לפרוע משכנתא מוקדם. עם זאת, בחלק מהמסלולים ישנן עמלות פירעון מוקדם. חשוב לבדוק את תנאי המשכנתא ולחשב אם זה משתלם. אנו יכולים לעזור בחישוב.',
  },
  {
    question: 'מה צריך להביא לפגישת ייעוץ?',
    answer: 'לפגישה הראשונית כדאי להביא: תלושי שכר (3 אחרונים), אישור יתרות מהבנק, דו"ח BDI אם יש, ופרטים על הנכס שמעוניינים לרכוש (או הנכס הקיים במקרה של מחזור).',
  },
  {
    question: 'האם אתם עובדים רק באזור חיפה?',
    answer: 'אנו מתמחים באזור חיפה והקריות, אך מלווים לקוחות מכל הארץ. הפגישות יכולות להתקיים במשרד, בזום, או בטלפון - לפי הנוחות שלכם.',
  },
];
---

<BaseLayout
  title="שאלות נפוצות על משכנתאות"
  description="תשובות לשאלות הנפוצות ביותר על משכנתאות, יועץ משכנתאות, תמהילים, מחזור ועוד. מידע מקצועי ועדכני."
>
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-dark mb-4">שאלות נפוצות</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        ריכזנו עבורכם את התשובות לשאלות הנפוצות ביותר בנושא משכנתאות. לא מצאתם תשובה? צרו קשר ונשמח לעזור.
      </p>
    </div>
  </section>

  <FAQ items={faqItems} title="" />

  <CTASection />
</BaseLayout>
