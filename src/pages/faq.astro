---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';

const faqItems = [
  // === יועץ משכנתאות - כללי ===
  {
    question: 'מה עושה יועץ משכנתאות?',
    answer: 'יועץ משכנתאות מלווה אתכם בכל תהליך קבלת המשכנתא - מבדיקת כדאיות ראשונית, דרך השוואת הצעות מבנקים שונים, בניית תמהיל אופטימלי, ועד ליווי בחתימת ההסכם. היועץ פועל לטובתכם ולא לטובת הבנק.',
  },
  {
    question: 'כמה עולה יועץ משכנתאות?',
    answer: 'עלות הייעוץ משתנה בהתאם למורכבות העסקה ונעה בדרך כלל בין 3,000-8,000 ש"ח. בפגישת הייעוץ הראשונה נסביר את עלות השירות עבורכם. חשוב לזכור - השקעה ביועץ מקצועי יכולה לחסוך לכם עשרות ואף מאות אלפי שקלים לאורך חיי המשכנתא.',
  },
  {
    question: 'למה לקחת יועץ ולא ללכת ישר לבנק?',
    answer: 'הבנק מייצג את האינטרסים שלו ולא שלכם. יועץ משכנתאות עובד עבורכם, משווה הצעות ממספר בנקים, מנהל משא ומתן לתנאים טובים יותר, ודואג שהתמהיל יתאים לצרכים שלכם ולא לרווחי הבנק.',
  },
  {
    question: 'האם יועץ משכנתאות מקבל עמלה מהבנק?',
    answer: 'יועץ עצמאי כמונו גובה תשלום ישירות מהלקוח ולא מקבל עמלות מבנקים. זה מבטיח שאנחנו עובדים לטובתכם בלבד, ללא ניגוד עניינים. יועצים שעובדים בחינם מקבלים עמלה מהבנק - מה שעלול להשפיע על ההמלצות שלהם.',
  },
  {
    question: 'מתי משלמים ליועץ משכנתאות?',
    answer: 'התשלום מתבצע רק לאחר קבלת אישור עקרוני מהבנק - לא משלמים על שירות שלא הצליח. חלק מהיועצים גובים מקדמה קטנה (500-1,000 ש"ח) שמקוזזת מהסכום הסופי.',
  },
  // === הון עצמי וזכאות ===
  {
    question: 'כמה הון עצמי צריך למשכנתא?',
    answer: 'לדירה ראשונה נדרש הון עצמי של לפחות 25% משווי הנכס. לדירה שנייה ומעלה - 50%. ישנם מקרים מיוחדים (כמו זוגות צעירים או מסלולים ייעודיים) שבהם ניתן להקטין את אחוז ההון העצמי.',
  },
  {
    question: 'האם הלוואה מההורים נחשבת הון עצמי?',
    answer: 'כן, הלוואה מההורים יכולה להיחשב הון עצמי אם מוצגת כמתנה ללא החזר. אם זו הלוואה עם החזר - הבנק יחשב אותה כהתחייבות שמקטינה את יכולת ההחזר שלכם. חשוב להציג את זה נכון.',
  },
  {
    question: 'מה זה הלוואה משלימה וכמה אפשר לקחת?',
    answer: 'הלוואה משלימה היא הלוואה נוספת לצורך השלמת ההון העצמי. ניתן לקחת עד 95% מימון (75% משכנתא + 20% הלוואה משלימה). הריבית על הלוואה משלימה גבוהה יותר והתקופה קצרה יותר (עד 7 שנים).',
  },
  {
    question: 'מה קורה אם אין לי הון עצמי?',
    answer: 'בלי הון עצמי כלל קשה מאוד לקבל משכנתא. אפשרויות: הלוואה מההורים, הלוואה משלימה (עד 20%), מכירת נכסים, חיסכון מואץ, או בדיקת זכאות למענקים (למשל לזוגות צעירים זכאים).',
  },
  // === זוגות צעירים ===
  {
    question: 'אילו הטבות יש לזוגות צעירים במשכנתא?',
    answer: 'זוגות צעירים (עד גיל 35, דירה ראשונה) זכאים לפטור ממס רכישה עד 1.97 מיליון ש"ח, מענקים לזכאי משרד השיכון (עד 80,000 ש"ח תלוי בנקודות זכאות), וריביות מסובסדות במסלולים ייעודיים.',
  },
  {
    question: 'מה זה נקודות זכאות ואיך מחשבים?',
    answer: 'נקודות זכאות נקבעות לפי קריטריונים של משרד השיכון: שנות נישואין, מספר ילדים, שירות צבאי/לאומי, תושבות בפריפריה. ככל שיש יותר נקודות, הזכאות למענק גדולה יותר. אנו מבצעים בדיקת זכאות מלאה.',
  },
  {
    question: 'האם כדאי לחכות למחיר למשתכן או לקנות עכשיו?',
    answer: 'זו שאלה מורכבת שתלויה במצב האישי: זמני ההמתנה במחיר למשתכן ארוכים (3-5 שנים), המחירים בשוק החופשי עולים, ושכר דירה בינתיים עולה כסף. נשמח לעזור בחישוב כדאיות אישי.',
  },
  // === תמהיל משכנתא ===
  {
    question: 'מה זה תמהיל משכנתא?',
    answer: 'תמהיל משכנתא הוא השילוב של מסלולי ההלוואה השונים שמרכיבים את המשכנתא - ריבית קבועה, ריבית משתנה, פריים ועוד. תמהיל נכון מאזן בין סיכון לבין גמישות ומותאם לצרכים האישיים שלכם.',
  },
  {
    question: 'מה ההבדל בין ריבית פריים לריבית קבועה?',
    answer: 'ריבית פריים צמודה לריבית בנק ישראל ויכולה לעלות או לרדת לאורך זמן. ריבית קבועה נשארת זהה לכל תקופת ההלוואה. לכל אחת יתרונות וחסרונות - תמהיל נכון משלב בין השתיים.',
  },
  {
    question: 'מה עדיף - ריבית צמודה למדד או לא צמודה?',
    answer: 'ריבית לא צמודה (קל"צ) מגינה מפני עליית מדד יוקר המחיה. ריבית צמודה (קל"מ) בדרך כלל נמוכה יותר בהתחלה. בסביבת אינפלציה גבוהה - עדיף לא צמוד. בסביבה יציבה - צמוד יכול להיות זול יותר.',
  },
  {
    question: 'כמה מהמשכנתא כדאי לשים בפריים?',
    answer: 'ההמלצה המקובלת היא לא יותר מ-33% בפריים, כי זה המסלול התנודתי ביותר. אם יש לכם הכנסה גבוהה ויציבה ואתם יכולים לספוג עליות - אפשר קצת יותר. אנו מתאימים את האחוז למצב האישי.',
  },
  {
    question: 'מהו תמהיל משכנתא מומלץ ב-2026?',
    answer: 'תמהיל מאוזן לשנת 2026: 33% פריים (גמישות), 33% קל"צ (הגנה מאינפלציה), 34% קל"מ (ריבית נמוכה). זה תמהיל בסיסי - התאמה אישית נעשית לפי גיל, הכנסה, תוכניות עתידיות ויכולת לספוג עליות.',
  },
  // === מחזור משכנתא ===
  {
    question: 'מתי כדאי למחזר משכנתא?',
    answer: 'מחזור משכנתא יכול להיות כדאי כאשר הריביות בשוק ירדו משמעותית, כאשר השתפרה ההכנסה שלכם, או כאשר רוצים לשנות את מבנה התמהיל. בדיקת כדאיות מחזור היא שירות שאנו מציעים ללא התחייבות.',
  },
  {
    question: 'כמה עולה מחזור משכנתא?',
    answer: 'עלויות מחזור: עמלת פירעון מוקדם (תלוי במסלולים), שמאות חדשה (1,500-2,500 ש"ח), עלויות משפטיות (2,000-4,000 ש"ח), ביטול ורישום משכנתא חדשה. נבדוק עבורכם אם החיסכון שווה את העלויות.',
  },
  {
    question: 'האם אפשר למחזר גם חלק מהמשכנתא?',
    answer: 'כן, ניתן למחזר רק חלק מהמסלולים. למשל, אם יש לכם מסלול עם ריבית גבוהה - אפשר למחזר רק אותו. זה יכול להיות חכם אם יש מסלולים אחרים עם תנאים טובים שלא כדאי לגעת בהם.',
  },
  // === עצמאים ומסורבים ===
  {
    question: 'האם עצמאים יכולים לקבל משכנתא?',
    answer: 'בהחלט, אבל התהליך מורכב יותר. נדרשים: דוחות מס ל-2-3 שנים אחרונות, אישור רו"ח על הכנסות, דפי בנק, ולפעמים ביטחונות נוספים. יש בנקים שידידותיים יותר לעצמאים - אנו יודעים לאיזה לפנות.',
  },
  {
    question: 'מה קורה אם נדחיתי למשכנתא בבנק?',
    answer: 'סירוב בבנק אחד לא אומר שלא תקבלו משכנתא. לכל בנק קריטריונים שונים. יועץ משכנתאות יכול לבחון את הסיבות לסירוב, להציע דרכים לשפר את התנאים, ולמצוא בנק שיאשר את הבקשה.',
  },
  {
    question: 'האם אפשר לקבל משכנתא עם BDI שלילי?',
    answer: 'זה מורכב אבל לא בלתי אפשרי. תלוי בסיבת ה-BDI השלילי, בגובה החוב, ובזמן שעבר. לפעמים צריך קודם לסדר את החובות או להביא ערבים. אנו מתמחים גם במקרים מורכבים.',
  },
  {
    question: 'מה עושים כשיש הכנסה לא מדווחת (שחור)?',
    answer: 'הבנקים עובדים רק עם הכנסה מדווחת לרשויות המס. הכנסה לא מדווחת לא נספרת. אם חלק גדול מההכנסה שחור - יכולת ההחזר שתחושב תהיה נמוכה, וזה יגביל את סכום המשכנתא.',
  },
  // === תהליך ולו"ז ===
  {
    question: 'כמה זמן לוקח לקבל משכנתא?',
    answer: 'תהליך קבלת משכנתא אורך בדרך כלל 3-6 שבועות מרגע הגשת הבקשה ועד קבלת האישור. הזמן תלוי במורכבות העסקה, בזמינות המסמכים, ובעומס בבנק.',
  },
  {
    question: 'מה זה אישור עקרוני וכמה זמן הוא תקף?',
    answer: 'אישור עקרוני הוא מסמך מהבנק שאומר "אנחנו מוכנים לתת לכם משכנתא בסכום X בתנאים Y". הוא תקף 60-90 יום. חשוב לקבל אישור עקרוני לפני שמתחייבים על נכס!',
  },
  {
    question: 'מה קורה בין האישור העקרוני לחתימה?',
    answer: 'אחרי האישור העקרוני: בחירת הנכס, חתימת זיכרון דברים/הסכם, שליחת הסכם לבנק, הזמנת שמאי, קבלת אישור סופי, תיאום חתימה, העברת כספים. התהליך לוקח 2-4 שבועות נוספים.',
  },
  // === מסמכים ===
  {
    question: 'מה צריך להביא לפגישת ייעוץ?',
    answer: 'לפגישה הראשונית כדאי להביא: תלושי שכר (3 אחרונים), אישור יתרות מהבנק, דו"ח BDI אם יש, ופרטים על הנכס שמעוניינים לרכוש (או הנכס הקיים במקרה של מחזור).',
  },
  {
    question: 'אילו מסמכים צריך להגיש לבנק?',
    answer: 'רשימה בסיסית: ת.ז., תלושי שכר (3-6 אחרונים), אישור מעסיק, תדפיסי עו"ש (3 חודשים), אישור יתרות חיסכון, הסכם רכישה, נסח טאבו. לעצמאים: דוחות שנתיים, אישור רו"ח.',
  },
  // === עלויות ותשלומים ===
  {
    question: 'האם אפשר לסגור משכנתא לפני הזמן?',
    answer: 'כן, ניתן לפרוע משכנתא מוקדם. עם זאת, בחלק מהמסלולים ישנן עמלות פירעון מוקדם. חשוב לבדוק את תנאי המשכנתא ולחשב אם זה משתלם. אנו יכולים לעזור בחישוב.',
  },
  {
    question: 'מהי עמלת פירעון מוקדם?',
    answer: 'עמלה שהבנק גובה כשסוגרים מסלול לפני הזמן. גובה העמלה תלוי בסוג המסלול ובריבית בשוק: אם הריביות עלו - אין עמלה. אם ירדו - יש עמלה שמפצה את הבנק על הפסד הריבית.',
  },
  {
    question: 'מה עדיף - תקופה קצרה או ארוכה?',
    answer: 'תקופה קצרה = החזר חודשי גבוה יותר אבל סה"כ ריבית נמוכה יותר. תקופה ארוכה = החזר חודשי נמוך יותר אבל סה"כ תשלמו יותר. ההמלצה: לקחת תקופה ארוכה אבל לשלם יותר כשאפשר.',
  },
  {
    question: 'האם כדאי לקחת ביטוח חיים דרך הבנק?',
    answer: 'הבנק מחייב ביטוח חיים, אבל לא חייבים לקנות דווקא ממנו. לרוב ביטוח פרטי זול יותר ב-30-50%. כדאי לבקש הצעות מחברות ביטוח ולהשוות. הבנק חייב לקבל כל פוליסה שעונה על הדרישות.',
  },
  // === שירות וכללי ===
  {
    question: 'האם אתם עובדים רק באזור חיפה?',
    answer: 'אנו מתמחים באזור חיפה והקריות, אך מלווים לקוחות מכל הארץ. הפגישות יכולות להתקיים במשרד, בזום, או בטלפון - לפי הנוחות שלכם.',
  },
  {
    question: 'כמה זמן נמשכת פגישת ייעוץ ראשונה?',
    answer: 'פגישה ראשונה נמשכת 45-60 דקות. במהלכה נבין את המצב הפיננסי, נסביר את האפשרויות, נענה על שאלות, ונתווה תוכנית פעולה. הפגישה ללא התחייבות.',
  },
  {
    question: 'האם אתם חברים בהתאחדות יועצי המשכנתאות?',
    answer: 'כן, איתי אנצל חבר בהתאחדות יועצי המשכנתאות והאשראי בישראל (HFCA) משנת 2017. החברות מבטיחה עמידה בקוד אתי מקצועי והשתתפות בהשתלמויות שוטפות.',
  },
];
---

<BaseLayout
  title="שאלות נפוצות על משכנתאות"
  description="תשובות לשאלות הנפוצות ביותר על משכנתאות, יועץ משכנתאות, תמהילים, מחזור ועוד. מידע מקצועי ועדכני."
>
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-dark mb-4">שאלות נפוצות</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        ריכזנו עבורכם את התשובות לשאלות הנפוצות ביותר בנושא משכנתאות. לא מצאתם תשובה? צרו קשר ונשמח לעזור.
      </p>
    </div>
  </section>

  <FAQ items={faqItems} title="" />

  <CTASection />
</BaseLayout>
