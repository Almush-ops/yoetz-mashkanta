---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

// Person schema for E-E-A-T
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://yoetz-mashkanta.co.il/#person',
  name: 'איתי אנצל',
  jobTitle: 'יועץ משכנתאות',
  worksFor: {
    '@type': 'Organization',
    name: 'אנצ\'ל ייעוץ ופיננסים בע"מ',
  },
  memberOf: {
    '@type': 'Organization',
    name: 'התאחדות יועצי המשכנתאות',
    url: 'https://hfca.org.il',
  },
  knowsAbout: ['משכנתאות', 'ייעוץ פיננסי', 'מחזור משכנתא', 'תמהיל משכנתא'],
  areaServed: ['חיפה', 'קריית ביאליק', 'קריית מוצקין', 'קריית אתא', 'נשר'],
};
---

<BaseLayout
  title="אודות איתי אנצל"
  description="הכירו את איתי אנצל - יועץ משכנתאות מוסמך, חבר התאחדות יועצי המשכנתאות משנת 2017. מעל 7 שנות ניסיון ו-169 לקוחות מרוצים."
>
  <!-- Hero -->
  <section class="bg-surface py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-dark mb-4">אודות איתי אנצל</h1>
        <p class="text-lg text-gray-600">יועץ משכנתאות מוסמך | חבר התאחדות יועצי המשכנתאות</p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-12 items-start">
        <!-- Image side -->
        <div class="lg:w-1/3">
          <div class="sticky top-24">
            <img
              src="/images/itai-office.webp"
              alt="איתי אנצל - יועץ משכנתאות"
              class="rounded-xl shadow-lg w-full mb-6"
              width="400"
              height="500"
              loading="eager"
            />
            <!-- Credentials -->
            <div class="bg-surface rounded-xl p-6">
              <h3 class="font-semibold text-dark mb-4">פרטים מקצועיים</h3>
              <ul class="space-y-3 text-sm text-gray-600">
                <li class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>חבר HFCA משנת 2017</span>
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>169 לקוחות מרוצים</span>
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>דירוג 9.68 מתוך 10</span>
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>אזור שירות: חיפה והקריות</span>
                </li>
              </ul>
              <a
                href="https://hfca.org.il/userprofile/?id=210"
                target="_blank"
                rel="noopener"
                class="mt-4 text-sm text-brand-600 hover:text-brand-700 inline-flex items-center gap-1"
              >
                פרופיל בהתאחדות יועצי המשכנתאות
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Text side -->
        <div class="lg:w-2/3">
          <div class="prose max-w-none">
            <h2>הסיפור שלי</h2>
            <p>
              שמי איתי אנצל, ואני יועץ משכנתאות מוסמך וחבר התאחדות יועצי המשכנתאות משנת 2017. המסע שלי בעולם המשכנתאות התחיל מתוך תשוקה לעזור לאנשים לממש את החלום של בית משלהם - בלי לשלם יותר מדי.
            </p>

            <h2>הגישה שלי</h2>
            <p>
              אני מאמין שכל לקוח הוא ייחודי, ולכן כל תמהיל משכנתא צריך להיות מותאם אישית. אני לא מתפשר על פחות מהתנאים הטובים ביותר, ומנהל משא ומתן קשוח מול הבנקים עבור הלקוחות שלי.
            </p>
            <p>
              הגישה שלי היא שקופה ואנושית - אני מסביר כל שלב בתהליך בשפה פשוטה, עונה על כל שאלה בסבלנות, ומלווה את הלקוחות שלי מהרגע הראשון ועד לחתימה על המשכנתא.
            </p>

            <h2>למה לבחור בי?</h2>
            <ul>
              <li><strong>ניסיון מוכח</strong> - מעל 7 שנים בתחום עם 169 לקוחות מרוצים</li>
              <li><strong>מקצועיות</strong> - חבר התאחדות יועצי המשכנתאות עם הכשרה מתמדת</li>
              <li><strong>שירות אישי</strong> - כל לקוח מקבל את תשומת הלב המלאה שלי</li>
              <li><strong>תוצאות</strong> - דירוג 9.68 מתוך 10 מעיד על שביעות רצון הלקוחות</li>
              <li><strong>נגישות</strong> - זמין לשאלות גם אחרי סיום התהליך</li>
            </ul>

            <h2>ההתמחויות שלי</h2>
            <p>
              אני מתמחה במגוון רחב של פתרונות משכנתא, כולל:
            </p>
            <ul>
              <li>משכנתא לזוגות צעירים ורוכשי דירה ראשונה</li>
              <li>מחזור משכנתא קיימת לשיפור תנאים</li>
              <li>משכנתא למסורבים ומקרים מורכבים</li>
              <li>איחוד הלוואות למשכנתא אחת</li>
              <li>ייעוץ פיננסי וכלכלת משפחה</li>
            </ul>

            <h2>אזור השירות</h2>
            <p>
              המשרד שלי ממוקם בקריית ביאליק, ואני נותן שירות בעיקר לאזור חיפה והקריות - כולל חיפה, קריית ביאליק, קריית מוצקין, קריית אתא, נשר, טירת כרמל, וזכרון יעקב.
            </p>
            <p>
              עבור לקוחות מאזורים אחרים בארץ, אני מציע פגישות בזום ושירות מלא גם מרחוק.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    title="רוצים להתחיל?"
    subtitle="השאירו פרטים לפגישת ייעוץ ראשונית ללא עלות"
    primaryText="השאירו פרטים"
    primaryHref="/contact/"
    phone="050-0000000"
  />

  <!-- Person Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
</BaseLayout>
