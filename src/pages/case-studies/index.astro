---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTASection from '../../components/CTASection.astro';
import { consultant, trustBadges } from '../../data/consultant';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'מקרי לקוח' },
];

const caseStudies = [
  {
    title: 'חיסכון 87,000 ש"ח לזוג צעיר',
    description: 'זוג צעיר מהקריות שתכנן לקחת משכנתא של 1.6 מיליון ש"ח. עם ייעוץ נכון חסכנו להם 87,000 ש"ח לאורך חיי ההלוואה.',
    savings: '87,000 ש"ח',
    type: 'דירה ראשונה',
    href: '/case-studies/young-couple-87k-savings/',
  },
];
---

<BaseLayout
  title="מקרי לקוח - דוגמאות לחיסכון במשכנתא | יועץ משכנתאות"
  description="מקרי לקוח אמיתיים של חיסכון במשכנתא: זוגות צעירים, משפרי דיור, ומחזורי משכנתא. ראו כמה אפשר לחסוך עם ייעוץ מקצועי."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">מקרי לקוח - דוגמאות לחיסכון אמיתי</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        הנה כמה דוגמאות אמיתיות ללקוחות שחסכו עשרות אלפי שקלים במשכנתא שלהם. השמות שונו לשמירה על פרטיות.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {trustBadges.rating}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
          {trustBadges.clients}
        </span>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="space-y-6">
        {caseStudies.map((study) => (
          <a href={study.href} class="block bg-surface p-6 rounded-xl hover:shadow-lg transition-shadow border border-border group">
            <div class="flex flex-col md:flex-row md:items-center gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-xs bg-brand-100 text-brand-700 px-2 py-1 rounded-full font-medium">{study.type}</span>
                </div>
                <h2 class="text-xl font-bold text-dark mb-2 group-hover:text-brand-600 transition-colors">{study.title}</h2>
                <p class="text-gray-600">{study.description}</p>
              </div>
              <div class="text-center md:text-left">
                <div class="bg-green-100 text-green-700 px-4 py-3 rounded-xl">
                  <div class="text-2xl font-bold">{study.savings}</div>
                  <div class="text-xs">חיסכון</div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-600 mb-4">רוצים לדעת כמה אתם יכולים לחסוך?</p>
        <a href="/contact/" class="inline-block bg-accent-500 text-white px-6 py-3 rounded-xl font-bold hover:bg-accent-600 transition-colors shadow-md">
          לתיאום שיחת ייעוץ חינם ←
        </a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
