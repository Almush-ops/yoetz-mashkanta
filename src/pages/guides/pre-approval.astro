---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema, localBusinessSchema, trustBadges } from '../../data/consultant';

const articleSchema = {
  '@type': 'Article',
  headline: 'אישור עקרוני למשכנתא - מה זה, למה חשוב ואיך מקבלים',
  description: 'מדריך מקיף לאישור עקרוני למשכנתא: מה זה אישור עקרוני, למה הוא חיוני לפני רכישת דירה, איך מגישים בקשה, כמה זמן תקף, ומה ההבדל בין הבנקים.',
  author: personSchema,
  publisher: {
    '@type': 'Organization',
    name: consultant.company,
    url: consultant.siteUrl,
  },
  datePublished: '2026-03-10',
  dateModified: '2026-03-10',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://yoetz-mashkanta.co.il/guides/pre-approval/',
  },
};

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'מדריכים', href: '/guides/' },
  { label: 'אישור עקרוני למשכנתא' },
];

const faqItems = [
  {
    question: 'כמה זמן לוקח לקבל אישור עקרוני?',
    answer: 'בבנקים הגדולים, אישור עקרוני מתקבל תוך 1-3 ימי עסקים. חלק מהבנקים מציעים אישור עקרוני דיגיטלי שמתקבל תוך שעות ספורות. עם יועץ משכנתאות, התהליך מואץ כי אנחנו יודעים בדיוק אילו מסמכים נדרשים.',
  },
  {
    question: 'האם אישור עקרוני מחייב אותי?',
    answer: 'לא, אישור עקרוני לא מחייב אתכם. זו הערכה ראשונית בלבד. אתם לא מחויבים לקחת משכנתא מהבנק שנתן את האישור, ואתם יכולים לבקש אישורים ממספר בנקים במקביל.',
  },
  {
    question: 'האם אישור עקרוני פוגע בדירוג האשראי?',
    answer: 'בקשה לאישור עקרוני כוללת בדיקה ב-BDI/CRB, אך ההשפעה על הדירוג מינימלית. מספר בדיקות בפרק זמן קצר (עד 30 יום) נספרות כבדיקה אחת, כי המערכת מבינה שאתם משווים הצעות.',
  },
  {
    question: 'מה ההבדל בין אישור עקרוני לאישור סופי?',
    answer: 'אישור עקרוני מבוסס על הצהרות והערכות. אישור סופי מתקבל רק אחרי בדיקת מסמכים מלאה, שמאות לנכס, ואישור ממחלקת האשראי. האישור הסופי הוא זה שמחייב את הבנק.',
  },
  {
    question: 'האם אפשר לקבל אישור עקרוני אונליין?',
    answer: 'כן, רוב הבנקים הגדולים מציעים היום אפשרות להגיש בקשה לאישור עקרוני באונליין. עם זאת, התהליך עם יועץ משכנתאות בדרך כלל מניב תוצאות טובות יותר כי אנחנו יודעים להציג את המקרה בצורה האופטימלית.',
  },
  {
    question: 'כמה זמן תקף אישור עקרוני?',
    answer: 'אישור עקרוני תקף בין 60 ל-90 יום, תלוי בבנק. אם לא מצאתם דירה בתקופה הזו, תצטרכו לחדש את האישור. החידוש בדרך כלל מהיר יותר מהפעם הראשונה.',
  },
];
---

<BaseLayout
  title="אישור עקרוני למשכנתא - מה זה ואיך מקבלים | מדריך 2026"
  description="מדריך מקיף לאישור עקרוני למשכנתא: מה זה, למה חיוני לפני רכישת דירה, אילו מסמכים צריך, כמה זמן תקף, וטיפים לקבלת אישור מהיר וטוב יותר."
>
  <SchemaOrg slot="schema" schema={[articleSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="inline-block bg-white/20 text-white text-sm font-medium px-3 py-1 rounded-full mb-4">מדריך מקיף</span>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">אישור עקרוני למשכנתא - מה זה ואיך מקבלים</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        אישור עקרוני הוא השלב הראשון והחשוב ביותר בדרך לרכישת דירה. הוא מאפשר לכם לדעת מראש כמה משכנתא תוכלו לקבל - לפני שאתם מתחילים לחפש.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {trustBadges.rating}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          {trustBadges.clients}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          {trustBadges.hfca}
        </span>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <article class="prose max-w-none">
        <h2>מה זה אישור עקרוני למשכנתא?</h2>
        <p>
          <strong>אישור עקרוני</strong> (Pre-Approval) הוא מסמך מהבנק שמצהיר כמה משכנתא הם מוכנים לתת לכם, בהתבסס על מצבכם הפיננסי. זו לא התחייבות סופית, אלא הערכה ראשונית שמבוססת על:
        </p>
        <ul>
          <li>ההכנסות שלכם (משכורת, עסק עצמאי, הכנסות נוספות)</li>
          <li>ההתחייבויות הקיימות (הלוואות, אשראי, ערבויות)</li>
          <li>ההון העצמי שיש לכם</li>
          <li>היסטוריית האשראי שלכם</li>
        </ul>

        <div class="bg-accent-50 border-r-4 border-accent-500 p-6 rounded-lg my-8 not-prose">
          <h3 class="text-lg font-semibold text-dark mb-2">למה זה כל כך חשוב?</h3>
          <p class="text-gray-600">
            בלי אישור עקרוני, אתם עלולים להתאהב בדירה, לחתום על זיכרון דברים, ואז לגלות שהבנק לא מוכן לתת לכם משכנתא בסכום הנדרש. אישור עקרוני מונע את הסיטואציה הכואבת הזו ונותן לכם ביטחון במשא ומתן.
          </p>
        </div>

        <h2>מתי כדאי לבקש אישור עקרוני?</h2>
        <p>
          התשובה הקצרה: <strong>לפני שאתם מתחילים לחפש דירה</strong>. אישור עקרוני צריך להיות הצעד הראשון בתהליך רכישת דירה, ולא הצעד האחרון.
        </p>

        <h3>היתרונות של אישור עקרוני מוקדם:</h3>
        <ul>
          <li><strong>תקציב ברור</strong> - תדעו בדיוק באיזה טווח מחירים לחפש</li>
          <li><strong>כוח מיקוח</strong> - מוכרים מעדיפים קונים עם אישור עקרוני</li>
          <li><strong>חיסכון בזמן</strong> - לא תבזבזו זמן על דירות שלא תוכלו לממן</li>
          <li><strong>גילוי בעיות מוקדם</strong> - אם יש בעיה באשראי, עדיף לדעת לפני</li>
          <li><strong>מהירות בסגירה</strong> - כשתמצאו דירה, תוכלו לסגור מהר</li>
        </ul>

        <h2>אילו מסמכים צריך לאישור עקרוני?</h2>

        <h3>לשכירים:</h3>
        <ul>
          <li>3 תלושי משכורת אחרונים</li>
          <li>טופס 106 מהשנה האחרונה (או אישור מעסיק על הכנסה שנתית)</li>
          <li>צילום תעודת זהות כולל ספח</li>
          <li>דפי חשבון בנק מ-3 החודשים האחרונים</li>
          <li>אישור על הון עצמי (חסכונות, קרנות, מניות)</li>
        </ul>

        <h3>לעצמאים:</h3>
        <ul>
          <li>שומות מס מאושרות מ-2 השנים האחרונות</li>
          <li>דו"חות כספיים מבוקרים (אם יש)</li>
          <li>תדפיס עו"ש מ-6 החודשים האחרונים</li>
          <li>אישור רו"ח על הכנסות (במקרים מסוימים)</li>
          <li>צילום תעודת זהות כולל ספח</li>
          <li>אישור על הון עצמי</li>
        </ul>

        <div class="bg-surface border border-border p-6 rounded-lg my-8 not-prose">
          <h3 class="text-lg font-semibold text-dark mb-2">טיפ מקצועי</h3>
          <p class="text-gray-600">
            לפני הגשת הבקשה, כדאי לבדוק את דוח האשראי שלכם ב-BDI או CRB. אם יש טעויות או חובות ישנים שכבר נסגרו - תקנו אותם לפני. זה יכול לשפר משמעותית את תנאי האישור.
          </p>
        </div>

        <h2>התהליך שלב אחר שלב</h2>

        <h3>1. איסוף מסמכים (יום 1)</h3>
        <p>אספו את כל המסמכים הנדרשים. ודאו שהם מעודכנים - תלושי משכורת ודפי בנק צריכים להיות מ-3 החודשים האחרונים.</p>

        <h3>2. הגשת בקשה (יום 1-2)</h3>
        <p>הגישו בקשה לאישור עקרוני. אפשר להגיש לכמה בנקים במקביל - זה לגיטימי ואפילו מומלץ.</p>

        <h3>3. בדיקה והערכה (ימים 2-5)</h3>
        <p>הבנק בודק את המסמכים, מריץ שאילתת BDI, ומעריך את יכולת ההחזר שלכם.</p>

        <h3>4. קבלת אישור (ימים 3-7)</h3>
        <p>מקבלים מכתב אישור עקרוני שמפרט: סכום מקסימלי, אחוז מימון מקסימלי, ותנאים עקרוניים.</p>

        <h2>מה כתוב באישור עקרוני?</h2>
        <p>
          אישור עקרוני טיפוסי כולל:
        </p>
        <ul>
          <li><strong>סכום משכנתא מקסימלי</strong> - כמה הבנק מוכן להלוות</li>
          <li><strong>אחוז מימון</strong> - מה היחס בין המשכנתא לשווי הנכס (LTV)</li>
          <li><strong>החזר חודשי מקסימלי</strong> - סכום ההחזר שהבנק מחשיב כסביר</li>
          <li><strong>תוקף האישור</strong> - בדרך כלל 60-90 יום</li>
          <li><strong>תנאים מוקדמים</strong> - מה צריך להתקיים כדי לקבל אישור סופי</li>
        </ul>

        <div class="bg-red-50 border-r-4 border-red-500 p-6 rounded-lg my-8 not-prose">
          <h3 class="text-lg font-semibold text-red-800 mb-2">חשוב לדעת</h3>
          <p class="text-red-700">
            אישור עקרוני הוא <strong>לא התחייבות</strong>. הבנק עדיין יכול לסרב או לשנות תנאים אחרי בדיקת הנכס הספציפי, שמאות, או שינוי במצבכם הפיננסי.
          </p>
        </div>

        <h2>כמה אישורים עקרוניים כדאי לבקש?</h2>
        <p>
          מומלץ לבקש אישורים עקרוניים מ-<strong>3-4 בנקים לפחות</strong>. למה?
        </p>
        <ul>
          <li>בנקים שונים מעריכים מקרים בצורה שונה</li>
          <li>התנאים (ריביות, אחוזי מימון) משתנים בין בנקים</li>
          <li>יש לכם כוח מיקוח כשיש לכם הצעות מתחרות</li>
          <li>אם בנק אחד מסרב, אחר עשוי לאשר</li>
        </ul>

        <h2>טעויות נפוצות שכדאי להימנע מהן</h2>

        <h3>1. לבקש אישור עקרוני מאוחר מדי</h3>
        <p>לא מחכים עד שמוצאים דירה. אישור עקרוני צריך להיות הצעד הראשון.</p>

        <h3>2. להגיש רק לבנק אחד</h3>
        <p>תמיד כדאי להשוות בין מספר בנקים. ההבדלים יכולים להיות משמעותיים.</p>

        <h3>3. להסתיר מידע</h3>
        <p>אם יש לכם חוב או בעיה באשראי - עדיף לגלות מראש. הבנק יגלה בכל מקרה, ושקיפות בונה אמון.</p>

        <h3>4. לא לקרוא את האותיות הקטנות</h3>
        <p>האישור העקרוני כולל תנאים. קראו אותם בעיון והבינו מה נדרש לאישור סופי.</p>

        <h2>למה כדאי לעבוד עם יועץ משכנתאות?</h2>
        <p>
          יועץ משכנתאות יכול לעזור לכם לקבל אישור עקרוני טוב יותר:
        </p>
        <ul>
          <li><strong>הכנת תיק מקצועית</strong> - אנחנו יודעים איך להציג את המקרה שלכם בצורה האופטימלית</li>
          <li><strong>ידע של השוק</strong> - יודעים איזה בנק מתאים לאיזה פרופיל</li>
          <li><strong>חיסכון בזמן</strong> - מטפלים בכל הניירת מולכם</li>
          <li><strong>משא ומתן</strong> - מנהלים מו"מ על תנאים טובים יותר</li>
          <li><strong>פתרון בעיות</strong> - יודעים להתמודד עם סירובים וחסמים</li>
        </ul>

        <h2>סיכום</h2>
        <p>
          אישור עקרוני הוא הצעד הראשון והחשוב ביותר בדרך לרכישת דירה. הוא נותן לכם ביטחון, כוח מיקוח, ומונע הפתעות לא נעימות. אל תתחילו לחפש דירה בלי אישור עקרוני ביד.
        </p>
        <p>
          רוצים לקבל אישור עקרוני? <a href="/contact/">צרו קשר</a> לפגישת ייעוץ ללא עלות ואעזור לכם להתחיל את התהליך נכון.
        </p>

        <h2>מדריכים נוספים</h2>
        <ul>
          <li><a href="/guides/young-couples/">משכנתא לזוגות צעירים - המדריך המלא</a></li>
          <li><a href="/guides/down-payment/">כמה הון עצמי צריך למשכנתא?</a></li>
          <li><a href="/guides/first-apartment/">משכנתא לדירה ראשונה - שלב אחר שלב</a></li>
          <li><a href="/guides/common-mistakes/">8 טעויות נפוצות במשכנתא</a></li>
        </ul>
      </article>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-3xl mx-auto px-4">
      <FAQ title="שאלות נפוצות על אישור עקרוני" items={faqItems} />
    </div>
  </section>

  <CTASection
    title="רוצים לקבל אישור עקרוני?"
    subtitle="פגישת ייעוץ ראשונית ללא עלות - אעזור לכם להתחיל את התהליך נכון"
    primaryText="לתיאום פגישה"
    primaryHref="/contact/"
    phone="055-432-6608"
  />
</BaseLayout>
