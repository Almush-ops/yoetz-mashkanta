---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';

const guides = [
  {
    title: 'משכנתא לזוגות צעירים - המדריך המלא 2026',
    description: 'כל מה שזוגות צעירים צריכים לדעת על לקיחת משכנתא לדירה ראשונה - הטבות, מענקים, ותמהילים מומלצים.',
    href: '/guides/young-couples/',
    category: 'זוגות צעירים',
  },
  {
    title: 'משכנתא לעצמאים - המדריך המלא',
    description: 'איך עצמאים מקבלים משכנתא? מסמכים נדרשים, חישוב הכנסה, בנקים מומלצים, וטיפים מהשטח.',
    href: '/guides/self-employed/',
    category: 'עצמאים',
  },
  {
    title: 'מחזור משכנתא - מתי כדאי ואיך לעשות נכון',
    description: 'מתי כדאי למחזר את המשכנתא? איך לחסוך עשרות אלפי שקלים בריבית? מדריך מקיף למחזור.',
    href: '/guides/refinancing/',
    category: 'מחזור',
  },
  {
    title: 'תמהיל משכנתא מומלץ 2026',
    description: 'איך לבנות את התמהיל האופטימלי? פריים, קל"צ, משתנה - יתרונות וחסרונות של כל מסלול.',
    href: '/guides/mortgage-mix/',
    category: 'תמהיל',
  },
  {
    title: 'כמה הון עצמי צריך למשכנתא',
    description: 'מה אחוז ההון העצמי הנדרש? האם אפשר עם פחות? טיפים לגיוס הון עצמי.',
    href: '/guides/down-payment/',
    category: 'הון עצמי',
  },
  {
    title: 'משכנתא בלי הון עצמי - האם זה אפשרי?',
    description: 'האם אפשר לקבל משכנתא ללא הון עצמי? חלופות מימון, הלוואות מההורים, מענקים וסיכונים.',
    href: '/guides/no-down-payment/',
    category: 'הון עצמי',
  },
  {
    title: 'לוח סילוקין משכנתא - מה זה ואיך לקרוא אותו',
    description: 'מדריך מקיף ללוח סילוקין: שיטת שפיצר מול קרן שווה, איך לקרוא את הלוח, ואיך להשתמש בו לתכנון.',
    href: '/guides/amortization-schedule/',
    category: 'מושגים',
  },
  {
    title: 'ביטוח משכנתא - מה חובה ומה מומלץ',
    description: 'ביטוח חיים, ביטוח מבנה, אובדן כושר עבודה - מה הבנק דורש, מה באמת צריך, ואיך לחסוך.',
    href: '/guides/mortgage-insurance/',
    category: 'ביטוח',
  },
  {
    title: '8 טעויות נפוצות במשכנתא (ואיך להימנע מהן)',
    description: 'הטעויות הנפוצות שעולות ללווים אלפי שקלים - ואיך להימנע מהן עם תכנון נכון.',
    href: '/guides/common-mistakes/',
    category: 'טיפים',
  },
  {
    title: 'כמה עולה יועץ משכנתאות ולמה זה שווה',
    description: 'עלות ייעוץ משכנתאות לעומת החיסכון הפוטנציאלי - מדוע יועץ מקצועי מחזיר את ההשקעה.',
    href: '/guides/consultant-cost/',
    category: 'ייעוץ',
  },
  {
    title: 'משכנתא לדירה ראשונה - שלב אחר שלב',
    description: 'מדריך מפורט לכל התהליך - מהגשת בקשה ראשונית ועד קבלת המפתחות.',
    href: '/guides/first-apartment/',
    category: 'דירה ראשונה',
  },
  {
    title: 'ריביות משכנתא 2026 - מה צריך לדעת',
    description: 'סקירת מצב הריביות, תחזיות, והשפעה על החלטות משכנתא בשנת 2026.',
    href: '/guides/interest-rates/',
    category: 'ריביות',
  },
];
---

<BaseLayout
  title="מדריכי משכנתאות"
  description="מדריכים מקצועיים ומעמיקים בנושאי משכנתאות - זוגות צעירים, מחזור, תמהילים, הון עצמי ועוד. מידע עדכני ל-2026."
>
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-dark mb-4">מדריכי משכנתאות</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        מדריכים מקצועיים ומעודכנים שיעזרו לכם להבין את עולם המשכנתאות ולקבל החלטות מושכלות.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="space-y-6">
        {guides.map((guide) => (
          <a
            href={guide.href}
            class="group block bg-white border border-border rounded-xl p-6 hover:shadow-lg hover:border-brand-300 transition-all duration-300"
          >
            <div class="flex flex-col md:flex-row md:items-center gap-4">
              <div class="flex-1">
                <span class="inline-block bg-brand-100 text-brand-700 text-xs font-medium px-2.5 py-1 rounded-full mb-2">
                  {guide.category}
                </span>
                <h2 class="text-xl font-bold text-dark group-hover:text-brand-600 transition-colors mb-2">
                  {guide.title}
                </h2>
                <p class="text-gray-600 text-sm leading-relaxed">{guide.description}</p>
              </div>
              <div class="flex-shrink-0">
                <span class="inline-flex items-center gap-1 text-brand-600 font-medium text-sm group-hover:gap-2 transition-all">
                  קרא את המדריך
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
