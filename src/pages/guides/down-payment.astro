---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema, localBusinessSchema, trustBadges } from '../../data/consultant';

const articleSchema = {
  '@type': 'Article',
  headline: 'כמה הון עצמי צריך למשכנתא - המדריך המלא 2026',
  description: 'מדריך מקיף להון עצמי למשכנתא: 25% לדירה ראשונה, 30% למשפרי דיור, 50% לדירה שנייה. מקורות מותרים, הלוואות משלימות וטיפים לצבירה.',
  author: personSchema,
  publisher: {
    '@type': 'Organization',
    name: consultant.company,
    url: consultant.siteUrl,
  },
  datePublished: '2026-01-28',
  dateModified: '2026-03-09',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://yoetz-mashkanta.co.il/guides/down-payment/',
  },
};

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'מדריכים', href: '/guides/' },
  { label: 'הון עצמי למשכנתא' },
];

const faqItems = [
  {
    question: 'האם הלוואה מההורים נחשבת הון עצמי?',
    answer: 'תלוי. מתנה מההורים נחשבת הון עצמי (עם מכתב מתנה חתום). הלוואה מההורים יכולה להיחשב כהון עצמי אם אין לוח סילוקין קבוע ואין ריבית, או אם מגובה בנכס של ההורים. הלוואה רגילה עם החזר חודשי נכנסת לחישוב יחס ההחזר ומקשה על קבלת המשכנתא.',
  },
  {
    question: 'האם אפשר להשתמש בקרן השתלמות כהון עצמי?',
    answer: 'כן, פדיון קרן השתלמות (אחרי 6 שנים) נחשב הון עצמי לכל דבר. אפשר גם לקחת הלוואה כנגד הקרן - אבל אז ההחזר החודשי נכנס לחישוב יחס ההחזר. מומלץ לפדות ולא לקחת הלוואה.',
  },
  {
    question: 'מה זה יחס מימון (LTV)?',
    answer: 'יחס מימון (Loan-To-Value) הוא היחס בין סכום המשכנתא לשווי הנכס. על דירה של 2 מיליון ש"ח עם משכנתא של 1.5 מיליון, יחס המימון הוא 75%. בנק ישראל קבע יחסים מקסימליים: 75% לדירה ראשונה, 70% למשפרי דיור, 50% לדירה שנייה.',
  },
  {
    question: 'האם אפשר לקנות דירה בלי הון עצמי בכלל?',
    answer: 'לא. בישראל חובה להביא הון עצמי לפי הוראות בנק ישראל. אין משכנתא של 100% מימון. במקרים חריגים אפשר לשעבד נכס אחר או לקבל ערבות הורים, אבל גם אז צריך לעמוד בדרישות ההון העצמי.',
  },
  {
    question: 'האם כסף שקיבלתי בירושה נחשב הון עצמי?',
    answer: 'כן, ירושה היא מקור לגיטימי לחלוטין להון עצמי. הבנק יבקש תצהיר ומסמכים שמוכיחים את מקור הכסף (צו ירושה, אישור העברה בנקאית). זה חלק מבדיקות איסור הלבנת הון.',
  },
  {
    question: 'מה אם אין לי מספיק הון עצמי?',
    answer: 'יש כמה אפשרויות: (1) לחסוך יותר ולדחות את הרכישה, (2) לבקש מתנה/הלוואה מההורים, (3) לפדות קרן השתלמות או קופת גמל, (4) לחפש דירה זולה יותר, (5) לקבל מענקי זכאות (לזכאים). הלוואה צרכנית רגילה לא פותרת את הבעיה - היא מקשה על קבלת המשכנתא.',
  },
];
---

<BaseLayout
  title="כמה הון עצמי צריך למשכנתא 2026 | 25%, 30%, 50% - מדריך מלא"
  description="מדריך מקיף להון עצמי למשכנתא: 25% לדירה ראשונה, 30% למשפרי דיור, 50% לדירה שנייה. מקורות מותרים, מתנות מההורים, קרן השתלמות וטיפים לצבירת הון."
>
  <SchemaOrg slot="schema" schema={[articleSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="inline-block bg-white/20 text-white text-sm font-medium px-3 py-1 rounded-full mb-4">מדריך מקיף</span>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">כמה הון עצמי צריך למשכנתא</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        הון עצמי הוא המחסום הראשון ברכישת דירה. במדריך הזה נסביר כמה צריך להביא, מאיפה אפשר לגייס, ואיך לחסוך בצורה חכמה.
      </p>
      <!-- E-E-A-T Trust Badges -->
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {trustBadges.rating}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
          {trustBadges.clients}
        </span>
        <a href={consultant.hfcaUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full hover:bg-white/20 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          {trustBadges.hfca}
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          <strong>הון עצמי הוא הכסף שאתם מביאים מהכיס לעסקה</strong> - ההפרש בין מחיר הדירה לבין סכום המשכנתא שהבנק נותן לכם. זו דרישה של בנק ישראל שמטרתה להגן גם עליכם וגם על הבנק מפני מימון יתר.
        </p>
        <p>
          אחוז ההון העצמי הנדרש תלוי במצב שלכם: האם זו דירה ראשונה, האם אתם משפרי דיור, או שזו דירה להשקעה. הנה הפירוט המלא:
        </p>

        <h2 class="text-xl font-bold text-dark mt-8 mb-4">אחוזי הון עצמי לפי סוג רוכש</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 my-8">
        <div class="bg-green-50 p-6 rounded-xl border border-green-200">
          <div class="w-16 h-16 bg-green-500 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">25%</div>
          <h3 class="text-lg font-bold text-dark text-center mb-2">דירה ראשונה</h3>
          <p class="text-sm text-gray-600 text-center mb-4">
            מי שלא הייתה בבעלותו דירה מעולם (או שמכר לפני 18+ חודשים)
          </p>
          <div class="bg-white p-3 rounded-lg text-sm">
            <p class="text-gray-700"><strong>דוגמה:</strong> דירה ב-2 מיליון ש"ח</p>
            <p class="text-green-700 font-bold">הון עצמי נדרש: 500,000 ש"ח</p>
            <p class="text-gray-600">משכנתא מקסימלית: 1,500,000 ש"ח</p>
          </div>
        </div>

        <div class="bg-blue-50 p-6 rounded-xl border border-blue-200">
          <div class="w-16 h-16 bg-blue-500 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">30%</div>
          <h3 class="text-lg font-bold text-dark text-center mb-2">משפרי דיור</h3>
          <p class="text-sm text-gray-600 text-center mb-4">
            מי שמוכר דירה קיימת וקונה אחרת (תוך 18 חודשים)
          </p>
          <div class="bg-white p-3 rounded-lg text-sm">
            <p class="text-gray-700"><strong>דוגמה:</strong> דירה ב-2.5 מיליון ש"ח</p>
            <p class="text-blue-700 font-bold">הון עצמי נדרש: 750,000 ש"ח</p>
            <p class="text-gray-600">משכנתא מקסימלית: 1,750,000 ש"ח</p>
          </div>
        </div>

        <div class="bg-orange-50 p-6 rounded-xl border border-orange-200">
          <div class="w-16 h-16 bg-orange-500 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">50%</div>
          <h3 class="text-lg font-bold text-dark text-center mb-2">דירה נוספת</h3>
          <p class="text-sm text-gray-600 text-center mb-4">
            רכישת דירה שנייה+ (להשקעה או מגורים)
          </p>
          <div class="bg-white p-3 rounded-lg text-sm">
            <p class="text-gray-700"><strong>דוגמה:</strong> דירה ב-1.8 מיליון ש"ח</p>
            <p class="text-orange-700 font-bold">הון עצמי נדרש: 900,000 ש"ח</p>
            <p class="text-gray-600">משכנתא מקסימלית: 900,000 ש"ח</p>
          </div>
        </div>
      </div>

      <div class="prose prose-lg max-w-none text-gray-700">
        <div class="bg-brand-50 p-6 rounded-xl my-6 not-prose border border-brand-200">
          <h4 class="font-bold text-dark mb-3">חשוב לדעת: מה נכלל בהון העצמי?</h4>
          <p class="text-sm text-gray-700 mb-3">
            ההון העצמי חייב לכסות לא רק את ה-25%/30%/50% משווי הנכס, אלא גם את <strong>עלויות הנלוות</strong>:
          </p>
          <ul class="text-sm space-y-1 text-gray-700">
            <li>• מס רכישה (0%-8% תלוי בשווי ובמצב הרוכש)</li>
            <li>• שכר טרחת עו"ד (0.5%-1% + מע"מ)</li>
            <li>• דמי תיווך (אם יש): 1%-2% + מע"מ</li>
            <li>• שמאות: 2,000-3,000 ש"ח</li>
            <li>• עמלות בנק ורישום משכון</li>
          </ul>
          <p class="text-sm text-brand-700 font-bold mt-3">
            כלל אצבע: הוסיפו 5%-7% על ההון העצמי הנדרש לכיסוי עלויות נלוות.
          </p>
        </div>

        <h2 class="text-xl font-bold text-dark mt-8 mb-4">מקורות הון עצמי מותרים</h2>
        <p>
          הבנק בודק את מקור ההון העצמי כחלק מבדיקות איסור הלבנת הון וכדי לוודא שהכסף אכן שלכם. הנה המקורות הלגיטימיים:
        </p>
      </div>

      <div class="bg-surface p-6 rounded-xl my-8">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h4 class="font-bold text-green-700 mb-3">מקורות מאושרים</h4>
            <ul class="text-sm space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-green-500">✓</span>
                <span><strong>חסכונות אישיים</strong> - עו"ש, פק"מ, חסכונות</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-green-500">✓</span>
                <span><strong>קרן השתלמות</strong> - פדיון אחרי 6 שנים</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-green-500">✓</span>
                <span><strong>קופת גמל להשקעה</strong> - משיכה לצורך דירה</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-green-500">✓</span>
                <span><strong>מתנה מההורים</strong> - עם מכתב מתנה חתום</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-green-500">✓</span>
                <span><strong>ירושה</strong> - עם מסמכים מתאימים</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-green-500">✓</span>
                <span><strong>מכירת נכס</strong> - רכב, דירה קודמת</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-green-500">✓</span>
                <span><strong>מענקי זכאות</strong> - ממשרד הבינוי</span>
              </li>
            </ul>
          </div>
          <div>
            <h4 class="font-bold text-red-700 mb-3">מה לא נחשב הון עצמי</h4>
            <ul class="text-sm space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-red-500">✗</span>
                <span><strong>הלוואה צרכנית רגילה</strong> - נכנסת ליחס החזר</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-500">✗</span>
                <span><strong>כרטיס אשראי</strong> - לא יכול לשמש כהון</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-500">✗</span>
                <span><strong>משיכת יתר</strong> - מראה על קושי פיננסי</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-500">✗</span>
                <span><strong>הלוואה מחבר</strong> - חייב להיות מתועד ומאושר</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-500">✗</span>
                <span><strong>כסף "מזומן"</strong> - לא ניתן להוכיח מקור</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <div class="prose prose-lg max-w-none text-gray-700">
        <h2 class="text-xl font-bold text-dark mt-8 mb-4">הלוואות משלימות - מה מותר ומה לא</h2>
        <p>
          לפעמים ההון העצמי לא מספיק, ורוצים להשלים בעזרת הלוואה. חשוב להבין מה מותר:
        </p>

        <div class="bg-surface p-6 rounded-xl my-6 not-prose">
          <div class="space-y-4">
            <div class="flex items-start gap-4 pb-4 border-b border-border">
              <span class="w-8 h-8 bg-green-100 text-green-600 rounded-full flex items-center justify-center flex-shrink-0">✓</span>
              <div>
                <h4 class="font-bold text-dark">הלוואה מההורים ללא לוח סילוקין</h4>
                <p class="text-sm text-gray-600">"הלוואה רכה" ללא החזר חודשי קבוע. עם מכתב מתאים מההורים - נחשבת כהון עצמי.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 pb-4 border-b border-border">
              <span class="w-8 h-8 bg-green-100 text-green-600 rounded-full flex items-center justify-center flex-shrink-0">✓</span>
              <div>
                <h4 class="font-bold text-dark">הלוואה מגובת נדל"ן של ההורים</h4>
                <p class="text-sm text-gray-600">ההורים לוקחים הלוואה על הנכס שלהם ומעבירים לכם. נחשב כהון עצמי כי יש בטוחה.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 pb-4 border-b border-border">
              <span class="w-8 h-8 bg-yellow-100 text-yellow-600 rounded-full flex items-center justify-center flex-shrink-0">~</span>
              <div>
                <h4 class="font-bold text-dark">הלוואה כנגד קרן השתלמות</h4>
                <p class="text-sm text-gray-600">אפשרי, אבל ההחזר החודשי נכנס לחישוב יחס ההחזר. עדיף לפדות את הקרן במקום.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="w-8 h-8 bg-red-100 text-red-600 rounded-full flex items-center justify-center flex-shrink-0">✗</span>
              <div>
                <h4 class="font-bold text-dark">הלוואה צרכנית רגילה</h4>
                <p class="text-sm text-gray-600">לא נחשבת הון עצמי. ההחזר החודשי נכנס ליחס ההחזר ומקטין את המשכנתא שתקבלו.</p>
              </div>
            </div>
          </div>
        </div>

        <h2 class="text-xl font-bold text-dark mt-8 mb-4">טיפים לצבירת הון עצמי</h2>
        <p>
          אם אתם עדיין בשלב החיסכון, הנה כמה טיפים פרקטיים:
        </p>
        <ul class="list-disc list-inside space-y-3 my-4">
          <li><strong>פתחו חשבון חיסכון נפרד:</strong> הפרידו את כסף הדירה מחשבון השוטף. זה גם מונע הוצאות מיותרות וגם מראה לבנק חיסכון עקבי.</li>
          <li><strong>הוראת קבע אוטומטית:</strong> קבעו העברה קבועה ביום המשכורת. מה שלא רואים - לא מוציאים.</li>
          <li><strong>השתמשו בקרן השתלמות:</strong> הפקדות פטורות ממס עד התקרה (2,756 ש"ח/חודש לשכיר). אחרי 6 שנים - משיכה ללא מס.</li>
          <li><strong>בדקו קופות גמל להשקעה:</strong> תשואה פוטנציאלית גבוהה יותר מפק"מ, משיכה לדירה בתנאים מועדפים.</li>
