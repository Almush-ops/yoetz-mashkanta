---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema, localBusinessSchema, trustBadges } from '../../data/consultant';

const articleSchema = {
  '@type': 'Article',
  headline: 'כמה עולה יועץ משכנתאות ולמה זה שווה',
  description: 'עלות ייעוץ משכנתאות בישראל: 3,000-8,000 ש"ח. מה כולל השירות, מתי זה משתלם, והאם החיסכון מצדיק את ההשקעה?',
  url: 'https://yoetz-mashkanta.co.il/guides/consultant-cost/',
  datePublished: '2026-01-20',
  dateModified: '2026-03-09',
  author: personSchema,
  publisher: {
    '@type': 'Organization',
    name: 'יועץ משכנתאות - איתי אנצל',
    url: 'https://yoetz-mashkanta.co.il',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://yoetz-mashkanta.co.il/guides/consultant-cost/',
  },
};

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'מדריכים', href: '/guides/' },
  { label: 'כמה עולה יועץ משכנתאות' },
];

const faqItems = [
  {
    question: 'כמה עולה יועץ משכנתאות בממוצע?',
    answer: 'עלות ייעוץ משכנתא נעה בין 3,000 ל-8,000 ש"ח. עסקאות פשוטות (שכירים, דירה ראשונה) בטווח הנמוך. עסקאות מורכבות (עצמאים, מסורבים, נכסים מיוחדים) בטווח הגבוה. חלק מהיועצים גובים אחוז מהמשכנתא (0.3%-0.5%).',
  },
  {
    question: 'מתי משלמים ליועץ משכנתאות?',
    answer: 'רוב היועצים גובים תשלום רק לאחר קבלת אישור עקרוני מהבנק - לא משלמים על שירות שלא הצליח. חלק גובים מקדמה קטנה (500-1,000 ש"ח) שמקוזזת מהסכום הסופי.',
  },
  {
    question: 'האם יועץ משכנתאות יכול לעבוד בחינם?',
    answer: 'יועץ שעובד בחינם מקבל עמלה מהבנק - מה שיוצר ניגוד עניינים. הוא ימליץ על הבנק שמשלם יותר, לא על הבנק שמתאים לכם. יועץ עצמאי שגובה מכם ישירות עובד לטובתכם בלבד.',
  },
  {
    question: 'כמה אפשר לחסוך עם יועץ משכנתאות?',
    answer: 'חיסכון ממוצע של 50,000-200,000 ש"ח לאורך חיי המשכנתא. החיסכון נובע מריבית נמוכה יותר (0.3%-0.5%), תמהיל מותאם, וניצול הטבות. עם עלות של 5,000 ש"ח, ה-ROI הוא פי 10-40.',
  },
  {
    question: 'מה כולל שירות יועץ משכנתאות?',
    answer: 'ניתוח פיננסי ובדיקת יכולת החזר, איסוף והכנת מסמכים, הגשה ל-5-7 בנקים, משא ומתן על תנאים, בניית תמהיל אופטימלי, בדיקת מסמכים לפני חתימה, וליווי עד העברת הכספים.',
  },
  {
    question: 'האם כדאי לקחת יועץ משכנתאות לכל עסקה?',
    answer: 'לא תמיד. עסקה פשוטה (שכירים, הון עצמי מסודר, דירה סטנדרטית) עם ידע בסיסי - אפשר להסתדר לבד. אבל ברוב המקרים, החיסכון מצדיק את ההשקעה. במיוחד: עצמאים, מסורבים, עסקאות מעל 1.5 מיליון, מחזור.',
  },
];

const pricingTiers = [
  {
    type: 'עסקה פשוטה',
    price: '3,000-4,500 ש"ח',
    suitable: 'שכירים, דירה ראשונה, הון עצמי מסודר',
    includes: ['ניתוח פיננסי', 'הגשה ל-5 בנקים', 'משא ומתן', 'ליווי בחתימה'],
  },
  {
    type: 'עסקה רגילה',
    price: '4,500-6,000 ש"ח',
    suitable: 'משפרי דיור, הון עצמי חלקי מהלוואות',
    includes: ['כל הנ"ל', 'בדיקת הלוואות משלימות', 'תיאום מכירה-רכישה', 'ליווי מורחב'],
  },
  {
    type: 'עסקה מורכבת',
    price: '6,000-8,000 ש"ח',
    suitable: 'עצמאים, מסורבים, נכסים מיוחדים',
    includes: ['כל הנ"ל', 'הכנת תיק מיוחד', 'פנייה לערוצים חלופיים', 'ליווי אינטנסיבי'],
  },
];

const savingsExamples = [
  {
    scenario: 'שיפור ריבית 0.3%',
    mortgage: '1,200,000 ש"ח',
    period: '25 שנה',
    saving: '70,000 ש"ח',
    monthly: '233 ש"ח פחות בחודש',
  },
  {
    scenario: 'שיפור ריבית 0.5%',
    mortgage: '1,500,000 ש"ח',
    period: '25 שנה',
    saving: '145,000 ש"ח',
    monthly: '483 ש"ח פחות בחודש',
  },
  {
    scenario: 'ניצול מענק זכאות',
    mortgage: '1,000,000 ש"ח',
    period: 'חד-פעמי',
    saving: '80,000 ש"ח',
    monthly: 'הפחתה בהון עצמי נדרש',
  },
  {
    scenario: 'מניעת תמהיל שגוי',
    mortgage: '1,300,000 ש"ח',
    period: '20 שנה',
    saving: '120,000 ש"ח',
    monthly: 'מניעת עליית החזר בעתיד',
  },
];
---

<BaseLayout
  title="כמה עולה יועץ משכנתאות ולמה זה שווה | מדריך מחירים 2026"
  description={'עלות יועץ משכנתאות: 3,000-8,000 ש"ח. מה כולל השירות, מתי משתלם, וכמה אפשר לחסוך. ROI של פי 10-40 על ההשקעה.'}
>
  <SchemaOrg slot="schema" schema={[articleSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">כמה עולה יועץ משכנתאות ולמה זה שווה</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        עלות ייעוץ משכנתא נעה בין 3,000 ל-8,000 ש"ח. נשמע הרבה? החיסכון הממוצע הוא 50,000-200,000 ש"ח. הנה כל מה שצריך לדעת לפני שמחליטים.
      </p>
      <!-- E-E-A-T Trust Badges -->
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {trustBadges.rating}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
          {trustBadges.clients}
        </span>
        <a href={consultant.hfcaUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full hover:bg-white/20 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          {trustBadges.hfca}
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          <strong>יועץ משכנתאות הוא מומחה שמלווה אתכם בתהליך המשכנתא ומייצג את האינטרסים שלכם</strong> - לא של הבנק. התפקיד שלו: להשיג לכם את התנאים הטובים ביותר, לבנות תמהיל שמתאים למצב שלכם, ולוודא שאתם לא עושים טעויות יקרות.
        </p>
        <p>
          השאלה היא לא רק "כמה זה עולה" אלא "מה אני מקבל תמורת הכסף" - וחשוב מכך: "כמה אני יכול להפסיד בלי יועץ".
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Tiers -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">מחירון ייעוץ משכנתאות 2026</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {pricingTiers.map((tier, index) => (
          <div class={`bg-white p-6 rounded-xl border-2 ${index === 1 ? 'border-brand-500 shadow-lg' : 'border-border'}`}>
            {index === 1 && (
              <span class="inline-block bg-brand-500 text-white text-xs px-2 py-1 rounded-full mb-3">הכי נפוץ</span>
            )}
            <h3 class="font-bold text-dark text-lg mb-2">{tier.type}</h3>
            <p class="text-2xl font-bold text-brand-600 mb-3">{tier.price}</p>
            <p class="text-sm text-gray-600 mb-4">{tier.suitable}</p>
            <ul class="space-y-2">
              {tier.includes.map((item) => (
                <li class="flex items-center gap-2 text-sm text-gray-700">
                  <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <p class="text-sm text-gray-500 mt-6 text-center">
        * חלק מהיועצים גובים אחוז מהמשכנתא (0.3%-0.5%) במקום מחיר קבוע
      </p>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">מה כולל שירות יועץ משכנתאות?</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            title: 'ניתוח פיננסי מקיף',
            desc: 'בדיקת הכנסות, הוצאות, חובות קיימים, ויכולת החזר. הגדרת תקציב ריאלי למשכנתא.',
            icon: '📊',
          },
          {
            title: 'הכנת תיק מסמכים',
            desc: 'ריכוז כל המסמכים הנדרשים בפורמט שמקובל בכל הבנקים. חיסכון בזמן ובסחבת.',
            icon: '📁',
          },
          {
            title: 'הגשה למספר בנקים',
            desc: 'הגשה ל-5-7 בנקים במקביל וקבלת הצעות. השוואה מקצועית של כל התנאים.',
            icon: '🏦',
          },
          {
            title: 'משא ומתן',
            desc: 'ניהול משא ומתן אפקטיבי מול כל הבנקים להשגת תנאים טובים יותר.',
            icon: '🤝',
          },
          {
            title: 'בניית תמהיל',
            desc: 'הרכבת תמהיל אופטימלי שמתאים ליכולת ההחזר, לתוכניות העתידיות, ולפרופיל הסיכון.',
            icon: '🧮',
          },
          {
            title: 'בדיקת מסמכים וליווי',
            desc: 'בדיקת כל מסמכי ההלוואה לפני חתימה. נוכחות (פיזית/טלפונית) בחתימה.',
            icon: '✅',
          },
        ].map((item) => (
          <div class="bg-surface p-6 rounded-xl border border-border">
            <div class="text-2xl mb-3">{item.icon}</div>
            <h3 class="font-bold text-dark mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Savings Examples -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">דוגמאות לחיסכון אמיתי</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {savingsExamples.map((example) => (
          <div class="bg-white p-6 rounded-xl border border-border">
            <h3 class="font-bold text-brand-600 mb-3">{example.scenario}</h3>
            <ul class="space-y-2 text-sm text-gray-700">
              <li><strong>משכנתא:</strong> {example.mortgage}</li>
              <li><strong>תקופה:</strong> {example.period}</li>
              <li class="text-lg font-bold text-green-600"><strong>חיסכון:</strong> {example.saving}</li>
              <li class="text-brand-600">{example.monthly}</li>
            </ul>
          </div>
        ))}
      </div>
      <div class="bg-brand-50 p-6 rounded-xl mt-8">
        <p class="text-center text-gray-700">
          <strong>עלות ייעוץ: ~5,000 ש"ח</strong> | <strong>חיסכון ממוצע: 50,000-200,000 ש"ח</strong>
          <br />
          <span class="text-brand-600 font-bold text-lg">ROI: פי 10-40 על ההשקעה</span>
        </p>
      </div>
    </div>
  </section>

  <!-- When Worth It / When Not -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">מתי כדאי יועץ ומתי לא?</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-green-50 p-6 rounded-xl border border-green-200">
          <h3 class="font-bold text-green-700 mb-4 text-lg">כדאי לקחת יועץ כשאתם:</h3>
          <ul class="space-y-2">
            {[
              'עצמאים או בעלי הכנסה לא קבועה',
              'מסורבים או עם היסטוריית אשראי בעייתית',
              'לוקחים משכנתא מעל 1.5 מיליון ש"ח',
              'רוכשים נכס מיוחד (מגרש, דירה על הנייר)',
              'לא בטוחים איזה תמהיל מתאים לכם',
              'ממחזרים משכנתא קיימת',
              'זוגות צעירים שרוצים לנצל הטבות',
            ].map((item) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-amber-50 p-6 rounded-xl border border-amber-200">
          <h3 class="font-bold text-amber-700 mb-4 text-lg">אפשר להסתדר בלי יועץ כשאתם:</h3>
          <ul class="space-y-2">
            {[
              'שכירים עם הכנסה יציבה וגבוהה',
              'הון עצמי מסודר (30%+ מהעסקה)',
              'רוכשים דירה סטנדרטית עד 1.2 מיליון',
              'מבינים בתמהילים ומסוגלים להשוות לבד',
              'יש לכם זמן לנהל משא ומתן עם בנקים',
              'כבר לקחתם משכנתא בעבר ומכירים את התהליך',
            ].map((item) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <svg class="w-4 h-4 text-amber-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Warning Signs -->
  <section class="py-12 md:py-16 bg-red-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">דגלים אדומים - מתי להיזהר מיועץ</h2>
      <div class="bg-white p-6 rounded-xl border border-red-200">
        <ul class="space-y-3">
          {[
            'יועץ שעובד בחינם - מקבל עמלה מהבנק ויש לו ניגוד עניינים',
            'דורש תשלום מראש לפני שהתחיל לעבוד',
            'מבטיח אישור 100% - אף אחד לא יכול להבטיח את זה',
            'לוחץ לחתום מהר בלי לתת זמן לחשוב',
            'לא מוכן להסביר את התמהיל או את ההצעות',
            'לא רשום בהתאחדות יועצי המשכנתאות (HFCA)',
          ].map((item) => (
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-red-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
