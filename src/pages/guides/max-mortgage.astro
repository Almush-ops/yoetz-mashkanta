---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema, localBusinessSchema, trustBadges } from '../../data/consultant';

const articleSchema = {
  '@type': 'Article',
  headline: 'כמה משכנתא אפשר לקבל? מדריך לחישוב יכולת ההלוואה',
  description: 'מדריך מקיף לחישוב כמה משכנתא אפשר לקבל: נוסחאות בנק ישראל, יחס החזר להכנסה, השפעת הגיל והמצב המשפחתי, וטיפים להגדלת סכום האישור.',
  author: personSchema,
  publisher: {
    '@type': 'Organization',
    name: consultant.company,
    url: consultant.siteUrl,
  },
  datePublished: '2026-03-10',
  dateModified: '2026-03-10',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://yoetz-mashkanta.co.il/guides/max-mortgage/',
  },
};

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'מדריכים', href: '/guides/' },
  { label: 'כמה משכנתא אפשר לקבל' },
];

const faqItems = [
  {
    question: 'מה יחס ההחזר המקסימלי שבנק ישראל מאפשר?',
    answer: 'בנק ישראל קבע שההחזר החודשי על המשכנתא לא יעלה על 40% מההכנסה הפנויה (נטו). בפועל, רוב הבנקים מאשרים עד 30-35% לרוב הלקוחות, ומגיעים ל-40% רק במקרים חזקים במיוחד.',
  },
  {
    question: 'האם הכנסה מעסק עצמאי נספרת?',
    answer: 'כן, הכנסה מעסק עצמאי נספרת, אך בצורה שונה. הבנקים מסתכלים על ממוצע ההכנסה מ-2 השנים האחרונות לפי שומות מס, ולפעמים מפחיתים 10-20% כ"מרווח ביטחון" בגלל התנודתיות בהכנסה.',
  },
  {
    question: 'איך הגיל משפיע על סכום המשכנתא?',
    answer: 'ככל שהגיל עולה, תקופת המשכנתא המקסימלית קטנה (רוב הבנקים דורשים שהמשכנתא תסתיים עד גיל 75-80). תקופה קצרה יותר = החזר חודשי גבוה יותר = סכום משכנתא נמוך יותר לאותה הכנסה.',
  },
  {
    question: 'האם הלוואות קיימות משפיעות על סכום המשכנתא?',
    answer: 'בהחלט. כל הלוואה קיימת (אשראי, ליסינג, הלוואה לרכב) מורידה את "ההכנסה הפנויה" ומקטינה את סכום המשכנתא שתוכלו לקבל. לפעמים כדאי לסגור הלוואות קטנות לפני בקשת משכנתא.',
  },
  {
    question: 'מה עושים אם סכום המשכנתא שאושר נמוך מהנדרש?',
    answer: 'יש כמה אפשרויות: להגדיל את ההון העצמי, לצרף לווה נוסף (הורה, בן זוג), להאריך את תקופת המשכנתא, לסגור הלוואות קיימות, או לחפש דירה זולה יותר. יועץ משכנתאות יכול לעזור למצוא את הפתרון המתאים.',
  },
  {
    question: 'האם אפשר לקבל משכנתא גדולה יותר מהכנסות השכירות?',
    answer: 'הכנסות משכירות נספרות, אך בדרך כלל רק 70-80% מהן (בגלל סיכון פינוי דייר). כדי לסמוך על הכנסה משכירות, צריך להוכיח שיש חוזה שכירות תקף ושהנכס אכן מושכר.',
  },
];
---

<BaseLayout
  title="כמה משכנתא אפשר לקבל? מדריך לחישוב יכולת ההלוואה 2026"
  description="מדריך מקיף לחישוב כמה משכנתא אפשר לקבל: נוסחאות בנק ישראל, יחס החזר להכנסה 30-40%, השפעת גיל ומצב משפחתי, וטיפים להגדלת סכום האישור."
>
  <SchemaOrg slot="schema" schema={[articleSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="inline-block bg-white/20 text-white text-sm font-medium px-3 py-1 rounded-full mb-4">מדריך מקיף</span>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">כמה משכנתא אפשר לקבל?</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        מדריך לחישוב סכום המשכנתא המקסימלי שתוכלו לקבל, על פי כללי בנק ישראל והבנקים בפועל.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {trustBadges.rating}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          {trustBadges.clients}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          {trustBadges.hfca}
        </span>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <article class="prose max-w-none">
        <h2>הנוסחה הבסיסית לחישוב משכנתא</h2>
        <p>
          סכום המשכנתא שתוכלו לקבל תלוי בעיקר ב-<strong>שני גורמים מרכזיים</strong>:
        </p>
        <ol>
          <li><strong>יכולת ההחזר</strong> - כמה אתם יכולים להחזיר בחודש על פי ההכנסות שלכם</li>
          <li><strong>שווי הנכס</strong> - כמה שווה הדירה שאתם רוצים לקנות (אחוזי מימון)</li>
        </ol>

        <div class="bg-brand-50 border-r-4 border-brand-500 p-6 rounded-lg my-8 not-prose">
          <h3 class="text-lg font-semibold text-dark mb-2">נוסחת אצבע מהירה</h3>
          <p class="text-gray-700 text-lg font-medium">
            הכנסה נטו × 300 = סכום משכנתא מקסימלי משוער
          </p>
          <p class="text-gray-600 text-sm mt-2">
            לדוגמה: הכנסה של 15,000 ₪ × 300 = משכנתא של כ-4.5 מיליון ₪ (בתקופה של 30 שנה)
          </p>
        </div>

        <h2>כללי בנק ישראל לשנת 2026</h2>
        <p>
          בנק ישראל קבע מספר מגבלות על משכנתאות:
        </p>

        <h3>יחס החזר להכנסה (PTI - Payment to Income)</h3>
        <ul>
          <li><strong>מקסימום 40%</strong> מההכנסה הפנויה יכול ללכת להחזר משכנתא</li>
          <li>בפועל, רוב הבנקים מאשרים <strong>30-35%</strong> לרוב הלקוחות</li>
          <li>40% מאושר רק ללקוחות עם פרופיל חזק במיוחד</li>
        </ul>

        <h3>אחוזי מימון (LTV - Loan to Value)</h3>
        <table>
          <thead>
            <tr>
              <th>סוג נכס</th>
              <th>מימון מקסימלי</th>
              <th>הון עצמי מינימלי</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>דירה ראשונה</td>
              <td>75%</td>
              <td>25%</td>
            </tr>
            <tr>
              <td>דירה להשקעה</td>
              <td>50%</td>
              <td>50%</td>
            </tr>
            <tr>
              <td>משפרי דיור</td>
              <td>70%</td>
              <td>30%</td>
            </tr>
          </tbody>
        </table>

        <h2>דוגמאות חישוב מעשיות</h2>

        <h3>דוגמה 1: זוג צעיר שכירים</h3>
        <div class="bg-surface border border-border p-6 rounded-lg my-4 not-prose">
          <p class="text-gray-600 mb-2"><strong>נתונים:</strong></p>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>הכנסה משותפת: 22,000 ₪ נטו</li>
            <li>גיל: 30</li>
            <li>הון עצמי: 400,000 ₪</li>
            <li>אין הלוואות קיימות</li>
          </ul>
          <p class="text-gray-600 mt-4 mb-2"><strong>חישוב:</strong></p>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>יחס החזר 35%: 22,000 × 35% = 7,700 ₪ לחודש</li>
            <li>תקופה: 30 שנה (360 תשלומים)</li>
            <li>ריבית משוערת: 4.5%</li>
            <li><strong>סכום משכנתא: כ-1,520,000 ₪</strong></li>
            <li>+ הון עצמי 400,000 ₪ = <strong>דירה עד 1.92 מיליון ₪</strong></li>
          </ul>
        </div>

        <h3>דוגמה 2: עצמאי עם הכנסה גבוהה</h3>
        <div class="bg-surface border border-border p-6 rounded-lg my-4 not-prose">
          <p class="text-gray-600 mb-2"><strong>נתונים:</strong></p>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>הכנסה: 40,000 ₪ (ממוצע שנתי משומות)</li>
            <li>גיל: 45</li>
            <li>הון עצמי: 800,000 ₪</li>
            <li>הלוואה לרכב: 1,500 ₪/חודש</li>
          </ul>
          <p class="text-gray-600 mt-4 mb-2"><strong>חישוב:</strong></p>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>הכנסה מותאמת (עצמאי): 40,000 × 85% = 34,000 ₪</li>
            <li>יחס החזר 33%: 34,000 × 33% = 11,220 ₪</li>
            <li>פחות הלוואת רכב: 11,220 - 1,500 = 9,720 ₪ לחודש</li>
            <li>תקופה: 25 שנה (עד גיל 70)</li>
            <li><strong>סכום משכנתא: כ-1,650,000 ₪</strong></li>
            <li>+ הון עצמי 800,000 ₪ = <strong>דירה עד 2.45 מיליון ₪</strong></li>
          </ul>
        </div>

        <h2>גורמים שמשפיעים על סכום המשכנתא</h2>

        <h3>1. סוג ההכנסה</h3>
        <ul>
          <li><strong>שכיר קבוע</strong> - ההכנסה הכי "חזקה" בעיני הבנקים</li>
          <li><strong>עצמאי</strong> - מקבל "תספורת" של 10-20% על ההכנסה</li>
          <li><strong>עמלות ובונוסים</strong> - נספרים חלקית (50-70%)</li>
          <li><strong>הכנסה משכירות</strong> - נספרת ב-70-80%</li>
        </ul>

        <h3>2. גיל הלווים</h3>
        <p>
          הבנקים דורשים שהמשכנתא תסתיים עד גיל 75-80. ככל שהגיל עולה, תקופת המשכנתא האפשרית קצרה יותר, מה שמגדיל את ההחזר החודשי ומקטין את סכום המשכנתא האפשרי.
        </p>

        <h3>3. היסטוריית אשראי</h3>
        <p>
          דירוג אשראי גבוה מאפשר לקבל תנאים טובים יותר ולפעמים גם סכומים גבוהים יותר. בעיות אשראי בעבר יכולות להגביל את האפשרויות.
        </p>

        <h3>4. מקצוע ויציבות תעסוקתית</h3>
        <p>
          מקצועות "יציבים" (רופאים, עורכי דין, מהנדסים, עובדי מדינה) מקבלים יחס טוב יותר. ותק במקום העבודה (3+ שנים) משפר את הסיכויים.
        </p>

        <h2>איך להגדיל את סכום המשכנתא?</h2>

        <h3>1. צרפו לווה נוסף</h3>
        <p>הורה או בן זוג עם הכנסה נוספת יכולים להגדיל משמעותית את יכולת ההלוואה.</p>

        <h3>2. סגרו הלוואות קיימות</h3>
        <p>כל הלוואה שתסגרו מפנה "מקום" להחזר משכנתא גדול יותר.</p>

        <h3>3. הגדילו את ההון העצמי</h3>
        <p>יותר הון עצמי = פחות צורך במימון = דירה יקרה יותר אפשרית.</p>

        <h3>4. האריכו את תקופת המשכנתא</h3>
        <p>תקופה ארוכה יותר = החזר חודשי נמוך יותר = סכום גבוה יותר. אך שימו לב שתשלמו יותר ריבית סה"כ.</p>

        <h3>5. בחרו בנק מתאים</h3>
        <p>בנקים שונים מעריכים מקרים בצורה שונה. בנק שאחד מסרב, אחר עשוי לאשר סכום גבוה יותר.</p>

        <div class="bg-accent-50 border-r-4 border-accent-500 p-6 rounded-lg my-8 not-prose">
          <h3 class="text-lg font-semibold text-dark mb-2">טיפ מקצועי</h3>
          <p class="text-gray-600">
            השתמשו ב<a href="/tools/eligibility-calculator/" class="text-accent-600 hover:underline">מחשבון הזכאות שלנו</a> לקבלת הערכה ראשונית. לחישוב מדויק, צרו קשר לפגישת ייעוץ - נבדוק את המצב שלכם לעומק ונמצא את הפתרון המתאים.
          </p>
        </div>

        <h2>מה קורה אם הסכום שאושר לא מספיק?</h2>
        <p>
          אם סכום המשכנתא שאושר נמוך מהנדרש, יש כמה אפשרויות:
        </p>
        <ul>
          <li><strong>לחפש דירה בתקציב</strong> - לפעמים זו האפשרות הכי הגיונית</li>
          <li><strong>לחכות ולחסוך עוד</strong> - להגדיל את ההון העצמי</li>
          <li><strong>הלוואה מההורים</strong> - בתנאים מסוימים נספרת כהון עצמי</li>
          <li><strong>לצרף לווה</strong> - הורה או בן משפחה</li>
          <li><strong>לבחון אזורים אחרים</strong> - לפעמים אזור סמוך זול יותר משמעותית</li>
        </ul>

        <h2>סיכום</h2>
        <p>
          סכום המשכנתא שתוכלו לקבל תלוי בהכנסה, בגיל, בהון העצמי, ובהתחייבויות קיימות. הנוסחה הבסיסית היא יחס החזר של 30-40% מההכנסה, אך כל מקרה נבחן לגופו.
        </p>
        <p>
          רוצים לדעת בדיוק כמה משכנתא תוכלו לקבל? <a href="/contact/">צרו קשר</a> לפגישת ייעוץ חינם ונחשב את זה יחד.
        </p>

        <h2>מדריכים נוספים</h2>
        <ul>
          <li><a href="/guides/pre-approval/">אישור עקרוני למשכנתא - מה זה ואיך מקבלים</a></li>
          <li><a href="/guides/down-payment/">כמה הון עצמי צריך למשכנתא?</a></li>
          <li><a href="/guides/mortgage-mix/">תמהיל משכנתא מומלץ 2026</a></li>
          <li><a href="/tools/mortgage-calculator/">מחשבון משכנתא אונליין</a></li>
        </ul>
      </article>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-3xl mx-auto px-4">
      <FAQ title="שאלות נפוצות על סכום המשכנתא" items={faqItems} />
    </div>
  </section>

  <CTASection
    title="רוצים לדעת כמה משכנתא תוכלו לקבל?"
    subtitle="פגישת ייעוץ ראשונית ללא עלות - נחשב את זה יחד"
    primaryText="לתיאום פגישה"
    primaryHref="/contact/"
    phone="055-432-6608"
  />
</BaseLayout>
