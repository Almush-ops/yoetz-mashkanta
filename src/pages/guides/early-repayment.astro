---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema, localBusinessSchema, trustBadges } from '../../data/consultant';

const articleSchema = {
  '@type': 'Article',
  headline: 'עמלת פירעון מוקדם - כל מה שצריך לדעת לפני שמחזרים או סוגרים משכנתא',
  description: 'מדריך מקיף לעמלת פירעון מוקדם: מתי חלה עמלה, כמה עולה, איך לחשב, מתי משתלם לשלם אותה, וטיפים לחיסכון.',
  author: personSchema,
  publisher: {
    '@type': 'Organization',
    name: consultant.company,
    url: consultant.siteUrl,
  },
  datePublished: '2026-03-10',
  dateModified: '2026-03-10',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://yoetz-mashkanta.co.il/guides/early-repayment/',
  },
};

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'מדריכים', href: '/guides/' },
  { label: 'עמלת פירעון מוקדם' },
];

const faqItems = [
  {
    question: 'האם יש עמלה על סגירת משכנתא מכספי מכירת דירה?',
    answer: 'לא, אם אתם סוגרים את המשכנתא כחלק ממכירת הנכס הממושכן, אתם פטורים מעמלת פירעון מוקדם. זה נקרא "פטור מעבר דירה" והוא קבוע בחוק.',
  },
  {
    question: 'כמה פעמים בשנה אפשר לפרוע בלי עמלה?',
    answer: 'החוק מאפשר פירעון מוקדם של עד 20% מיתרת הקרן בשנה ללא עמלה. אפשר לפרוע בתשלום אחד או לפצל למספר תשלומים, כל עוד הסכום הכולל לא עובר את ה-20%.',
  },
  {
    question: 'מתי הזמן הטוב ביותר לפרוע מוקדם?',
    answer: 'בדרך כלל בתחילת החודש (ולא בסוף), ובתאריכים קרובים ליום התשלום החודשי. כך תחסכו ריבית של ימים נוספים. כדאי גם להתייעץ לגבי התזמון ביחס לשינויי ריבית צפויים.',
  },
  {
    question: 'האם עמלת היוון חלה גם על מסלול פריים?',
    answer: 'מסלול פריים הוא מסלול בריבית משתנה, ולכן לרוב לא חלה עליו עמלת היוון. העמלה המקסימלית על פריים היא עמלת אי-הודעה מוקדמת (כ-0.1%) ועמלה תפעולית קטנה.',
  },
  {
    question: 'האם אפשר לנהל משא ומתן על עמלת הפירעון?',
    answer: 'בגבולות מסוימים, כן. הבנק יכול לתת הנחה על העמלה התפעולית ולפעמים גם על עמלת ההיוון, במיוחד אם אתם לקוחות טובים או אם אתם מאיימים לעבור לבנק אחר במחזור.',
  },
  {
    question: 'מה עדיף - לפרוע מוקדם או להשקיע את הכסף?',
    answer: 'תלוי בריבית על המשכנתא לעומת התשואה הצפויה על ההשקעה. אם המשכנתא ב-4% ואתם יכולים להשיג 6% נטו על השקעה - עדיף להשקיע. אבל צריך לקחת בחשבון גם סיכון וודאות.',
  },
];
---

<BaseLayout
  title="עמלת פירעון מוקדם - מדריך מקיף לחישוב ולחיסכון 2026"
  description="מדריך מקיף לעמלת פירעון מוקדם: מתי חלה עמלה, כמה עולה (0.1%-2%), איך לחשב, פטורים (20% בשנה, מכירת דירה), וטיפים לחיסכון במחזור משכנתא."
>
  <SchemaOrg slot="schema" schema={[articleSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="inline-block bg-white/20 text-white text-sm font-medium px-3 py-1 rounded-full mb-4">מדריך מקיף</span>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">עמלת פירעון מוקדם - כל מה שצריך לדעת</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        מתכננים לסגור או למחזר את המשכנתא? חשוב להבין מה עמלת הפירעון המוקדם, מתי היא חלה, ואיך אפשר לחסוך עליה.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {trustBadges.rating}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          {trustBadges.clients}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          {trustBadges.hfca}
        </span>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <article class="prose max-w-none">
        <h2>מה זה עמלת פירעון מוקדם?</h2>
        <p>
          <strong>עמלת פירעון מוקדם</strong> היא תשלום שהבנק גובה כשאתם סוגרים או מקטינים את המשכנתא לפני תום התקופה המקורית. העמלה נועדה לפצות את הבנק על אובדן הריבית העתידית שהיה צפוי לקבל.
        </p>

        <div class="bg-brand-50 border-r-4 border-brand-500 p-6 rounded-lg my-8 not-prose">
          <h3 class="text-lg font-semibold text-dark mb-2">למה הבנק גובה עמלה?</h3>
          <p class="text-gray-600">
            הבנק מממן את המשכנתא שלכם מכסף שהוא עצמו לווה (מפיקדונות או שוק ההון). אם אתם מחזירים מוקדם, הבנק עלול להישאר עם עלויות מימון שהוא לא יכול לכסות בריבית שלכם.
          </p>
        </div>

        <h2>סוגי עמלות הפירעון המוקדם</h2>

        <h3>1. עמלת היוון (הגדולה ביותר)</h3>
        <p>
          עמלה שחלה על מסלולים בריבית <strong>קבועה</strong> (קל"צ, קבועה צמודה, קבועה לא צמודה). היא מחושבת לפי ההפרש בין הריבית שלכם לריבית הנוכחית בשוק.
        </p>
        <ul>
          <li><strong>אם הריבית ירדה</strong> - תשלמו עמלה גבוהה (הבנק מפסיד כי נתן לכם ריבית גבוהה)</li>
          <li><strong>אם הריבית עלתה</strong> - העמלה נמוכה או אפסית (הבנק ירוויח מהלוואה חדשה)</li>
        </ul>

        <h3>2. עמלת אי-הודעה מוקדמת</h3>
        <p>
          אם לא נתתם הודעה מראש על כוונה לפרוע, הבנק יכול לגבות עמלה של עד <strong>0.1%</strong> מהסכום הנפרע. ניתן להימנע ממנה על ידי מתן הודעה 10-45 יום מראש (תלוי בבנק).
        </p>

        <h3>3. עמלה תפעולית</h3>
        <p>
          עמלה קבועה של <strong>60-300 ₪</strong> שמכסה את העלות הניהולית של הפעולה. זו עמלה קטנה יחסית.
        </p>

        <h2>טבלת עמלות לפי מסלול</h2>
        <table>
          <thead>
            <tr>
              <th>מסלול</th>
              <th>עמלת היוון</th>
              <th>הערות</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>פריים</td>
              <td>אין</td>
              <td>ריבית משתנה - אין עמלת היוון</td>
            </tr>
            <tr>
              <td>משתנה כל 5 שנים</td>
              <td>אין</td>
              <td>ריבית משתנה - אין עמלת היוון</td>
            </tr>
            <tr>
              <td>קבועה לא צמודה</td>
              <td>עד 2%</td>
              <td>תלוי בהפרש הריביות</td>
            </tr>
            <tr>
              <td>קבועה צמודה (קל"צ)</td>
              <td>עד 2%</td>
              <td>תלוי בהפרש הריביות + הצמדה</td>
            </tr>
          </tbody>
        </table>

        <h2>פטורים מעמלת פירעון מוקדם</h2>

        <h3>1. פטור 20% בשנה</h3>
        <p>
          החוק מאפשר לפרוע עד <strong>20% מיתרת הקרן בשנה</strong> ללא עמלה כלל. זה מצטבר - אם לא פרעתם בשנה שעברה, אתם עדיין יכולים לפרוע 20% השנה.
        </p>

        <h3>2. פטור מכירת דירה</h3>
        <p>
          אם אתם סוגרים את המשכנתא כחלק ממכירת הנכס הממושכן, אתם <strong>פטורים לחלוטין</strong> מעמלת פירעון מוקדם.
        </p>

        <h3>3. פטור בתום תקופת ריבית</h3>
        <p>
          במסלולים עם ריבית משתנה לתקופות (כל 5 שנים, כל 3 שנים), ב-<strong>30 הימים לפני ואחרי</strong> תום התקופה אין עמלת היוון.
        </p>

        <h3>4. פטור עד 3 שנים מהלקיחה</h3>
        <p>
          ב-3 השנים הראשונות של המשכנתא, עמלת ההיוון מוגבלת. אחרי 3 שנים, אין הגבלה.
        </p>

        <div class="bg-accent-50 border-r-4 border-accent-500 p-6 rounded-lg my-8 not-prose">
          <h3 class="text-lg font-semibold text-dark mb-2">דוגמה לחישוב</h3>
          <p class="text-gray-700 mb-4">
            <strong>מצב:</strong> יתרת קרן 600,000 ₪, מסלול קבוע לא צמוד, ריבית 4.5%, ריבית נוכחית בשוק 3.5%
          </p>
          <ul class="text-gray-600 space-y-1">
            <li>הפרש ריביות: 1% לטובת הבנק</li>
            <li>תקופה שנותרה: 15 שנים</li>
            <li>עמלת היוון משוערת: כ-1.2% = <strong>7,200 ₪</strong></li>
            <li>+ עמלה תפעולית: 150 ₪</li>
            <li><strong>סה"כ: כ-7,350 ₪</strong></li>
          </ul>
        </div>

        <h2>מתי משתלם לשלם את העמלה?</h2>
        <p>
          פירעון מוקדם עם עמלה משתלם כשהחיסכון בריבית גדול מעלות העמלה:
        </p>
        <ul>
          <li><strong>מחזור משכנתא</strong> - אם הריבית החדשה נמוכה מספיק כדי לכסות את העמלה תוך 2-3 שנים</li>
          <li><strong>קבלת ירושה/בונוס</strong> - אם הכסף יושב בחשבון בלי לעבוד, עדיף לפרוע</li>
          <li><strong>שיפור תזרים</strong> - לפעמים הורדת ההחזר החודשי שווה את העמלה</li>
        </ul>

        <h2>טיפים לחיסכון בעמלת פירעון</h2>

        <h3>1. נצלו את הפטור של 20%</h3>
        <p>בכל שנה תוכלו לפרוע 20% ללא עמלה. תכננו מראש ותפרעו בפעימות.</p>

        <h3>2. תזמנו את הפירעון נכון</h3>
        <p>במסלולים עם ריבית משתנה לתקופות, המתינו לתום התקופה.</p>

        <h3>3. תנו הודעה מראש</h3>
        <p>הודעה של 10-45 יום מראש חוסכת את עמלת אי-ההודעה המוקדמת.</p>

        <h3>4. השוו בין בנקים במחזור</h3>
        <p>לפעמים הבנק החדש יכסה חלק מעמלת הפירעון כדי "לקנות" אתכם.</p>

        <h3>5. נהלו משא ומתן</h3>
        <p>הבנק יכול לתת הנחה על העמלה התפעולית ולפעמים גם על ההיוון.</p>

        <h2>איך מחשבים אם מחזור משתלם?</h2>
        <p>
          החישוב הבסיסי:
        </p>
        <ol>
          <li>חשבו את <strong>עלות העמלה</strong> הצפויה</li>
          <li>חשבו את <strong>החיסכון בריבית</strong> במחזור</li>
          <li>חלקו את העמלה בחיסכון החודשי = <strong>תקופת החזר</strong></li>
        </ol>
        <p>
          אם תקופת ההחזר קצרה מהתקופה שנותרה - המחזור משתלם.
        </p>

        <div class="bg-surface border border-border p-6 rounded-lg my-8 not-prose">
          <h3 class="text-lg font-semibold text-dark mb-2">דוגמה</h3>
          <p class="text-gray-600 mb-2">
            עמלת פירעון: 5,000 ₪<br>
            חיסכון חודשי בריבית: 400 ₪<br>
            תקופת החזר: 5,000 ÷ 400 = <strong>12.5 חודשים</strong>
          </p>
          <p class="text-gray-600">
            אם נותרו יותר מ-12.5 חודשים למשכנתא - המחזור משתלם!
          </p>
        </div>

        <h2>סיכום</h2>
        <p>
          עמלת פירעון מוקדם יכולה להיות משמעותית במסלולים בריבית קבועה, אך יש דרכים לחסוך: פטור 20% שנתי, פטור מכירת דירה, תזמון נכון, ומשא ומתן. לפני כל החלטה על מחזור או פירעון מוקדם, כדאי לבדוק בדיוק מה העמלה ומה החיסכון הצפוי.
        </p>
        <p>
          רוצים לבדוק אם מחזור או פירעון מוקדם משתלם לכם? <a href="/contact/">צרו קשר</a> לחישוב מדויק.
        </p>

        <h2>מדריכים נוספים</h2>
        <ul>
          <li><a href="/guides/refinancing/">מחזור משכנתא - מתי כדאי ואיך לעשות נכון</a></li>
          <li><a href="/guides/mortgage-mix/">תמהיל משכנתא מומלץ 2026</a></li>
          <li><a href="/tools/refinance-calculator/">מחשבון כדאיות מחזור</a></li>
          <li><a href="/services/mortgage-refinance/">שירות מחזור משכנתא</a></li>
        </ul>
      </article>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-3xl mx-auto px-4">
      <FAQ title="שאלות נפוצות על עמלת פירעון מוקדם" items={faqItems} />
    </div>
  </section>

  <CTASection
    title="רוצים לבדוק אם מחזור משתלם?"
    subtitle="פגישת ייעוץ ראשונית ללא עלות - נחשב את העמלה והחיסכון יחד"
    primaryText="לתיאום פגישה"
    primaryHref="/contact/"
    phone="055-432-6608"
  />
</BaseLayout>
