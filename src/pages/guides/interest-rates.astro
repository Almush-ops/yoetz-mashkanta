---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema, localBusinessSchema, trustBadges } from '../../data/consultant';

const articleSchema = {
  '@type': 'Article',
  headline: 'ריביות משכנתא 2026 - מה צריך לדעת',
  description: 'סקירת ריביות משכנתא עדכנית: פריים 6.25%, קל"צ 4-5%, קל"מ 5-6%. השפעת בנק ישראל, תחזיות, ואיך לבחור מסלול.',
  url: 'https://yoetz-mashkanta.co.il/guides/interest-rates/',
  datePublished: '2026-02-01',
  dateModified: '2026-03-09',
  author: personSchema,
  publisher: {
    '@type': 'Organization',
    name: 'יועץ משכנתאות - איתי אנצל',
    url: 'https://yoetz-mashkanta.co.il',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://yoetz-mashkanta.co.il/guides/interest-rates/',
  },
};

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'מדריכים', href: '/guides/' },
  { label: 'ריביות משכנתא 2026' },
];

const faqItems = [
  {
    question: 'מהי ריבית הפריים הנוכחית?',
    answer: 'ריבית הפריים כיום עומדת על 6.25% (מרץ 2026). ריבית הפריים = ריבית בנק ישראל (4.75%) + מרווח קבוע (1.5%). כשבנק ישראל מעלה או מוריד ריבית, הפריים משתנה בהתאם באותו שיעור.',
  },
  {
    question: 'מה ההבדל בין קל"צ לקל"מ?',
    answer: 'קל"צ (קבועה לא צמודה) = ריבית קבועה שלא משתנה כל התקופה, אך חשופה לאינפלציה בערך הכסף. קל"מ (קבועה צמודה למדד) = ריבית נמוכה יותר אך הקרן עולה עם המדד. בתקופות של אינפלציה גבוהה, קל"מ עלולה להיות יקרה יותר.',
  },
  {
    question: 'האם צפויה הורדת ריבית ב-2026?',
    answer: 'לפי תחזיות בנק ישראל, צפויות הורדות ריבית מתונות של 0.25%-0.5% במהלך 2026. זה תלוי באינפלציה ובמצב הכלכלי. אם האינפלציה תמשיך לרדת, סביר שנראה ירידה בריבית הפריים.',
  },
  {
    question: 'איזה מסלול הכי משתלם ב-2026?',
    answer: 'אין תשובה אחת - תלוי במצב האישי. באופן כללי: תמהיל מפוזר (שליש פריים, שליש קבועה, שליש משתנה) מגן מסיכונים. בסביבת ריבית גבוהה עם ציפייה לירידה, אפשר להגדיל את חלק הפריים.',
  },
  {
    question: 'כמה עולה הפרש של 0.5% בריבית?',
    answer: 'על משכנתא של 1.2 מיליון ש"ח ל-25 שנה: הפרש של 0.5% בריבית = כ-115,000 ש"ח לאורך חיי ההלוואה, או כ-380 ש"ח בחודש. לכן משא ומתן על ריבית הוא קריטי.',
  },
  {
    question: 'האם כדאי לממחזר משכנתא עכשיו?',
    answer: 'תלוי בריבית הנוכחית שלכם ובעלויות המחזור. כלל אצבע: אם אפשר לשפר את הריבית ב-0.5% או יותר, ונותרו לפחות 10 שנים - כדאי לבדוק מחזור. יש לקחת בחשבון עלויות: קנס פירעון (עד 3%), עו"ד, שמאי.',
  },
];

const currentRates = [
  {
    type: 'פריים',
    rate: '6.25%',
    change: 'ללא שינוי',
    trend: 'stable',
    description: 'ריבית משתנה הצמודה לריבית בנק ישראל',
    pros: ['גמישות - אפשר לפרוע בכל עת', 'יורדת כשהריבית במשק יורדת', 'החזר נמוך יחסית בהתחלה'],
    cons: ['חשיפה לעליית ריבית', 'אי-ודאות בהחזר החודשי', 'עלולה להפתיע בעליות חדות'],
  },
  {
    type: 'קל"צ (קבועה לא צמודה)',
    rate: '4.0%-5.0%',
    change: '-0.2%',
    trend: 'down',
    description: 'ריבית קבועה לכל התקופה, לא צמודה למדד',
    pros: ['ודאות - ההחזר לא משתנה', 'הגנה מעליית ריבית', 'תכנון פיננסי קל יותר'],
    cons: ['ריבית גבוהה יחסית', 'קנס פירעון מוקדם', 'לא נהנים מירידת ריבית'],
  },
  {
    type: 'קל"מ (קבועה צמודה למדד)',
    rate: '3.5%-4.5%',
    change: 'ללא שינוי',
    trend: 'stable',
    description: 'ריבית קבועה נמוכה, אבל הקרן צמודה לאינפלציה',
    pros: ['ריבית נמוכה יחסית', 'החזר נמוך בהתחלה', 'מתאים לתקופות של אינפלציה נמוכה'],
    cons: ['הקרן עולה עם המדד', 'אי-ודאות בסכום הסופי', 'מסוכן באינפלציה גבוהה'],
  },
  {
    type: 'משתנה כל 5 שנים',
    rate: '4.2%-5.2%',
    change: '-0.15%',
    trend: 'down',
    description: 'ריבית שמשתנה פעם ב-5 שנים לפי השוק',
    pros: ['ודאות ל-5 שנים', 'ריבית נמוכה מקבועה', 'איזון בין סיכון לביטחון'],
    cons: ['אי-ודאות אחרי 5 שנים', 'קשה לתכנן לטווח ארוך', 'תלוי במצב השוק'],
  },
];

const historicalData = [
  { year: '2020', prime: '1.6%', fixed: '2.5%-3.5%' },
  { year: '2021', prime: '1.6%', fixed: '2.8%-3.8%' },
  { year: '2022', prime: '2.75%', fixed: '3.5%-4.5%' },
  { year: '2023', prime: '6.0%', fixed: '4.5%-5.5%' },
  { year: '2024', prime: '6.5%', fixed: '4.2%-5.2%' },
  { year: '2025', prime: '6.25%', fixed: '4.0%-5.0%' },
  { year: '2026 (מרץ)', prime: '6.25%', fixed: '4.0%-5.0%' },
];

const recommendedMixes = [
  {
    profile: 'שמרני - מעדיף ודאות',
    mix: '20% פריים + 50% קל"צ + 30% משתנה 5 שנים',
    suitable: 'משפחות עם הכנסה קבועה שרוצות לדעת בדיוק מה יהיה ההחזר',
    risk: 'נמוך',
  },
  {
    profile: 'מאוזן - הסטנדרט',
    mix: '33% פריים + 33% קל"צ + 34% משתנה 5 שנים',
    suitable: 'רוב האנשים - פיזור סיכונים ואיזון בין עלות לביטחון',
    risk: 'בינוני',
  },
  {
    profile: 'אגרסיבי - מאמין בירידת ריבית',
    mix: '50% פריים + 25% קל"צ + 25% משתנה 5 שנים',
    suitable: 'מי שמאמין שהריבית תרד ומוכן לקחת סיכון',
    risk: 'גבוה',
  },
  {
    profile: 'תזרימי - מקסום החזר נמוך',
    mix: '40% פריים + 20% קל"צ + 40% קל"מ',
    suitable: 'מי שרוצה החזר נמוך בהתחלה (עלול להיות יקר יותר בסוף)',
    risk: 'בינוני-גבוה',
  },
];
---

<BaseLayout
  title="ריביות משכנתא 2026 - מה צריך לדעת | עדכון מרץ"
  description={'ריביות משכנתא עדכניות מרץ 2026: פריים 6.25%, קל"צ 4-5%, קל"מ 3.5-4.5%. תחזיות, השוואה, ואיך לבחור את המסלול הנכון.'}
>
  <SchemaOrg slot="schema" schema={[articleSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">ריביות משכנתא 2026 - מה צריך לדעת</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        סקירה מעודכנת של ריביות המשכנתא בישראל: מצב נוכחי, תחזיות, והשפעה על בחירת התמהיל. עדכון אחרון: מרץ 2026.
      </p>
      <!-- E-E-A-T Trust Badges -->
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {trustBadges.rating}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
          {trustBadges.clients}
        </span>
        <a href={consultant.hfcaUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full hover:bg-white/20 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          {trustBadges.hfca}
        </a>
      </div>
    </div>
  </section>

  <!-- Current Interest Rate -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-brand-50 p-6 rounded-xl border border-brand-200 mb-8">
        <div class="flex flex-wrap justify-center gap-8 text-center">
          <div>
            <span class="block text-sm text-gray-600 mb-1">ריבית בנק ישראל</span>
            <span class="block text-3xl font-bold text-brand-700">4.75%</span>
          </div>
          <div>
            <span class="block text-sm text-gray-600 mb-1">ריבית פריים</span>
            <span class="block text-3xl font-bold text-brand-700">6.25%</span>
          </div>
          <div>
            <span class="block text-sm text-gray-600 mb-1">עדכון אחרון</span>
            <span class="block text-3xl font-bold text-brand-700">מרץ 2026</span>
          </div>
        </div>
      </div>

      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          <strong>ריבית בנק ישראל עומדת על 4.75% (מרץ 2026)</strong>, וריבית הפריים על 6.25% (פריים = ריבית בנק ישראל + 1.5%). לאחר שנתיים של עליות חדות (מ-0.1% ב-2021 ל-4.75% ב-2024), הריבית מתייצבת עם מגמה קלה של ירידה.
        </p>
        <p>
          המשמעות: מי שלקח משכנתא ב-2021 עם 100% פריים ראה עלייה של כ-3,000 ש"ח בהחזר החודשי. מי שנכנס היום לשוק צריך להתחשב בריבית הגבוהה ולבנות תמהיל מתאים.
        </p>
      </div>
    </div>
  </section>

  <!-- Current Rates Table -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">ריביות לפי מסלול - מרץ 2026</h2>
      <div class="space-y-6">
        {currentRates.map((rate) => (
          <div class="bg-white p-6 rounded-xl border border-border">
            <div class="flex flex-wrap justify-between items-start gap-4 mb-4">
              <div>
                <h3 class="font-bold text-dark text-lg">{rate.type}</h3>
                <p class="text-gray-600 text-sm">{rate.description}</p>
              </div>
              <div class="text-left">
                <span class="block text-2xl font-bold text-brand-600">{rate.rate}</span>
                <span class={`text-sm ${rate.trend === 'down' ? 'text-green-600' : rate.trend === 'up' ? 'text-red-600' : 'text-gray-500'}`}>
                  {rate.change}
                </span>
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div class="bg-green-50 p-3 rounded-lg">
                <h4 class="font-medium text-green-700 text-sm mb-2">יתרונות</h4>
                <ul class="space-y-1">
                  {rate.pros.map((pro) => (
                    <li class="flex items-center gap-2 text-xs text-gray-700">
                      <svg class="w-3 h-3 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      {pro}
                    </li>
                  ))}
                </ul>
              </div>
              <div class="bg-red-50 p-3 rounded-lg">
                <h4 class="font-medium text-red-700 text-sm mb-2">חסרונות</h4>
                <ul class="space-y-1">
                  {rate.cons.map((con) => (
                    <li class="flex items-center gap-2 text-xs text-gray-700">
                      <svg class="w-3 h-3 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                      </svg>
                      {con}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Historical Data -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">התפתחות הריביות - 2020 עד היום</h2>
      <div class="bg-surface p-6 rounded-xl border border-border overflow-x-auto">
        <table class="w-full text-right min-w-[400px]">
          <thead>
            <tr class="border-b border-border">
              <th class="pb-3 text-gray-600 font-medium">שנה</th>
              <th class="pb-3 text-gray-600 font-medium">פריים</th>
              <th class="pb-3 text-gray-600 font-medium">קל"צ (קבועה)</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            {historicalData.map((row) => (
              <tr>
                <td class="py-3 font-medium text-dark">{row.year}</td>
                <td class="py-3 text-brand-600">{row.prime}</td>
                <td class="py-3 text-gray-700">{row.fixed}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="mt-6 bg-amber-50 p-4 rounded-lg">
        <p class="text-sm text-amber-800">
          <strong>מגמה:</strong> הריבית עלתה באופן דרמטי בין 2022-2024 (מ-1.6% ל-6.5% בפריים). מאז סוף 2024 יש מגמת התייצבות עם ירידות קלות. תחזית 2026: ירידה מתונה של 0.25%-0.5%.
        </p>
      </div>
    </div>
  </section>

  <!-- Recommended Mixes -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">תמהילים מומלצים לסביבת הריבית הנוכחית</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {recommendedMixes.map((mix) => (
          <div class="bg-white p-6 rounded-xl border border-border">
            <div class="flex justify-between items-start mb-3">
              <h3 class="font-bold text-dark">{mix.profile}</h3>
              <span class={`text-xs px-2 py-1 rounded-full ${
                mix.risk === 'נמוך' ? 'bg-green-100 text-green-700' :
                mix.risk === 'בינוני' ? 'bg-amber-100 text-amber-700' :
                'bg-red-100 text-red-700'
              }`}>
                סיכון {mix.risk}
              </span>
            </div>
            <div class="bg-brand-50 p-3 rounded-lg mb-3">
              <p class="text-sm font-medium text-brand-700">{mix.mix}</p>
            </div>
            <p class="text-gray-600 text-sm">{mix.suitable}</p>
          </div>
        ))}
      </div>
      <p class="text-sm text-gray-500 mt-6 text-center">
        * התמהיל האופטימלי תלוי בנתונים האישיים שלכם. מומלץ להתייעץ עם יועץ משכנתאות.
      </p>
    </div>
  </section>

  <!-- Forecast -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">תחזיות לשנת 2026</h2>
      <div class="bg-brand-50 p-6 rounded-xl border border-brand-200">
        <div class="space-y-4">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <h4 class="font-bold text-dark mb-1">תחזית בנק ישראל</h4>
