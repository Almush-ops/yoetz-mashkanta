---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const testimonials = [
  {
    name: 'יעל ודני כהן',
    location: 'חיפה',
    text: 'איתי ליווה אותנו בתהליך הרכישה של הדירה הראשונה שלנו. הוא היה סבלני, הסביר כל פרט, ובסוף השיג לנו תנאים מעולים שחסכו לנו עשרות אלפי שקלים.',
    service: 'משכנתא לדירה ראשונה',
  },
  {
    name: 'משה לוי',
    location: 'קריית ביאליק',
    text: 'עשיתי מחזור משכנתא עם איתי והוא הוריד לי את ההחזר החודשי ב-800 שקל! מקצועי, אמין, וזמין מאוד לשאלות.',
    service: 'מחזור משכנתא',
  },
  {
    name: 'רונית אברהם',
    location: 'קריית מוצקין',
    text: 'אחרי שנדחיתי בשני בנקים, איתי מצא לי פתרון יצירתי וקיבלתי משכנתא. ממליצה בחום!',
    service: 'משכנתא למסורבים',
  },
  {
    name: 'אבי ושרה גולדשטיין',
    location: 'נשר',
    text: 'ייעוץ משכנתאות ופיננסים בטיפול אישי מקצה לקצה. איתי עזר לנו לא רק עם המשכנתא אלא גם עם תכנון פיננסי כולל.',
    service: 'ייעוץ פיננסי',
  },
  {
    name: 'תמר ברק',
    location: 'טירת כרמל',
    text: 'היה מעולה! אין לי מילים! איתי הפך תהליך מלחיץ לפשוט וברור. ידעתי בדיוק מה קורה בכל שלב.',
    service: 'משכנתא לרכישה',
  },
  {
    name: 'דוד ומרים שמעון',
    location: 'זכרון יעקב',
    text: 'רצינו לאחד את כל ההלוואות שלנו והגענו לאיתי. הוא בנה לנו תוכנית שהורידה את ההחזרים החודשיים בצורה משמעותית.',
    service: 'איחוד הלוואות',
  },
];
---

<BaseLayout
  title="המלצות לקוחות"
  description="קראו מה הלקוחות שלנו אומרים על שירותי ייעוץ המשכנתאות. 169 לקוחות מרוצים, דירוג 9.68."
>
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-dark mb-4">המלצות לקוחות</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        יותר מ-169 לקוחות מרוצים בדירוג 9.68. קראו מה הם אומרים על החוויה איתנו.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((testimonial) => (
          <div class="bg-white border border-border rounded-xl p-6 hover:shadow-md transition-shadow">
            <div class="flex gap-1 mb-4">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">"{testimonial.text}"</p>
            <div class="border-t border-border pt-4">
              <p class="font-semibold text-dark">{testimonial.name}</p>
              <p class="text-sm text-gray-500">{testimonial.location} • {testimonial.service}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="bg-white border border-border rounded-2xl p-8 md:p-12">
        <div class="flex justify-center gap-1 mb-4">
          {[...Array(5)].map(() => (
            <svg class="w-8 h-8 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="text-4xl font-bold text-brand-600 mb-2">9.68</p>
        <p class="text-gray-600 mb-4">דירוג ממוצע מ-169 לקוחות מרוצים</p>
        <p class="text-sm text-gray-500">
          הדירוג מבוסס על ביקורות מאומתות
        </p>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
