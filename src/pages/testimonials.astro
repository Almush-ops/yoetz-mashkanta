---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const testimonials = [
  {
    name: 'יעל ודני כהן',
    location: 'חיפה',
    text: 'איתי ליווה אותנו בתהליך הרכישה של הדירה הראשונה שלנו. הוא היה סבלני, הסביר כל פרט, ובסוף השיג לנו תנאים מעולים שחסכו לנו עשרות אלפי שקלים.',
    service: 'משכנתא לדירה ראשונה',
    savings: '87,000 ₪',
  },
  {
    name: 'משה לוי',
    location: 'קריית ביאליק',
    text: 'עשיתי מחזור משכנתא עם איתי והוא הוריד לי את ההחזר החודשי ב-800 שקל! מקצועי, אמין, וזמין מאוד לשאלות.',
    service: 'מחזור משכנתא',
    savings: '800 ₪/חודש',
  },
  {
    name: 'רונית אברהם',
    location: 'קריית מוצקין',
    text: 'אחרי שנדחיתי בשני בנקים, איתי מצא לי פתרון יצירתי וקיבלתי משכנתא. ממליצה בחום!',
    service: 'משכנתא למסורבים',
    savings: null,
  },
  {
    name: 'אבי ושרה גולדשטיין',
    location: 'נשר',
    text: 'ייעוץ משכנתאות ופיננסים בטיפול אישי מקצה לקצה. איתי עזר לנו לא רק עם המשכנתא אלא גם עם תכנון פיננסי כולל.',
    service: 'ייעוץ פיננסי',
    savings: null,
  },
  {
    name: 'תמר ברק',
    location: 'טירת כרמל',
    text: 'היה מעולה! אין לי מילים! איתי הפך תהליך מלחיץ לפשוט וברור. ידעתי בדיוק מה קורה בכל שלב.',
    service: 'משכנתא לרכישה',
    savings: null,
  },
  {
    name: 'דוד ומרים שמעון',
    location: 'זכרון יעקב',
    text: 'רצינו לאחד את כל ההלוואות שלנו והגענו לאיתי. הוא בנה לנו תוכנית שהורידה את ההחזרים החודשיים בצורה משמעותית.',
    service: 'איחוד הלוואות',
    savings: '1,200 ₪/חודש',
  },
];

// Review schema for structured data
const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://yoetz-mashkanta.co.il/#organization',
  name: 'יועץ משכנתאות - איתי אנצל',
  image: 'https://yoetz-mashkanta.co.il/images/itai-profile.webp',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '9.68',
    ratingCount: '169',
    bestRating: '10',
    worstRating: '1',
  },
  review: testimonials.slice(0, 3).map((t, i) => ({
    '@type': 'Review',
    reviewRating: {
      '@type': 'Rating',
      ratingValue: '5',
      bestRating: '5',
    },
    author: {
      '@type': 'Person',
      name: t.name,
    },
    reviewBody: t.text,
  })),
};
---

<BaseLayout
  title="המלצות לקוחות - יועץ משכנתאות איתי אנצל"
  description="קראו מה הלקוחות שלנו אומרים על שירותי ייעוץ המשכנתאות. 169 לקוחות מרוצים, דירוג 9.68. המלצות אמיתיות מלקוחות מחיפה והקריות."
>
  <!-- Hero with Stats -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-dark mb-4">המלצות לקוחות</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8">
        יותר מ-169 משפחות כבר סמכו עליי בתהליך לקיחת המשכנתא. קראו מה הם אומרים על החוויה.
      </p>

      <!-- Trust Stats -->
      <div class="grid grid-cols-3 gap-4 max-w-xl mx-auto">
        <div class="bg-white rounded-xl p-4 shadow-sm border border-border">
          <div class="text-2xl md:text-3xl font-bold text-brand-600">169</div>
          <div class="text-sm text-gray-500">לקוחות מרוצים</div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-border">
          <div class="text-2xl md:text-3xl font-bold text-brand-600">9.68</div>
          <div class="text-sm text-gray-500">דירוג ממוצע</div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-border">
          <div class="text-2xl md:text-3xl font-bold text-brand-600">7+</div>
          <div class="text-sm text-gray-500">שנות ניסיון</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Real Photo Banner -->
  <section class="bg-white py-8 border-b border-border">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row gap-6 items-center">
        <img
          src="/images/client-meeting-1.webp"
          alt="איתי אנצל בפגישת ייעוץ משכנתא עם לקוחות"
          class="w-full md:w-1/3 rounded-xl shadow-md"
          width="400"
          height="300"
          loading="lazy"
        />
        <div class="md:w-2/3">
          <h2 class="text-xl font-semibold text-dark mb-2">לקוחות אמיתיים, תוצאות אמיתיות</h2>
          <p class="text-gray-600">
            כל ההמלצות בעמוד הזה הן מלקוחות אמיתיים שליוויתי בתהליך לקיחת משכנתא. אני גאה בכל אחד ואחת מהם ובתוצאות שהשגנו יחד.
          </p>
          <p class="text-sm text-gray-500 mt-2 flex items-center gap-2">
            <svg class="w-4 h-4 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <span>שמות הלקוחות שונו לשמירה על פרטיותם</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Grid -->
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((testimonial) => (
          <div class="bg-white border border-border rounded-xl p-6 hover:shadow-md transition-shadow flex flex-col">
            <div class="flex gap-1 mb-4">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mb-4 flex-grow">"{testimonial.text}"</p>
            {testimonial.savings && (
              <div class="bg-accent-50 text-accent-700 text-sm font-medium px-3 py-1.5 rounded-lg mb-4 inline-flex items-center gap-1 w-fit">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                חיסכון: {testimonial.savings}
              </div>
            )}
            <div class="border-t border-border pt-4">
              <p class="font-semibold text-dark">{testimonial.name}</p>
              <p class="text-sm text-gray-500">{testimonial.location} • {testimonial.service}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Rating Summary -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="bg-white border border-border rounded-2xl p-8 md:p-12">
        <div class="flex justify-center gap-1 mb-4">
          {[...Array(5)].map(() => (
            <svg class="w-8 h-8 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="text-4xl font-bold text-brand-600 mb-2">9.68</p>
        <p class="text-gray-600 mb-6">דירוג ממוצע מ-169 לקוחות מרוצים</p>

        <!-- Verification -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a
            href="https://hfca.org.il/userprofile/?id=210"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 text-sm text-brand-600 hover:text-brand-700"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            פרופיל מאומת בהתאחדות יועצי המשכנתאות
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    title="רוצים להצטרף ל-169 הלקוחות המרוצים?"
    subtitle="השאירו פרטים וקבלו ייעוץ ראשוני ללא עלות"
    primaryText="השאירו פרטים"
    primaryHref="/contact/"
    phone="055-432-6608"
  />

  <!-- Review Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
</BaseLayout>
