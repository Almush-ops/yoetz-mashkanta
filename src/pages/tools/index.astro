---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTASection from '../../components/CTASection.astro';
import { consultant } from '../../data/consultant';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'כלים ומחשבונים' },
];

const tools = [
  {
    title: 'מחשבון משכנתא',
    description: 'חישוב החזר חודשי, סה״כ ריבית, ולוח סילוקין מפורט לפי סכום, ריבית ותקופה.',
    href: '/tools/mortgage-calculator/',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
    </svg>`,
    color: 'bg-brand-100 text-brand-700',
  },
  {
    title: 'מחשבון כדאיות מחזור',
    description: 'בדיקת כדאיות מחזור משכנתא - השוואה בין תנאי המשכנתא הנוכחית לתנאים חדשים.',
    href: '/tools/refinance-calculator/',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
    </svg>`,
    color: 'bg-accent-100 text-accent-700',
  },
  {
    title: 'בדיקת יכולת החזר',
    description: 'חישוב משכנתא מקסימלית לפי הכנסה, התחייבויות והון עצמי - לפי הנחיות בנק ישראל.',
    href: '/tools/eligibility-calculator/',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
    </svg>`,
    color: 'bg-green-100 text-green-700',
  },
];
---

<BaseLayout
  title="מחשבוני משכנתא חינמיים | יועץ משכנתאות"
  description="מחשבוני משכנתא חינמיים: חישוב החזר חודשי, כדאיות מחזור, ובדיקת יכולת החזר. כלים מקצועיים לתכנון המשכנתא שלכם."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">מחשבוני משכנתא חינמיים</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        כלים מקצועיים שיעזרו לכם לתכנן את המשכנתא בצורה חכמה. חישובים מהירים ומדויקים - בחינם.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid gap-6">
        {tools.map((tool) => (
          <a
            href={tool.href}
            class="group block bg-white border border-border rounded-xl p-6 hover:shadow-lg hover:border-brand-300 transition-all duration-300"
          >
            <div class="flex items-start gap-5">
              <div class={`p-3 rounded-xl ${tool.color} group-hover:scale-110 transition-transform`}>
                <Fragment set:html={tool.icon} />
              </div>
              <div class="flex-1">
                <h2 class="text-xl font-bold text-dark group-hover:text-brand-600 transition-colors mb-2">
                  {tool.title}
                </h2>
                <p class="text-gray-600">{tool.description}</p>
              </div>
              <div class="flex-shrink-0 self-center">
                <span class="inline-flex items-center gap-1 text-brand-600 font-medium text-sm group-hover:gap-2 transition-all">
                  לחישוב
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-12 p-6 bg-surface rounded-xl border border-border">
        <h3 class="text-lg font-bold text-dark mb-3">למה להשתמש במחשבונים שלנו?</h3>
        <ul class="space-y-2 text-gray-600">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span><strong>חינם לחלוטין</strong> - ללא הרשמה או פרטים אישיים</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span><strong>מעודכנים להנחיות בנק ישראל</strong> - אחוזי מימון ויחסי החזר נכונים</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span><strong>פשוטים ומהירים</strong> - תוצאות מיידיות ללא המתנה</span>
          </li>
        </ul>
      </div>

      <div class="mt-8 text-center">
        <p class="text-gray-600 mb-4">רוצים ייעוץ אישי מיועץ משכנתאות מקצועי?</p>
        <a href="/contact/" class="inline-block bg-accent-500 text-white px-6 py-3 rounded-xl font-bold hover:bg-accent-600 transition-colors shadow-md">
          לתיאום שיחת ייעוץ חינם ←
        </a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
