---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import EligibilityCalc from '../../components/calculators/EligibilityCalc.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema } from '../../data/consultant';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'כלים ומחשבונים', href: '/tools/' },
  { label: 'בדיקת יכולת החזר' },
];

const softwareSchema = {
  '@type': 'SoftwareApplication',
  name: 'מחשבון זכאות משכנתא',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'ILS',
  },
  description: 'מחשבון חינמי לבדיקת זכאות משכנתא - כמה משכנתא אפשר לקבל לפי הכנסה והון עצמי.',
};

const faqItems = [
  {
    question: 'מהו יחס החזר/הכנסה המקסימלי?',
    answer: 'לפי הנחיות בנק ישראל, ההחזר החודשי לא יעלה על 40% מההכנסה הפנויה (הכנסה פחות התחייבויות קיימות). בנקים מסוימים מחמירים ל-35%.',
  },
  {
    question: 'מהם אחוזי המימון המקסימליים?',
    answer: 'לפי בנק ישראל: דירה ראשונה - עד 75% מימון, דירה חליפית (משפרי דיור) - עד 70%, דירה להשקעה - עד 50%.',
  },
  {
    question: 'מה נחשב להתחייבויות?',
    answer: 'התחייבויות כוללות: הלוואות קיימות, החזרי אשראי קבועים, מזונות, ליסינג, והתשלום העתידי על כרטיסי אשראי. הבנק בודק את כל ההתחייבויות שלכם.',
  },
  {
    question: 'האם המחשבון נותן תשובה סופית?',
    answer: 'לא. המחשבון נותן הערכה ראשונית בלבד. האישור הסופי של הבנק תלוי בגורמים נוספים: היסטוריית אשראי, יציבות תעסוקתית, סוג הנכס, ועוד.',
  },
];

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title="מחשבון זכאות משכנתא - כמה משכנתא אפשר לקבל?"
  description="בדקו כמה משכנתא תוכלו לקבל לפי ההכנסה וההון העצמי שלכם. מחשבון מעודכן להנחיות בנק ישראל 2026."
>
  <SchemaOrg schema={softwareSchema} slot="schema" />
  <SchemaOrg schema={faqSchema} slot="schema" />

  <Breadcrumbs items={breadcrumbs} />

  <section class="py-8 md:py-12 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-3">בדיקת יכולת החזר</h1>
      <p class="text-lg text-brand-100">
        גלו כמה משכנתא תוכלו לקבל לפי ההכנסה וההון העצמי שלכם
      </p>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-surface rounded-2xl p-6 md:p-8 border border-border">
        <EligibilityCalc />
      </div>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6">הנחיות בנק ישראל 2026</h2>

      <div class="grid md:grid-cols-3 gap-4 mb-8">
        <div class="bg-white p-5 rounded-xl border border-border text-center">
          <div class="text-4xl font-bold text-brand-600 mb-2">75%</div>
          <div class="font-semibold text-dark mb-1">דירה ראשונה</div>
          <p class="text-sm text-gray-600">מימון מקסימלי</p>
        </div>
        <div class="bg-white p-5 rounded-xl border border-border text-center">
          <div class="text-4xl font-bold text-brand-600 mb-2">70%</div>
          <div class="font-semibold text-dark mb-1">דירה חליפית</div>
          <p class="text-sm text-gray-600">משפרי דיור</p>
        </div>
        <div class="bg-white p-5 rounded-xl border border-border text-center">
          <div class="text-4xl font-bold text-brand-600 mb-2">50%</div>
          <div class="font-semibold text-dark mb-1">דירה להשקעה</div>
          <p class="text-sm text-gray-600">מימון מקסימלי</p>
        </div>
      </div>

      <div class="bg-white p-6 rounded-xl border border-border">
        <h3 class="font-bold text-dark mb-4">מה משפיע על גובה המשכנתא?</h3>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <h4 class="font-semibold text-brand-700 mb-2">גורמים חיוביים</h4>
            <ul class="space-y-1 text-sm text-gray-600">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                הכנסה גבוהה ויציבה
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                הון עצמי משמעותי
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                היסטוריית אשראי נקייה
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                ותק בעבודה
              </li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-red-700 mb-2">גורמים מגבילים</h4>
            <ul class="space-y-1 text-sm text-gray-600">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                הלוואות קיימות
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                חובות מזונות
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                הכנסה לא יציבה
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                גיל מבוגר (מקצר תקופה)
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6">שאלות נפוצות</h2>
      <div class="space-y-4">
        {faqItems.map((item) => (
          <details class="group bg-surface rounded-xl border border-border overflow-hidden">
            <summary class="px-5 py-4 font-semibold text-dark cursor-pointer hover:bg-brand-50 transition-colors list-none flex items-center justify-between">
              {item.question}
              <svg class="w-5 h-5 text-brand-600 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-4 text-gray-600">{item.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-white rounded-xl p-6 border border-brand-200">
        <h3 class="text-lg font-bold text-dark mb-3">רוצים לדעת בדיוק כמה תקבלו?</h3>
        <p class="text-gray-600 mb-4">
          המחשבון נותן הערכה ראשונית לפי הנחיות בנק ישראל. יועץ משכנתאות יכול לבדוק את המצב שלכם
          מול כל הבנקים ולמצוא את ההצעה הטובה ביותר - גם אם סורבתם בעבר.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/contact/" class="inline-block bg-accent-500 text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-accent-600 transition-colors">
            לתיאום ייעוץ חינם ←
          </a>
          <a href="/guides/down-payment/" class="inline-block bg-white text-brand-600 border border-brand-300 px-5 py-2.5 rounded-lg font-semibold hover:bg-brand-50 transition-colors">
            מדריך הון עצמי
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
