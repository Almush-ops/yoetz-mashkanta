---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import MortgageCalc from '../../components/calculators/MortgageCalc.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema } from '../../data/consultant';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'כלים ומחשבונים', href: '/tools/' },
  { label: 'מחשבון משכנתא' },
];

const softwareSchema = {
  '@type': 'SoftwareApplication',
  name: 'מחשבון משכנתא',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'ILS',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '156',
  },
  description: 'מחשבון משכנתא חינמי לחישוב החזר חודשי, סה״כ ריבית ולוח סילוקין מפורט.',
};

const faqItems = [
  {
    question: 'איך מחשבים החזר חודשי למשכנתא?',
    answer: 'החזר חודשי מחושב לפי נוסחת שפיצר: הסכום כפול הריבית החודשית, מחולק ב-(1 פחות (1 חלקי 1 פלוס ריבית בחזקת מספר החודשים)). המחשבון שלנו עושה את החישוב אוטומטית.',
  },
  {
    question: 'מהי שיטת שפיצר?',
    answer: 'שיטת שפיצר היא לוח סילוקין בו ההחזר החודשי קבוע לאורך כל תקופת ההלוואה. בתחילה רוב התשלום הולך לריבית, ובהדרגה יותר הולך לקרן.',
  },
  {
    question: 'האם התוצאות מדויקות?',
    answer: 'המחשבון נותן הערכה מדויקת מאוד להחזר לפי שיטת שפיצר. בפועל, ההחזר בבנק עשוי להשתנות בגלל סוג ריבית (קבועה/משתנה), הצמדה למדד, ותנאים ספציפיים.',
  },
];

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title="מחשבון משכנתא חינם - חישוב החזר חודשי ולוח סילוקין"
  description="מחשבון משכנתא חינמי לחישוב החזר חודשי, סה״כ ריבית, ולוח סילוקין מפורט. הזינו סכום, ריבית ותקופה וקבלו תוצאות מיידיות."
>
  <SchemaOrg schema={softwareSchema} slot="schema" />
  <SchemaOrg schema={faqSchema} slot="schema" />

  <Breadcrumbs items={breadcrumbs} />

  <section class="py-8 md:py-12 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-3">מחשבון משכנתא</h1>
      <p class="text-lg text-brand-100">
        חישוב מהיר של החזר חודשי, סה״כ ריבית, ולוח סילוקין מפורט
      </p>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-surface rounded-2xl p-6 md:p-8 border border-border">
        <MortgageCalc />
      </div>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6">איך להשתמש במחשבון?</h2>

      <div class="grid md:grid-cols-3 gap-4 mb-8">
        <div class="bg-white p-5 rounded-xl border border-border">
          <div class="w-10 h-10 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center font-bold mb-3">1</div>
          <h3 class="font-semibold text-dark mb-2">הזינו סכום</h3>
          <p class="text-sm text-gray-600">הכניסו את סכום המשכנתא הרצוי בשקלים</p>
        </div>
        <div class="bg-white p-5 rounded-xl border border-border">
          <div class="w-10 h-10 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center font-bold mb-3">2</div>
          <h3 class="font-semibold text-dark mb-2">בחרו תנאים</h3>
          <p class="text-sm text-gray-600">הגדירו ריבית שנתית ותקופת ההלוואה</p>
        </div>
        <div class="bg-white p-5 rounded-xl border border-border">
          <div class="w-10 h-10 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center font-bold mb-3">3</div>
          <h3 class="font-semibold text-dark mb-2">קבלו תוצאות</h3>
          <p class="text-sm text-gray-600">החזר חודשי, סה״כ ריבית ולוח סילוקין</p>
        </div>
      </div>

      <div class="prose max-w-none">
        <h2 class="text-xl font-bold text-dark mb-4">מה המחשבון מציג?</h2>
        <ul class="space-y-2 text-gray-700 mb-6 ps-5 list-disc">
          <li><strong>החזר חודשי</strong> - הסכום שתשלמו כל חודש לבנק</li>
          <li><strong>סה״כ תשלומים</strong> - כמה תשלמו לאורך כל התקופה</li>
          <li><strong>סה״כ ריבית</strong> - כמה ריבית תשלמו מעבר לקרן</li>
          <li><strong>לוח סילוקין</strong> - פירוט חודשי/שנתי של קרן וריבית</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6">שאלות נפוצות</h2>
      <div class="space-y-4">
        {faqItems.map((item) => (
          <details class="group bg-surface rounded-xl border border-border overflow-hidden">
            <summary class="px-5 py-4 font-semibold text-dark cursor-pointer hover:bg-brand-50 transition-colors list-none flex items-center justify-between">
              {item.question}
              <svg class="w-5 h-5 text-brand-600 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-4 text-gray-600">{item.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-white rounded-xl p-6 border border-brand-200">
        <h3 class="text-lg font-bold text-dark mb-3">רוצים לדעת מה התמהיל האופטימלי עבורכם?</h3>
        <p class="text-gray-600 mb-4">
          המחשבון נותן תמונה ראשונית, אבל משכנתא אמיתית כוללת שילוב של מספר מסלולים בריביות שונות.
          יועץ משכנתאות מקצועי יכול לעזור לכם לבנות תמהיל שחוסך עשרות אלפי שקלים.
        </p>
        <a href="/contact/" class="inline-block bg-accent-500 text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-accent-600 transition-colors">
          לתיאום ייעוץ חינם ←
        </a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
