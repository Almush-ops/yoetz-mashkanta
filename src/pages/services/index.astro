---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';

const services = [
  {
    title: 'ייעוץ משכנתא לרכישת דירה',
    description: 'ליווי מקצועי בכל תהליך קבלת המשכנתא - מבדיקת כדאיות ועד חתימה על הסכם ההלוואה. נבנה עבורכם את התמהיל המשתלם ביותר.',
    icon: 'home',
    href: '/services/mortgage-consultation/',
  },
  {
    title: 'מחזור משכנתא',
    description: 'בדיקת כדאיות מחזור, השוואת תנאים מול הבנקים, וליווי בתהליך המחזור לחיסכון משמעותי בהחזרים החודשיים.',
    icon: 'refresh',
    href: '/services/mortgage-refinance/',
  },
  {
    title: 'משכנתא לזוגות צעירים',
    description: 'התמחות בליווי זוגות צעירים בדרך לדירה הראשונה - ניצול מענקים, הטבות מס, ובניית תמהיל מותאם לתקציב.',
    icon: 'users',
    href: '/services/young-couples/',
  },
  {
    title: 'משכנתא למסורבים',
    description: 'פתרונות יצירתיים ללקוחות שנתקלו בסירוב בבנקים - שיפור תנאי הזכאות ומציאת דרכים חלופיות למימון.',
    icon: 'shield',
    href: '/services/declined-applicants/',
  },
  {
    title: 'משכנתא הפוכה',
    description: 'ייעוץ למשכנתא הפוכה לגיל הזהב - מימוש ההון בנכס ללא מכירתו, תוך שמירה על רמת חיים גבוהה.',
    icon: 'clock',
    href: '/services/reverse-mortgage/',
  },
  {
    title: 'משכנתא לשיפוץ',
    description: 'מימון שיפוץ הדירה באמצעות משכנתא - ריבית נמוכה, פריסה ארוכה, ותנאים טובים משמעותית מהלוואה רגילה.',
    icon: 'tool',
    href: '/services/mortgage-renovation/',
  },
  {
    title: 'איחוד הלוואות',
    description: 'איחוד כל ההלוואות והחובות למשכנתא אחת עם ריבית נמוכה יותר והחזר חודשי נוח.',
    icon: 'merge',
    href: '/services/debt-consolidation/',
  },
  {
    title: 'ייעוץ פיננסי וכלכלת משפחה',
    description: 'תכנון פיננסי מקיף למשפחה - ניהול תקציב, תכנון חסכונות, והכנה כלכלית לרכישת דירה.',
    icon: 'chart',
    href: '/services/financial-planning/',
  },
];

const iconPaths: Record<string, string> = {
  home: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  refresh: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  users: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  clock: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  tool: 'M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z',
  merge: 'M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4',
  chart: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
};
---

<BaseLayout
  title="שירותי ייעוץ משכנתאות"
  description="מגוון שירותי ייעוץ משכנתאות מקצועיים - רכישת דירה, מחזור, זוגות צעירים, משכנתא למסורבים ועוד. ליווי אישי מקצה לקצה."
>
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-dark mb-4">שירותי ייעוץ משכנתאות</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        ליווי מקצועי ואישי בכל סוגי המשכנתאות - מהייעוץ הראשוני ועד חתימת ההסכם. כל שירות מותאם לצרכים הייחודיים שלכם.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a
            href={service.href}
            class="group block bg-white border border-border rounded-xl p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
          >
            <div class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-brand-200 transition-colors">
              <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[service.icon]} />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-dark mb-2 group-hover:text-brand-600 transition-colors">{service.title}</h2>
            <p class="text-gray-600 text-sm leading-relaxed">{service.description}</p>
            <span class="inline-flex items-center gap-1 text-brand-600 font-medium text-sm mt-4 group-hover:gap-2 transition-all">
              למידע נוסף
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
