---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { consultant, personSchema, localBusinessSchema, createServiceSchema, trustBadges } from '../../data/consultant';

const serviceSchema = createServiceSchema({
  name: 'משכנתא לשיפוץ',
  description: 'מימון שיפוץ הדירה באמצעות משכנתא - ריבית נמוכה, פריסה ארוכה, ותנאים טובים משמעותית מהלוואה רגילה. עד 70% מערך הנכס.',
  url: 'https://yoetz-mashkanta.co.il/services/mortgage-renovation/',
});

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'שירותים', href: '/services/' },
  { label: 'משכנתא לשיפוץ' },
];

const faqItems = [
  {
    question: 'מה זה משכנתא לשיפוץ?',
    answer: 'משכנתא לשיפוץ היא הלוואה המובטחת בנכס קיים, המיועדת למימון עבודות שיפוץ. הריבית נמוכה משמעותית מהלוואה צרכנית (3-5% לעומת 8-15%), והפריסה יכולה להגיע עד 30 שנה.',
  },
  {
    question: 'כמה כסף אפשר לקבל למשכנתא לשיפוץ?',
    answer: 'הסכום תלוי ביתרה הפנויה בנכס. ניתן ללוות עד 70% משווי הנכס (כולל משכנתא קיימת). לדוגמה, נכס בשווי 2 מיליון עם משכנתא של 800,000 = יתרה פנויה של 600,000 ש"ח לשיפוץ.',
  },
  {
    question: 'האם צריך אישור לסוג השיפוץ?',
    answer: 'הבנק לא מגביל את סוג השיפוץ, אך דורש הצעת מחיר מקבלן או פירוט עלויות. שיפוצים נפוצים: מטבח, אמבטיה, הרחבה, החלפת חלונות, איטום, ומערכות חשמל/אינסטלציה.',
  },
  {
    question: 'מתי כדאי לקחת משכנתא לשיפוץ ומתי הלוואה רגילה?',
    answer: 'משכנתא לשיפוץ כדאית לסכומים מעל 100,000 ש"ח. מתחת לסכום זה, עלויות פתיחת התיק והשמאות עלולות לבטל את החיסכון בריבית. גם זמן התהליך (4-6 שבועות) הוא שיקול - הלוואה רגילה מהירה יותר.',
  },
  {
    question: 'איך משחררים את הכסף לשיפוץ?',
    answer: 'יש שני מודלים: (1) שחרור חד-פעמי - מקבלים את כל הסכום בבת אחת. (2) שחרור בשלבים - הכסף משוחרר בהתאם להתקדמות העבודות (נפוץ בשיפוצים גדולים). השיטה השנייה חוסכת ריבית אך דורשת תיאום מול הבנק.',
  },
  {
    question: 'האם אפשר לקחת משכנתא לשיפוץ דירה שזה עתה קניתי?',
    answer: 'כן, זה נקרא "משכנתא משולבת" - מימון רכישה + שיפוץ במשכנתא אחת. זה דורש הערכת שמאי לשווי הנכס אחרי השיפוץ (After Repair Value), והבנק מאשר עד 70% מהשווי העתידי.',
  },
];

const renovationTypes = [
  {
    title: 'הגדלת משכנתא קיימת',
    desc: 'הוספת סכום למשכנתא הקיימת עבור השיפוץ',
    pros: 'תהליך פשוט, ללא פתיחת תיק חדש',
    cons: 'תלוי ביתרה פנויה בנכס',
    icon: '🏦',
  },
  {
    title: 'משכנתא לרכישה + שיפוץ',
    desc: 'מימון רכישת דירה ושיפוץ במשכנתא אחת',
    pros: 'תנאים טובים, תהליך אחד',
    cons: 'דורש הערכת שמאי לשווי עתידי',
    icon: '🏠',
  },
  {
    title: 'משכנתא שנייה לשיפוץ',
    desc: 'לקיחת משכנתא נוספת על הנכס למימון השיפוץ',
    pros: 'לא משנה את המשכנתא הקיימת',
    cons: 'עלויות פתיחת תיק נוספות',
    icon: '📋',
  },
];

const popularRenovations = [
  { name: 'מטבח חדש', range: '40,000-120,000 ש"ח', icon: '🍳' },
  { name: 'אמבטיה/שירותים', range: '25,000-60,000 ש"ח', icon: '🚿' },
  { name: 'הרחבת דירה', range: '150,000-400,000 ש"ח', icon: '🏗️' },
  { name: 'החלפת חלונות', range: '30,000-80,000 ש"ח', icon: '🪟' },
  { name: 'איטום ובידוד', range: '20,000-50,000 ש"ח', icon: '🔒' },
  { name: 'שיפוץ כללי', range: '100,000-300,000 ש"ח', icon: '🔧' },
];

const benefits = [
  {
    title: 'ריבית נמוכה משמעותית',
    desc: '3-5% לעומת 8-15% בהלוואה צרכנית',
    icon: '📉',
  },
  {
    title: 'פריסה ארוכה',
    desc: 'עד 30 שנה - החזר חודשי נוח יותר',
    icon: '📅',
  },
  {
    title: 'סכומים גבוהים',
    desc: 'עד מאות אלפי שקלים בהתאם לשווי הנכס',
    icon: '💰',
  },
  {
    title: 'גמישות בשימוש',
    desc: 'כל סוג שיפוץ - מטבח, אמבטיה, הרחבה',
    icon: '🔧',
  },
  {
    title: 'הטבת מס',
    desc: 'ריבית על דירת מגורים מוכרת לניכוי מס',
    icon: '📋',
  },
  {
    title: 'העלאת ערך הנכס',
    desc: 'שיפוץ נכון יכול להעלות את שווי הנכס',
    icon: '📈',
  },
];
---

<BaseLayout
  title="משכנתא לשיפוץ 2026 | ריבית 3-5% במקום 12%"
  description="משכנתא לשיפוץ - מימון שיפוץ בתנאי משכנתא. ריבית נמוכה, פריסה ארוכה, עד 70% משווי הנכס. ייעוץ חינם לבדיקת כדאיות."
>
  <SchemaOrg slot="schema" schema={[serviceSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <ServiceHero
    title="משכנתא לשיפוץ"
    description="מימון שיפוץ הדירה בתנאי משכנתא - ריבית נמוכה, פריסה ארוכה, וחיסכון של עשרות אלפי שקלים לעומת הלוואה רגילה."
    trustBadges={trustBadges}
    hfcaUrl={consultant.hfcaUrl}
  />

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          שיפוץ דירה הוא השקעה משמעותית שדורשת תקציב של עשרות עד מאות אלפי שקלים. <strong>הלוואה צרכנית לשיפוץ עולה 8-15% ריבית, בעוד משכנתא לשיפוץ עולה רק 3-5%</strong>. על שיפוץ של 200,000 ש"ח, זה הבדל של 10,000-20,000 ש"ח בשנה בריביות.
        </p>
        <p>
          משכנתא לשיפוץ מתאימה לבעלי דירות שיש להם יתרה פנויה בנכס (שווי הנכס גבוה מסכום המשכנתא הקיימת). אם יש לכם נכס בשווי 2 מיליון ומשכנתא של מיליון - יש יתרה פנויה של 400,000 ש"ח שניתן לנצל למימון שיפוץ.
        </p>

        <h2>למי מתאימה משכנתא לשיפוץ?</h2>
        <ul>
          <li><strong>בעלי דירות עם יתרה פנויה בנכס</strong> - LTV מתחת ל-70%</li>
          <li><strong>מתכננים שיפוץ של 100,000+ ש"ח</strong> - בסכומים נמוכים יותר, הלוואה רגילה עדיפה</li>
          <li><strong>יכולים לחכות 4-6 שבועות</strong> - התהליך ארוך יותר מהלוואה צרכנית</li>
          <li><strong>רוכשי דירה יד שנייה</strong> שמתכננים לשפץ אחרי הרכישה</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Example Calculation -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">דוגמת חיסכון - שיפוץ של 200,000 ש"ח</h2>
      <div class="bg-white p-8 rounded-xl shadow-sm border border-border">
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <h3 class="font-bold text-dark mb-4 text-lg text-red-600">הלוואה צרכנית</h3>
            <ul class="space-y-2 text-gray-700">
              <li>סכום: <strong>200,000 ש"ח</strong></li>
              <li>ריבית: <strong>12%</strong></li>
              <li>תקופה: <strong>7 שנים</strong></li>
              <li class="pt-2 border-t border-border">החזר חודשי: <strong>~3,500 ש"ח</strong></li>
              <li>סה"כ ריביות: <strong>~94,000 ש"ח</strong></li>
            </ul>
          </div>
          <div>
            <h3 class="font-bold text-dark mb-4 text-lg text-accent">משכנתא לשיפוץ</h3>
            <ul class="space-y-2 text-gray-700">
              <li>סכום: <strong>200,000 ש"ח</strong></li>
              <li>ריבית: <strong>4.5%</strong></li>
              <li>תקופה: <strong>15 שנים</strong></li>
              <li class="pt-2 border-t border-border">החזר חודשי: <strong>~1,530 ש"ח</strong></li>
              <li>סה"כ ריביות: <strong>~75,000 ש"ח</strong></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 pt-6 border-t border-border text-center">
          <p class="text-2xl font-bold text-accent">
            חיסכון: ~2,000 ש"ח בחודש + ~19,000 ש"ח בריביות
          </p>
          <p class="text-sm text-gray-500 mt-2">* המשכנתא ארוכה יותר אך ההחזר החודשי נמוך משמעותית וסה"כ הריביות נמוך יותר</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Renovation Types -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">סוגי משכנתאות לשיפוץ</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {renovationTypes.map((type) => (
          <div class="bg-surface p-6 rounded-xl border border-border">
            <div class="text-3xl mb-3">{type.icon}</div>
            <h3 class="font-bold text-dark mb-2">{type.title}</h3>
            <p class="text-gray-600 text-sm mb-4">{type.desc}</p>
            <div class="text-sm space-y-1">
              <p class="text-accent"><strong>יתרון:</strong> {type.pros}</p>
              <p class="text-gray-500"><strong>חיסרון:</strong> {type.cons}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Popular Renovations -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">עלויות שיפוץ נפוצות (2026)</h2>
      <div class="grid md:grid-cols-3 gap-4">
        {popularRenovations.map((item) => (
          <div class="bg-white p-4 rounded-xl border border-border">
            <div class="flex items-center gap-3">
              <span class="text-2xl">{item.icon}</span>
              <div>
                <h3 class="font-bold text-dark text-sm">{item.name}</h3>
                <p class="text-brand-600 text-sm font-medium">{item.range}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-gray-500 text-sm mt-4">
        * המחירים משתנים לפי גודל, חומרים, ואזור בארץ
      </p>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">יתרונות משכנתא לשיפוץ</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {benefits.map((benefit) => (
          <div class="bg-surface p-6 rounded-xl border border-border text-center">
            <div class="text-3xl mb-3">{benefit.icon}</div>
            <h3 class="font-bold text-dark mb-2">{benefit.title}</h3>
            <p class="text-gray-600 text-sm">{benefit.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Requirements -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">תנאים לקבלת משכנתא לשיפוץ</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded-xl border border-border">
          <h3 class="font-bold text-dark mb-3">דרישות הנכס</h3>
          <ul class="text-gray-600 text-sm space-y-2">
            <li>• בעלות על הנכס (נסח טאבו)</li>
            <li>• LTV מקסימלי 70% (כולל המשכנתא לשיפוץ)</li>
            <li>• שמאות עדכנית של הנכס</li>
            <li>• הנכס במצב סחיר ותקין</li>
          </ul>
        </div>
        <div class="bg-white p-6 rounded-xl border border-border">
          <h3 class="font-bold text-dark mb-3">דרישות הלווה</h3>
          <ul class="text-gray-600 text-sm space-y-2">
            <li>• הכנסה קבועה ויציבה</li>
            <li>• יחס החזר עד 40% מההכנסה נטו</li>
            <li>• דירוג אשראי תקין</li>
            <li>• הצעת מחיר/תכנון לשיפוץ</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">תהליך קבלת משכנתא לשיפוץ</h2>
      <div class="space-y-4">
        {[
          { step: '1', title: 'בדיקת כדאיות', desc: 'ניתוח יתרה פנויה בנכס, השוואה להלוואה רגילה', time: 'פגישה ראשונה' },
          { step: '2', title: 'תכנון השיפוץ', desc: 'איסוף הצעות מחיר מקבלנים, הגדרת תקציב', time: 'שבוע-שבועיים' },
          { step: '3', title: 'הגשה לבנקים', desc: 'הגשת בקשה לבנקים עם תוכנית השיפוץ', time: '2-3 שבועות' },
          { step: '4', title: 'שמאות ואישור', desc: 'שמאות הנכס, אישור סופי מהבנק', time: 'שבוע-שבועיים' },
          { step: '5', title: 'חתימה והעברת כסף', desc: 'חתימה על ההסכם, שחרור הכספים לשיפוץ', time: 'שבוע' },
        ].map((item) => (
          <div class="bg-surface p-6 rounded-xl border border-border">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-brand-600 text-white rounded-full flex items-center justify-center font-bold shrink-0">
                {item.step}
              </div>
              <div class="flex-1">
                <div class="flex justify-between items-start">
                  <h3 class="font-bold text-dark">{item.title}</h3>
                  <span class="text-xs text-brand-600 font-medium bg-brand-50 px-2 py-1 rounded">{item.time}</span>
                </div>
                <p class="text-gray-600 text-sm mt-1">{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-gray-600 mt-8">
        משך התהליך הכולל: <strong>4-8 שבועות</strong>
      </p>
    </div>
  </section>

  <!-- When NOT to use -->
  <section class="py-12 md:py-16 bg-brand-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">מתי עדיף הלוואה רגילה?</h2>
      <div class="prose prose-lg max-w-none text-gray-700">
        <ul>
          <li><strong>שיפוץ קטן (מתחת ל-100,000 ש"ח)</strong> - עלויות פתיחת התיק לא משתלמות</li>
          <li><strong>צריכים את הכסף מהר</strong> - הלוואה צרכנית מאושרת תוך ימים</li>
          <li><strong>אין יתרה פנויה בנכס</strong> - ה-LTV כבר גבוה מ-70%</li>
          <li><strong>מתכננים למכור בקרוב</strong> - לא שווה להתחיל תהליך משכנתא</li>
        </ul>
        <p>
          <strong>בפגישת הייעוץ נבדוק מה המסלול הכדאי ביותר עבורכם</strong> - משכנתא, הלוואה, או שילוב של שניהם.
        </p>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">שירותים קשורים</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <a href="/services/mortgage-refinance/" class="block bg-surface p-6 rounded-xl border border-border hover:border-brand-300 transition-colors">
          <h3 class="font-bold text-dark mb-2">מחזור משכנתא</h3>
          <p class="text-gray-600 text-sm">שילוב מחזור + כסף לשיפוץ בתהליך אחד ←</p>
        </a>
        <a href="/services/mortgage-consultation/" class="block bg-surface p-6 rounded-xl border border-border hover:border-brand-300 transition-colors">
          <h3 class="font-bold text-dark mb-2">ייעוץ משכנתא לרכישת דירה</h3>
          <p class="text-gray-600 text-sm">קונים דירה ומתכננים לשפץ? נתכנן יחד ←</p>
        </a>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות על משכנתא לשיפוץ" />

  <CTASection />
</BaseLayout>
