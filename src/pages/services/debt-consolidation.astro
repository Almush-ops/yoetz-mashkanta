---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'שירותים', href: '/services/' },
  { label: 'איחוד הלוואות' },
];

const faqItems = [
  {
    question: 'מהו איחוד הלוואות?',
    answer: 'איחוד הלוואות מאפשר לכם לקחת את כל החובות וההלוואות הקיימות ולאחד אותם להלוואה אחת עם ריבית נמוכה יותר.',
  },
  {
    question: 'האם זה מתאים לי?',
    answer: 'אם יש לכם מספר הלוואות עם ריביות גבוהות, איחוד הלוואות יכול לחסוך לכם כסף רב ולהקל על ניהול התקציב.',
  },
  {
    question: 'האם צריך נכס לאיחוד הלוואות?',
    answer: 'לרוב כן, הנכס משמש כבטוחה להלוואה המאוחדת, מה שמאפשר ריבית נמוכה יותר.',
  },
];
---

<BaseLayout
  title="איחוד הלוואות | יועץ משכנתאות"
  description="איחוד כל ההלוואות והחובות למשכנתא אחת עם ריבית נמוכה יותר והחזר חודשי נוח."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">איחוד הלוואות</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        כל החובות וההלוואות להחזר אחד נוח - ריבית נמוכה יותר ושליטה בתקציב.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          ריבוי הלוואות וחובות יוצר עומס פיננסי ונפשי. איחוד הלוואות מאפשר לכם לפשט את המצב ולחסוך כסף.
        </p>
        <p>
          תיאור מפורט של שירות איחוד הלוואות יתווסף כאן - כולל הסבר על התהליך, יתרונות, ודוגמאות לחיסכון.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">יתרונות איחוד הלוואות</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { title: 'ריבית נמוכה יותר', desc: 'ריבית משכנתא נמוכה מריבית הלוואות צרכניות' },
          { title: 'החזר אחד', desc: 'החזר חודשי אחד במקום מספר תשלומים' },
          { title: 'שליטה בתקציב', desc: 'קל יותר לנהל את הכסף עם תשלום אחד' },
          { title: 'חיסכון כספי', desc: 'הפחתה משמעותית בסך התשלומים' },
        ].map((item) => (
          <div class="bg-white p-6 rounded-xl shadow-sm border border-border">
            <h3 class="font-bold text-dark mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות על איחוד הלוואות" />

  <CTASection />
</BaseLayout>
