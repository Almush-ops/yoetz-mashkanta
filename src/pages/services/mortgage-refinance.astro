---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { consultant, personSchema, localBusinessSchema, createServiceSchema, trustBadges } from '../../data/consultant';

const serviceSchema = createServiceSchema({
  name: 'מחזור משכנתא',
  description: 'בדיקת כדאיות מחזור משכנתא, השוואת הצעות מכל הבנקים, וליווי מלא בתהליך. חיסכון ממוצע של 400-800 ש"ח בחודש.',
  url: 'https://yoetz-mashkanta.co.il/services/mortgage-refinance/',
});

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'שירותים', href: '/services/' },
  { label: 'מחזור משכנתא' },
];

const faqItems = [
  {
    question: 'מתי כדאי למחזר משכנתא?',
    answer: 'מחזור משכנתא כדאי כשהריבית הממוצעת על המשכנתא הקיימת גבוהה ב-0.5% או יותר מריביות השוק הנוכחיות. גם שיפור משמעותי בהכנסות, ירידה ביחס ההחזר מההכנסה, או שינוי במצב המשפחתי יכולים להפוך מחזור לכדאי. בדיקת כדאיות מקצועית תיתן תמונה מדויקת.',
  },
  {
    question: 'מה העלויות של מחזור משכנתא?',
    answer: 'עלויות מחזור משכנתא כוללות: עמלת פירעון מוקדם (0-2.3% על מסלולי פריים וקבועה לא צמודה), שמאות מקרקעין (1,500-3,000 ש"ח), עו"ד (2,000-4,000 ש"ח), ודמי פתיחת תיק בבנק החדש (0.25-0.5% מגובה ההלוואה). סה"כ 5,000-25,000 ש"ח תלוי בגובה המשכנתא.',
  },
  {
    question: 'האם יש עמלות פירעון מוקדם?',
    answer: 'עמלות פירעון מוקדם משתנות לפי סוג המסלול: פריים - ללא עמלה כלל. קבועה לא צמודה - עד 2.3% על היתרה. קבועה צמודה - לפי נוסחת ההיוון. משתנה צמודה - בדרך כלל עמלה נמוכה או אפסית. נחשב לכם את העמלות המדויקות לפני ההחלטה.',
  },
  {
    question: 'כמה זמן לוקח תהליך מחזור?',
    answer: 'תהליך מחזור משכנתא אורך 3-6 שבועות בממוצע: בדיקת כדאיות ואיסוף מסמכים (שבוע), הגשה לבנקים וקבלת אישורים (1-2 שבועות), שמאות וביטוחים (שבוע), וחתימה וביצוע (שבוע). במקרים דחופים ניתן לקצר ל-2-3 שבועות.',
  },
  {
    question: 'האם ניתן למחזר רק חלק מהמשכנתא?',
    answer: 'כן, ניתן למחזר מסלולים ספציפיים ולא את כל המשכנתא. לדוגמה - למחזר רק את המסלול הצמוד למדד שעלה, ולהשאיר את הפריים. זו אסטרטגיה נפוצה שחוסכת בעמלות פירעון ומשפרת את התמהיל.',
  },
  {
    question: 'מה ההבדל בין מחזור לגרירת משכנתא?',
    answer: 'מחזור משכנתא הוא פירעון המשכנתא הקיימת ולקיחת משכנתא חדשה, לרוב באותו בנק או בבנק אחר. גרירת משכנתא היא העברת המשכנתא הקיימת לנכס חדש כשמוכרים דירה וקונים אחרת. גרירה שומרת על תנאי המשכנתא המקורית.',
  },
];

const refinanceReasons = [
  {
    title: 'ירידת ריביות',
    desc: 'הריביות בשוק נמוכות מהריביות במשכנתא הקיימת שלכם',
    icon: '📉',
  },
  {
    title: 'שיפור בהכנסה',
    desc: 'השתפרה ההכנסה ואתם יכולים לקבל תנאים טובים יותר',
    icon: '💰',
  },
  {
    title: 'יציאה ממסלול בעייתי',
    desc: 'המסלול הצמוד למדד מכביד והגיע הזמן לצאת ממנו',
    icon: '🔓',
  },
  {
    title: 'קיצור תקופה',
    desc: 'רוצים לסיים את המשכנתא מהר יותר ולחסוך בריביות',
    icon: '⏱️',
  },
  {
    title: 'הקטנת החזר',
    desc: 'צריכים להקטין את ההחזר החודשי לתזרים טוב יותר',
    icon: '📊',
  },
  {
    title: 'איחוד הלוואות',
    desc: 'משלבים הלוואות נוספות למשכנתא בתנאים טובים יותר',
    icon: '🔗',
  },
];
---

<BaseLayout
  title="מחזור משכנתא 2026 | חסכו עד 100,000 ש״ח בריביות"
  description="מחזור משכנתא מקצועי - בדיקת כדאיות חינם, השוואת הצעות מ-7 בנקים, וליווי מלא. חיסכון ממוצע 400-800 ש״ח בחודש."
>
  <SchemaOrg slot="schema" schema={[serviceSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <ServiceHero
    title="מחזור משכנתא"
    description="בדיקת כדאיות מקצועית, השוואת הצעות מכל הבנקים, וליווי מלא בתהליך המחזור - לחיסכון של עשרות אלפי שקלים."
    trustBadges={trustBadges}
    hfcaUrl={consultant.hfcaUrl}
  />

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          מחזור משכנתא הוא פירעון המשכנתא הקיימת ולקיחת משכנתא חדשה בתנאים טובים יותר. עם שינויי הריבית בשוק, <strong>כ-40% מבעלי המשכנתאות בישראל משלמים יותר מדי</strong> על המשכנתא שלהם מבלי לדעת.
        </p>
        <p>
          בדיקת כדאיות מחזור אורכת שעה אחת ויכולה לחשוף חיסכון של 50,000-150,000 ש"ח לאורך חיי המשכנתא. בממוצע, לקוחות שמחזרו דרכנו חוסכים 400-800 ש"ח בחודש בהחזר.
        </p>

        <h2>מתי מחזור משכנתא כדאי?</h2>
        <p>
          מחזור משכנתא הופך כדאי כשמתקיים אחד מהתנאים הבאים:
        </p>
        <ul>
          <li><strong>פער ריביות של 0.5% ומעלה</strong> - הריבית הממוצעת על המשכנתא שלכם גבוהה מריביות השוק</li>
          <li><strong>שיפור ביחס ההחזר מההכנסה</strong> - ההכנסה עלתה ואתם יכולים לקבל תנאים טובים יותר</li>
          <li><strong>מסלול צמוד למדד שעלה</strong> - המדד עלה משמעותית והמסלול הפך יקר מאוד</li>
          <li><strong>נותרו 10+ שנים למשכנתא</strong> - ככל שנותר זמן רב יותר, החיסכון המצטבר גדול יותר</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Example Calculation -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">דוגמת חיסכון במחזור</h2>
      <div class="bg-white p-8 rounded-xl shadow-sm border border-border">
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <h3 class="font-bold text-dark mb-4 text-lg">לפני המחזור</h3>
            <ul class="space-y-2 text-gray-700">
              <li>יתרת משכנתא: <strong>800,000 ש"ח</strong></li>
              <li>תקופה שנותרה: <strong>18 שנים</strong></li>
              <li>ריבית ממוצעת: <strong>4.8%</strong></li>
              <li>החזר חודשי: <strong>5,850 ש"ח</strong></li>
            </ul>
          </div>
          <div>
            <h3 class="font-bold text-dark mb-4 text-lg">אחרי המחזור</h3>
            <ul class="space-y-2 text-gray-700">
              <li>יתרת משכנתא: <strong>800,000 ש"ח</strong></li>
              <li>תקופה: <strong>18 שנים</strong></li>
              <li>ריבית ממוצעת: <strong>3.9%</strong></li>
              <li>החזר חודשי: <strong>5,500 ש"ח</strong></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 pt-6 border-t border-border text-center">
          <p class="text-2xl font-bold text-accent">
            חיסכון: 350 ש"ח בחודש = 75,600 ש"ח סה"כ
          </p>
          <p class="text-sm text-gray-500 mt-2">* לאחר ניכוי עלויות המחזור</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Reasons to Refinance -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">סיבות נפוצות למחזור משכנתא</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {refinanceReasons.map((reason) => (
          <div class="bg-surface p-6 rounded-xl border border-border text-center">
            <div class="text-3xl mb-3">{reason.icon}</div>
            <h3 class="font-bold text-dark mb-2">{reason.title}</h3>
            <p class="text-gray-600 text-sm">{reason.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Costs Section -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">עלויות מחזור משכנתא</h2>
      <div class="bg-white rounded-xl shadow-sm border border-border overflow-hidden">
        <table class="w-full">
          <thead class="bg-brand-50">
            <tr>
              <th class="text-right py-4 px-6 font-bold text-dark">סוג עלות</th>
              <th class="text-right py-4 px-6 font-bold text-dark">טווח מחירים</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr>
              <td class="py-4 px-6 text-gray-700">עמלת פירעון מוקדם</td>
              <td class="py-4 px-6 text-gray-700">0-2.3% מהיתרה (תלוי מסלול)</td>
            </tr>
            <tr>
              <td class="py-4 px-6 text-gray-700">שמאות מקרקעין</td>
              <td class="py-4 px-6 text-gray-700">1,500-3,000 ש"ח</td>
            </tr>
            <tr>
              <td class="py-4 px-6 text-gray-700">עורך דין</td>
              <td class="py-4 px-6 text-gray-700">2,000-4,000 ש"ח</td>
            </tr>
            <tr>
              <td class="py-4 px-6 text-gray-700">דמי פתיחת תיק</td>
              <td class="py-4 px-6 text-gray-700">0.25-0.5% מגובה ההלוואה</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-center text-gray-500 text-sm mt-4">
        * נחשב לכם את העלויות המדויקות ונוודא שהמחזור כדאי לאחר ניכוי כל ההוצאות
      </p>
    </div>
  </section>

  <!-- Process -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">תהליך המחזור - 4 שלבים</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { step: '1', title: 'בדיקת כדאיות', desc: 'ניתוח המשכנתא הקיימת, חישוב עמלות פירעון, והשוואה לתנאי השוק', time: 'שבוע' },
          { step: '2', title: 'השוואת הצעות', desc: 'קבלת הצעות מ-7 בנקים, משא ומתן על תנאים, ובחירת ההצעה הטובה', time: '1-2 שבועות' },
          { step: '3', title: 'הכנת מסמכים', desc: 'שמאות, ביטוחים, אישורי הכנסה, ואימות הנכס', time: 'שבוע' },
          { step: '4', title: 'חתימה וביצוע', desc: 'חתימה על המשכנתא החדשה, פירעון הישנה, ורישום בטאבו', time: 'שבוע' },
        ].map((item) => (
          <div class="bg-surface p-6 rounded-xl border border-border">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-brand-600 text-white rounded-full flex items-center justify-center font-bold shrink-0">
                {item.step}
              </div>
              <div>
                <h3 class="font-bold text-dark mb-1">{item.title}</h3>
                <p class="text-gray-600 text-sm mb-2">{item.desc}</p>
                <span class="text-xs text-brand-600 font-medium">⏱️ {item.time}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-gray-600 mt-8">
        משך התהליך הכולל: <strong>3-6 שבועות</strong> (במקרים דחופים ניתן לקצר ל-2-3 שבועות)
      </p>
    </div>
  </section>

  <!-- When NOT to refinance -->
  <section class="py-12 md:py-16 bg-brand-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">מתי לא כדאי למחזר?</h2>
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          לא בכל מקרה מחזור משכנתא כדאי. הנה מקרים בהם כדאי להישאר עם המשכנתא הקיימת:
        </p>
        <ul>
          <li><strong>נותרו פחות מ-5 שנים</strong> - החיסכון לא יכסה את עלויות המחזור</li>
          <li><strong>יתרה נמוכה מ-200,000 ש"ח</strong> - העלויות הקבועות הופכות את המחזור ללא כדאי</li>
          <li><strong>עמלות פירעון גבוהות</strong> - במיוחד על מסלולים צמודים עם תקופה ארוכה</li>
          <li><strong>שינוי צפוי במצב</strong> - אם מתכננים למכור את הדירה בקרוב</li>
        </ul>
        <p>
          <strong>בבדיקת הכדאיות נחשב בדיוק אם המחזור משתלם במקרה שלכם</strong>, ונמליץ בכנות אם כדאי או לא.
        </p>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">שירותים קשורים</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <a href="/services/debt-consolidation/" class="block bg-surface p-6 rounded-xl border border-border hover:border-brand-300 transition-colors">
          <h3 class="font-bold text-dark mb-2">איחוד הלוואות</h3>
          <p class="text-gray-600 text-sm">שילוב הלוואות קיימות למשכנתא בתנאים טובים יותר ←</p>
        </a>
        <a href="/services/financial-planning/" class="block bg-surface p-6 rounded-xl border border-border hover:border-brand-300 transition-colors">
          <h3 class="font-bold text-dark mb-2">ייעוץ פיננסי</h3>
          <p class="text-gray-600 text-sm">תכנון פיננסי מקיף לאחר המחזור ←</p>
        </a>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות על מחזור משכנתא" />

  <CTASection />
</BaseLayout>
