---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'שירותים', href: '/services/' },
  { label: 'ייעוץ פיננסי וכלכלת משפחה' },
];

const faqItems = [
  {
    question: 'מה כולל ייעוץ פיננסי?',
    answer: 'ניתוח מצב כלכלי, בניית תקציב, תכנון חסכונות, ייעוץ לפני רכישת נכס, והכנה לעתיד.',
  },
  {
    question: 'האם זה רק למי שרוצה לקנות דירה?',
    answer: 'לא. ייעוץ פיננסי מתאים לכל מי שרוצה לנהל את הכסף שלו בצורה חכמה יותר.',
  },
  {
    question: 'כמה פגישות צריך?',
    answer: 'תלוי במורכבות המצב. לרוב מדובר בפגישה אחת או שתיים, עם אפשרות לליווי שוטף.',
  },
];
---

<BaseLayout
  title="ייעוץ פיננסי וכלכלת משפחה | יועץ משכנתאות"
  description="תכנון פיננסי מקיף למשפחה - ניהול תקציב, תכנון חסכונות, והכנה כלכלית לרכישת דירה."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">ייעוץ פיננסי וכלכלת משפחה</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        תכנון פיננסי חכם היום יבטיח עתיד כלכלי יציב - לכם ולמשפחה.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          ניהול פיננסי נכון הוא הבסיס להשגת יעדים כלכליים. בין אם מדובר ברכישת דירה, חיסכון לילדים, או פשוט שליטה בתקציב.
        </p>
        <p>
          תיאור מפורט של שירות הייעוץ הפיננסי יתווסף כאן - כולל הסבר על התהליך, מה בודקים, ומה מקבלים.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">מה כולל השירות</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { title: 'ניתוח מצב כלכלי', desc: 'הבנת ההכנסות, ההוצאות והנכסים הקיימים' },
          { title: 'בניית תקציב', desc: 'תכנון תקציב משפחתי מאוזן וריאלי' },
          { title: 'תכנון חסכונות', desc: 'אסטרטגיה לצבירת הון עצמי לדירה' },
          { title: 'הכנה לעתיד', desc: 'תכנון פנסיוני וביטוחי' },
        ].map((item) => (
          <div class="bg-white p-6 rounded-xl shadow-sm border border-border">
            <h3 class="font-bold text-dark mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות על ייעוץ פיננסי" />

  <CTASection />
</BaseLayout>
