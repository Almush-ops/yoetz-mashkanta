---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema, localBusinessSchema, trustBadges } from '../../data/consultant';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: 'קריית מוצקין' },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'יועץ משכנתאות בקריית מוצקין',
  description: 'ייעוץ משכנתאות מקצועי לתושבי קריית מוצקין - ליווי ברכישת דירה, מחזור משכנתא, משכנתא לזוגות צעירים.',
  url: 'https://yoetz-mashkanta.co.il/areas/kiryat-motzkin/',
  provider: { '@id': 'https://yoetz-mashkanta.co.il/#business' },
  areaServed: { '@type': 'City', name: 'קריית מוצקין' },
};

const faqItems = [
  {
    question: 'כמה עולה דירה ממוצעת בקריית מוצקין?',
    answer: 'מחירי דירות בקריית מוצקין נעים בין 1.4-2.0 מיליון ש"ח ל-3-4 חדרים. שכונות מבוקשות כמו הירוקה והמרכז מציעות דירות ב-1.6-2.2 מיליון.',
  },
  {
    question: 'האם אתם מגיעים לפגישות בקריית מוצקין?',
    answer: 'כן, המשרד שלנו נמצא בקריית ביאליק הסמוכה (5 דקות נסיעה). אנו מגיעים גם לפגישות בבית הלקוח בקריית מוצקין.',
  },
  {
    question: 'למה כדאי לקנות דירה בקריית מוצקין?',
    answer: 'קריית מוצקין נחשבת לאחת הערים האיכותיות בקריות - בתי ספר מצוינים, פארקים ושטחים ירוקים, תחנת רכבת, וקרבה לים. המחירים עדיין נגישים יחסית למרכז.',
  },
  {
    question: 'יש תחנת רכבת בקריית מוצקין?',
    answer: 'כן, תחנת "קריות" נמצאת בקריית מוצקין ומחברת לחיפה (10 דקות) ולתל אביב (שעה). זה יתרון משמעותי לעובדים מחוץ לאזור.',
  },
  {
    question: 'כמה הון עצמי צריך לדירה בקריית מוצקין?',
    answer: 'לדירה ממוצעת (1.7 מיליון ש"ח) תצטרכו כ-425,000 ש"ח הון עצמי (25%). זוגות צעירים יכולים לקבל מענקים של 40,000-100,000 ש"ח.',
  },
];
---

<BaseLayout
  title="יועץ משכנתאות בקריית מוצקין 2026 | ייעוץ משכנתאות מקצועי"
  description="יועץ משכנתאות בקריית מוצקין - ליווי מקצועי ברכישת דירה ומחזור משכנתא. 169 לקוחות מרוצים, דירוג 9.68. פגישה ראשונה ללא עלות."
>
  <SchemaOrg slot="schema" schema={[serviceSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">יועץ משכנתאות בקריית מוצקין</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        ייעוץ משכנתאות מקצועי לתושבי קריית מוצקין - היכרות מעמיקה עם שוק הנדל"ן המקומי וליווי אישי מהשלב הראשון.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {trustBadges.rating}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          {trustBadges.clients}
        </span>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          <strong>קריית מוצקין נחשבת לאחת הערים האיכותיות ביותר בקריות</strong>, עם אוכלוסייה של כ-45,000 תושבים. העיר מציעה בתי ספר מצוינים, שטחים ירוקים, תחנת רכבת מרכזית, וקרבה לים - הכל במחירים נגישים יחסית למרכז.
        </p>
        <p>
          המשרד שלנו נמצא בקריית ביאליק הסמוכה (5 דקות נסיעה), ואנחנו מלווים משפחות רבות מקריית מוצקין בתהליך רכישת דירה ומחזור משכנתא.
        </p>

        <h2 class="text-xl font-bold text-dark mt-8 mb-4">מחירי דירות בקריית מוצקין 2026</h2>
        <div class="bg-surface p-6 rounded-xl not-prose">
          <div class="grid md:grid-cols-2 gap-4">
            <div class="bg-white p-4 rounded-lg border border-border">
              <h4 class="font-bold text-dark">מרכז העיר והירוקה</h4>
              <p class="text-brand-600 font-bold">1.6-2.2M ש"ח</p>
              <p class="text-sm text-gray-600">קרבה לשירותים, בנייה חדשה</p>
            </div>
            <div class="bg-white p-4 rounded-lg border border-border">
              <h4 class="font-bold text-dark">שכונות ותיקות</h4>
              <p class="text-brand-600 font-bold">1.4-1.7M ש"ח</p>
              <p class="text-sm text-gray-600">בתים צמודי קרקע, מגרשים גדולים</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">השירותים שלנו</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <a href="/services/mortgage-consultation/" class="block bg-white p-6 rounded-xl hover:shadow-md transition-shadow border border-border">
          <h3 class="font-bold text-dark mb-2">ייעוץ משכנתא לרכישת דירה</h3>
          <p class="text-gray-600 text-sm">השוואת 7 בנקים, בניית תמהיל, וליווי עד החתימה.</p>
        </a>
        <a href="/services/mortgage-refinance/" class="block bg-white p-6 rounded-xl hover:shadow-md transition-shadow border border-border">
          <h3 class="font-bold text-dark mb-2">מחזור משכנתא</h3>
          <p class="text-gray-600 text-sm">בדיקת כדאיות ללא עלות. חיסכון ממוצע: 50,000-150,000 ש"ח.</p>
        </a>
        <a href="/services/young-couples/" class="block bg-white p-6 rounded-xl hover:shadow-md transition-shadow border border-border">
          <h3 class="font-bold text-dark mb-2">משכנתא לזוגות צעירים</h3>
          <p class="text-gray-600 text-sm">פטור ממס רכישה ומענקים לזכאים.</p>
        </a>
        <a href="/guides/down-payment/" class="block bg-white p-6 rounded-xl hover:shadow-md transition-shadow border border-border">
          <h3 class="font-bold text-dark mb-2">מדריך: הון עצמי למשכנתא</h3>
          <p class="text-gray-600 text-sm">כמה צריך ומאיפה אפשר לגייס?</p>
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">אזורים נוספים</h2>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/areas/haifa/" class="bg-surface px-4 py-2 rounded-lg border border-border hover:border-brand-300 text-sm">חיפה</a>
        <a href="/areas/kiryat-bialik/" class="bg-surface px-4 py-2 rounded-lg border border-border hover:border-brand-300 text-sm">קריית ביאליק</a>
        <a href="/areas/kiryat-ata/" class="bg-surface px-4 py-2 rounded-lg border border-border hover:border-brand-300 text-sm">קריית אתא</a>
        <a href="/areas/nesher/" class="bg-surface px-4 py-2 rounded-lg border border-border hover:border-brand-300 text-sm">נשר</a>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות - קריית מוצקין" />

  <CTASection />
</BaseLayout>
