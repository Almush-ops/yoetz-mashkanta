---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema, localBusinessSchema, trustBadges } from '../../data/consultant';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: 'טירת כרמל' },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'יועץ משכנתאות בטירת כרמל',
  description: 'ייעוץ משכנתאות מקצועי לתושבי טירת כרמל - ליווי ברכישת דירה, מחזור משכנתא, משכנתא לזוגות צעירים.',
  url: 'https://yoetz-mashkanta.co.il/areas/tirat-carmel/',
  provider: { '@id': 'https://yoetz-mashkanta.co.il/#business' },
  areaServed: { '@type': 'City', name: 'טירת כרמל' },
};

const faqItems = [
  {
    question: 'כמה עולה דירה ממוצעת בטירת כרמל?',
    answer: 'מחירי דירות בטירת כרמל הם מהנמוכים באזור חיפה - 900,000-1.4 מיליון ש"ח ל-3-4 חדרים. יש פרויקטים חדשים עם מחירים של 1.2-1.6 מיליון.',
  },
  {
    question: 'למה המחירים בטירת כרמל נמוכים?',
    answer: 'טירת כרמל היא עיר קטנה שעוברת תהליכי התחדשות. המחירים הנמוכים יחסית מושכים זוגות צעירים ומשקיעים. יש פוטנציאל משמעותי לעליית ערך.',
  },
  {
    question: 'האם יש חוף ים בטירת כרמל?',
    answer: 'כן, טירת כרמל גובלת בים התיכון עם חופים. הקרבה לים היא יתרון משמעותי לאיכות החיים.',
  },
  {
    question: 'כמה הון עצמי צריך לדירה בטירת כרמל?',
    answer: 'לדירה ממוצעת (1.1 מיליון ש"ח) תצטרכו כ-275,000 ש"ח הון עצמי (25%). זו אחת נקודות הכניסה הנמוכות ביותר באזור.',
  },
  {
    question: 'האם יש התחדשות עירונית בטירת כרמל?',
    answer: 'כן, יש תכניות משמעותיות להתחדשות עירונית ופינוי-בינוי. רוכשים יכולים ליהנות גם ממחירים נמוכים כיום וגם מעליית ערך עתידית.',
  },
];
---

<BaseLayout
  title="יועץ משכנתאות בטירת כרמל 2026 | מחירים נמוכים | איתי אנצל"
  description="יועץ משכנתאות בטירת כרמל - ליווי מקצועי ברכישת דירה ומחזור משכנתא. מחירי דירות נמוכים: 900K-1.4M ש״ח. קרבה לים. פגישה ראשונה ללא עלות."
>
  <SchemaOrg slot="schema" schema={[serviceSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">יועץ משכנתאות בטירת כרמל</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        ייעוץ משכנתאות מקצועי לתושבי טירת כרמל - מחירי דירות נמוכים, קרבה לים, ופוטנציאל עליית ערך.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          {trustBadges.rating}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          {trustBadges.clients}
        </span>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          <strong>טירת כרמל מציעה את מחירי הדירות הנמוכים ביותר באזור חיפה</strong> - הזדמנות מצוינת לרוכשים ראשונים ולמשקיעים. העיר גובלת בים, עוברת תהליכי התחדשות, ויש פוטנציאל משמעותי לעליית ערך.
        </p>
        <p>
          אני מלווה זוגות צעירים ומשפחות מטירת כרמל ברכישת הדירה הראשונה. המחירים הנגישים מאפשרים כניסה לשוק הדיור עם הון עצמי נמוך יחסית.
        </p>

        <h2 class="text-xl font-bold text-dark mt-8 mb-4">מחירי דירות בטירת כרמל 2026</h2>
        <div class="bg-surface p-6 rounded-xl not-prose">
          <div class="grid md:grid-cols-2 gap-4">
            <div class="bg-white p-4 rounded-lg border border-border">
              <h4 class="font-bold text-dark">דירות קיימות</h4>
              <p class="text-brand-600 font-bold">900K-1.2M ש"ח</p>
              <p class="text-sm text-gray-600">הון עצמי: 225,000-300,000 ש"ח</p>
            </div>
            <div class="bg-white p-4 rounded-lg border border-border">
              <h4 class="font-bold text-dark">פרויקטים חדשים</h4>
              <p class="text-brand-600 font-bold">1.2-1.6M ש"ח</p>
              <p class="text-sm text-gray-600">בנייה מודרנית, מפרט גבוה</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">למה לקנות בטירת כרמל?</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { icon: '💰', title: 'מחירים נמוכים', desc: 'נקודת כניסה נגישה לשוק' },
          { icon: '🏖️', title: 'קרבה לים', desc: 'חוף ים במרחק הליכה' },
          { icon: '📈', title: 'פוטנציאל', desc: 'עליית ערך צפויה' },
          { icon: '🏗️', title: 'התחדשות', desc: 'פרויקטים חדשים' },
        ].map((item) => (
          <div class="bg-white p-4 rounded-xl border border-border text-center">
            <span class="text-2xl">{item.icon}</span>
            <h3 class="font-bold text-dark mt-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">השירותים שלנו</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <a href="/services/young-couples/" class="block bg-surface p-6 rounded-xl hover:shadow-md border border-border">
          <h3 class="font-bold text-dark mb-2">משכנתא לזוגות צעירים</h3>
          <p class="text-gray-600 text-sm">טירת כרמל אידיאלית לרוכשים ראשונים - מחירים + הטבות.</p>
        </a>
        <a href="/services/mortgage-consultation/" class="block bg-surface p-6 rounded-xl hover:shadow-md border border-border">
          <h3 class="font-bold text-dark mb-2">ייעוץ משכנתא</h3>
          <p class="text-gray-600 text-sm">השוואת 7 בנקים, בניית תמהיל, וליווי עד החתימה.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">אזורים נוספים</h2>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/areas/haifa/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 text-sm">חיפה</a>
        <a href="/areas/nesher/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 text-sm">נשר</a>
        <a href="/areas/kiryat-ata/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 text-sm">קריית אתא</a>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות - טירת כרמל" />

  <CTASection />
</BaseLayout>
