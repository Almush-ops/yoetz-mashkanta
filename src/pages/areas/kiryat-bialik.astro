---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: 'קריית ביאליק' },
];

const faqItems = [
  {
    question: 'איפה נמצא המשרד?',
    answer: 'המשרד שלנו נמצא ברחוב קרן היסוד 7, קריית ביאליק - נגיש ונוח להגעה.',
  },
  {
    question: 'האם אפשר להגיע גם ללא רכב?',
    answer: 'כן, המשרד נמצא במרחק הליכה מתחנות אוטובוס ויש חניה בסביבה.',
  },
  {
    question: 'מה שעות הפעילות?',
    answer: 'אנו פעילים בימים א-ה, ובמידת הצורך גם בשעות הערב ובימי שישי לפי תיאום.',
  },
];
---

<BaseLayout
  title="יועץ משכנתאות בקריית ביאליק | ייעוץ משכנתאות"
  description="יועץ משכנתאות בקריית ביאליק - משרד ברחוב קרן היסוד 7. ליווי מקצועי ואישי בכל סוגי המשכנתאות."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">יועץ משכנתאות בקריית ביאליק</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        המשרד הראשי שלנו נמצא בקריית ביאליק - בואו לפגישת ייעוץ אישית.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          קריית ביאליק היא עיר מגורים איכותית עם קהילה חמה ושירותים מעולים. המשרד שלנו ממוקם ברחוב קרן היסוד 7, ואנחנו מזמינים אתכם לפגישת ייעוץ.
        </p>
        <p>
          תוכן מפורט על שוק הנדל"ן בקריית ביאליק והשירותים שלנו יתווסף כאן.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">פרטי המשרד</h2>
      <div class="bg-white p-8 rounded-xl shadow-sm border border-border max-w-md mx-auto text-center">
        <div class="w-16 h-16 bg-brand-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 class="font-bold text-dark text-lg mb-2">כתובת המשרד</h3>
        <p class="text-gray-600">קרן היסוד 7, קריית ביאליק</p>
        <p class="text-sm text-gray-500 mt-2">חניה זמינה בסביבה</p>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות - קריית ביאליק" />

  <CTASection />
</BaseLayout>
