---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema, localBusinessSchema, trustBadges } from '../../data/consultant';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: 'קריית ביאליק' },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'יועץ משכנתאות בקריית ביאליק',
  description: 'ייעוץ משכנתאות מקצועי בקריית ביאליק - המשרד הראשי. ליווי ברכישת דירה, מחזור משכנתא, משכנתא לזוגות צעירים.',
  url: 'https://yoetz-mashkanta.co.il/areas/kiryat-bialik/',
  provider: { '@id': 'https://yoetz-mashkanta.co.il/#business' },
  areaServed: { '@type': 'City', name: 'קריית ביאליק' },
};

const faqItems = [
  {
    question: 'איפה נמצא המשרד?',
    answer: 'המשרד שלנו נמצא ברחוב קרן היסוד 7, קריית ביאליק. נגיש בקלות מחיפה והקריות, עם חניה חינמית בסביבה.',
  },
  {
    question: 'כמה עולה דירה ממוצעת בקריית ביאליק?',
    answer: 'מחירי דירות בקריית ביאליק נעים בין 1.3-1.9 מיליון ש"ח ל-3-4 חדרים. שכונות חדשות כמו קריית ביאליק הירוקה מציעות דירות ב-1.7-2.2 מיליון.',
  },
  {
    question: 'מה שעות הפעילות?',
    answer: 'אנו פעילים בימים א-ה בשעות 09:00-18:00. ניתן לתאם פגישות גם בשעות הערב ובימי שישי לפי הצורך.',
  },
  {
    question: 'האם אפשר להגיע גם ללא רכב?',
    answer: 'כן, המשרד נמצא במרחק הליכה מתחנות אוטובוס. קווים 3, 5 ו-27 עוצרים בקרבת מקום. יש גם חניה חינמית בסביבה.',
  },
  {
    question: 'למה כדאי לקנות דירה בקריית ביאליק?',
    answer: 'קריית ביאליק מציעה יחס מחיר-איכות מצוין - מחירים נמוכים ב-15-20% מחיפה, עם שירותים מעולים, בתי ספר טובים, וקרבה לים ולטבע. העיר עוברת התחדשות עם פרויקטים חדשים.',
  },
  {
    question: 'כמה הון עצמי צריך לדירה בקריית ביאליק?',
    answer: 'לדירה ממוצעת (1.6 מיליון ש"ח) תצטרכו כ-400,000 ש"ח הון עצמי (25%). זוגות צעירים זכאים יכולים לקבל מענקים של 40,000-100,000 ש"ח.',
  },
];

const neighborhoods = [
  { name: 'קריית ביאליק הירוקה', price: '1.7-2.2M', desc: 'שכונה חדשה, בנייה מודרנית, פארקים', type: 'משפחות צעירות' },
  { name: 'מרכז העיר', price: '1.4-1.8M', desc: 'קרבה לשירותים, תחבורה ציבורית', type: 'כל הגילאים' },
  { name: 'הותיקה', price: '1.3-1.6M', desc: 'בתים צמודי קרקע, אווירה שקטה', type: 'משפחות מבוססות' },
  { name: 'גבעת גאולה', price: '1.5-1.9M', desc: 'נוף לים, קרבה לחוף', type: 'זוגות עם ילדים' },
];
---

<BaseLayout
  title="יועץ משכנתאות בקריית ביאליק | המשרד הראשי | איתי אנצל"
  description="יועץ משכנתאות בקריית ביאליק - משרד ראשי ברחוב קרן היסוד 7. 169 לקוחות מרוצים, דירוג 9.68. ליווי מקצועי ברכישת דירה ומחזור משכנתא. פגישה ראשונה ללא עלות."
>
  <SchemaOrg slot="schema" schema={[serviceSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="inline-block bg-accent/20 text-white text-sm font-medium px-3 py-1 rounded-full mb-4">המשרד הראשי</span>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">יועץ משכנתאות בקריית ביאליק</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        המשרד שלנו נמצא בקריית ביאליק, בלב הקריות. בואו לפגישת ייעוץ אישית וקבלו ליווי מקצועי בכל סוגי המשכנתאות.
      </p>
      <!-- E-E-A-T Trust Badges -->
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {trustBadges.rating}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
          {trustBadges.clients}
        </span>
        <a href={consultant.hfcaUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full hover:bg-white/20 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          {trustBadges.hfca}
        </a>
      </div>
    </div>
  </section>

  <!-- Office Info -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-brand-50 p-8 rounded-2xl border border-brand-200 mb-8">
        <div class="flex flex-col md:flex-row gap-8 items-center">
          <div class="w-24 h-24 bg-brand-600 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-12 h-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div class="text-center md:text-right flex-1">
            <h2 class="text-2xl font-bold text-dark mb-2">כתובת המשרד</h2>
            <p class="text-xl text-gray-700 mb-2">קרן היסוד 7, קריית ביאליק</p>
            <p class="text-gray-600">חניה חינמית | נגיש בתחבורה ציבורית | קווים 3, 5, 27</p>
          </div>
          <div class="flex flex-col gap-2">
            <a href="tel:054-284-8431" class="inline-flex items-center justify-center gap-2 bg-brand-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-700 transition-colors">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              054-284-8431
            </a>
            <a href="/contact/" class="inline-flex items-center justify-center gap-2 border-2 border-brand-600 text-brand-600 px-6 py-3 rounded-lg font-medium hover:bg-brand-50 transition-colors">
              קביעת פגישה
            </a>
          </div>
        </div>
      </div>

      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          <strong>קריית ביאליק היא עיר מגורים איכותית בלב הקריות</strong>, עם אוכלוסייה של כ-42,000 תושבים. העיר מציעה שילוב אידיאלי של מחירי דיור נגישים, שירותים מפותחים, קרבה לחיפה (10 דקות נסיעה), ואיכות חיים גבוהה.
        </p>
        <p>
          המשרד שלנו ממוקם בלב העיר, ברחוב קרן היסוד 7. אנו מלווים עשרות משפחות מקריית ביאליק ומהקריות בתהליך רכישת דירה ומחזור משכנתא, עם היכרות מעמיקה של השוק המקומי ושל סניפי הבנקים באזור.
        </p>

        <h2 class="text-xl font-bold text-dark mt-8 mb-4">מחירי דירות בקריית ביאליק 2026</h2>
        <p>
          שוק הנדל"ן בקריית ביאליק מציע מגוון אפשרויות - מדירות קיימות במחירים נגישים ועד פרויקטים חדשים בשכונות מתפתחות:
        </p>
      </div>
    </div>
  </section>

  <!-- Neighborhoods -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">שכונות בקריית ביאליק - מחירים וקהל יעד</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {neighborhoods.map((n) => (
          <div class="bg-white p-5 rounded-xl border border-border">
            <h3 class="font-bold text-dark text-lg mb-2">{n.name}</h3>
            <p class="text-brand-600 font-bold mb-2">{n.price} ש"ח</p>
            <p class="text-gray-600 text-sm mb-2">{n.desc}</p>
            <span class="inline-block text-xs bg-brand-50 text-brand-700 px-2 py-1 rounded">{n.type}</span>
          </div>
        ))}
      </div>
      <p class="text-sm text-gray-500 text-center mt-4">* המחירים הם אומדן לדירות 3-4 חדרים, מרץ 2026</p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">השירותים שלנו</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <a href="/services/mortgage-consultation/" class="block bg-surface p-6 rounded-xl hover:shadow-md transition-shadow border border-border hover:border-brand-300">
          <h3 class="font-bold text-dark mb-2">ייעוץ משכנתא לרכישת דירה</h3>
          <p class="text-gray-600 text-sm mb-3">ליווי מלא ברכישת דירה - השוואת 7 בנקים, בניית תמהיל, וליווי עד החתימה.</p>
          <span class="text-brand-600 text-sm font-medium">למידע נוסף ←</span>
        </a>
        <a href="/services/mortgage-refinance/" class="block bg-surface p-6 rounded-xl hover:shadow-md transition-shadow border border-border hover:border-brand-300">
          <h3 class="font-bold text-dark mb-2">מחזור משכנתא</h3>
          <p class="text-gray-600 text-sm mb-3">בדיקת כדאיות מחזור ללא עלות. חיסכון ממוצע: 50,000-150,000 ש"ח.</p>
          <span class="text-brand-600 text-sm font-medium">למידע נוסף ←</span>
        </a>
        <a href="/services/young-couples/" class="block bg-surface p-6 rounded-xl hover:shadow-md transition-shadow border border-border hover:border-brand-300">
          <h3 class="font-bold text-dark mb-2">משכנתא לזוגות צעירים</h3>
          <p class="text-gray-600 text-sm mb-3">פטור ממס רכישה, מענקים לזכאים, וליווי מותאם לרוכשים ראשונים.</p>
          <span class="text-brand-600 text-sm font-medium">למידע נוסף ←</span>
        </a>
        <a href="/services/financial-planning/" class="block bg-surface p-6 rounded-xl hover:shadow-md transition-shadow border border-border hover:border-brand-300">
          <h3 class="font-bold text-dark mb-2">ייעוץ פיננסי</h3>
          <p class="text-gray-600 text-sm mb-3">תכנון תקציב משפחתי והכנה לרכישת דירה.</p>
          <span class="text-brand-600 text-sm font-medium">למידע נוסף ←</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Other Areas -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">אזורים נוספים שאנו משרתים</h2>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/areas/haifa/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">חיפה</a>
        <a href="/areas/kiryat-motzkin/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">קריית מוצקין</a>
        <a href="/areas/kiryat-ata/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">קריית אתא</a>
        <a href="/areas/nesher/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">נשר</a>
        <a href="/areas/tirat-carmel/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">טירת כרמל</a>
        <a href="/areas/zichron-yaakov/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">זכרון יעקב</a>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות - קריית ביאליק" />

  <CTASection
    title="מחפשים יועץ משכנתאות בקריות?"
    subtitle="בואו לפגישת ייעוץ במשרד שלנו או בזום - ללא עלות"
  />
</BaseLayout>
