---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';

const areas = [
  {
    name: 'חיפה',
    slug: 'haifa',
    description: 'ייעוץ משכנתאות מקצועי בחיפה והסביבה - ליווי אישי בכל תהליך המשכנתא.',
  },
  {
    name: 'קריית ביאליק',
    slug: 'kiryat-bialik',
    description: 'יועץ משכנתאות בקריית ביאליק - המשרד שלנו ממוקם ברחוב קרן היסוד 7.',
  },
  {
    name: 'קריית מוצקין',
    slug: 'kiryat-motzkin',
    description: 'ייעוץ משכנתאות בקריית מוצקין - שירות מקצועי לתושבי העיר והסביבה.',
  },
  {
    name: 'קריית אתא',
    slug: 'kiryat-ata',
    description: 'יועץ משכנתאות בקריית אתא - ליווי מקצועי ברכישת דירה או מחזור משכנתא.',
  },
  {
    name: 'נשר',
    slug: 'nesher',
    description: 'ייעוץ משכנתאות בנשר - שירות אישי ומקצועי לתושבי העיר.',
  },
  {
    name: 'טירת כרמל',
    slug: 'tirat-carmel',
    description: 'יועץ משכנתאות בטירת כרמל - ליווי בכל סוגי המשכנתאות.',
  },
  {
    name: 'זכרון יעקב',
    slug: 'zichron-yaakov',
    description: 'ייעוץ משכנתאות בזכרון יעקב - שירות מקצועי לתושבי האזור.',
  },
];
---

<BaseLayout
  title="אזורי שירות | יועץ משכנתאות חיפה והקריות"
  description="יועץ משכנתאות בחיפה, קריית ביאליק, קריית מוצקין, קריית אתא, נשר, טירת כרמל וזכרון יעקב. ליווי מקצועי ואישי."
>
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-dark mb-4">אזורי שירות</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        אנו מעניקים שירותי ייעוץ משכנתאות באזור חיפה והקריות. הפגישות יכולות להתקיים במשרד, בביתכם, או בזום.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {areas.map((area) => (
          <a
            href={`/areas/${area.slug}/`}
            class="group block bg-white border border-border rounded-xl p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
          >
            <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent-200 transition-colors">
              <svg class="w-6 h-6 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-dark mb-2 group-hover:text-brand-600 transition-colors">
              יועץ משכנתאות ב{area.name}
            </h2>
            <p class="text-gray-600 text-sm leading-relaxed">{area.description}</p>
            <span class="inline-flex items-center gap-1 text-brand-600 font-medium text-sm mt-4 group-hover:gap-2 transition-all">
              למידע נוסף
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
