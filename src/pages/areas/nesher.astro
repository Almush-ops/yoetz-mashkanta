---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: 'נשר' },
];

const faqItems = [
  {
    question: 'האם אתם מגיעים לנשר?',
    answer: 'כן, אנו מעניקים שירות לתושבי נשר. הפגישות יכולות להתקיים במשרד או אצלכם.',
  },
  {
    question: 'מה מיוחד בנשר?',
    answer: 'נשר היא עיר שקטה עם אווירה קהילתית, קרובה לחיפה עם מחירים נוחים יותר.',
  },
  {
    question: 'האם יש התחדשות עירונית בנשר?',
    answer: 'יש פרויקטים של התחדשות עירונית בנשר. נוכל לעזור גם עם משכנתא לדירה בפרויקט חדש.',
  },
];
---

<BaseLayout
  title="יועץ משכנתאות בנשר | ייעוץ משכנתאות"
  description="יועץ משכנתאות בנשר - ליווי מקצועי ברכישת דירה ומחזור משכנתא. שירות אישי לתושבי נשר."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">יועץ משכנתאות בנשר</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        ייעוץ משכנתאות מקצועי לתושבי נשר - ליווי אישי בדרך לדירה שלכם.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          נשר היא עיר מגורים שקטה ומשפחתית, הממוקמת בין חיפה לקריות. העיר מציעה איכות חיים גבוהה במחירים נגישים יחסית.
        </p>
        <p>
          תוכן מפורט על שוק הנדל"ן בנשר והשירותים שלנו יתווסף כאן.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">השירותים שלנו בנשר</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { title: 'משכנתא לדירה', desc: 'ליווי ברכישת דירה חדשה או יד שנייה' },
          { title: 'מחזור משכנתא', desc: 'בדיקת כדאיות והפחתת החזרים' },
          { title: 'ייעוץ ראשוני', desc: 'פגישת היכרות ללא עלות' },
          { title: 'ליווי מלא', desc: 'מהבדיקה הראשונית ועד החתימה' },
        ].map((item) => (
          <div class="bg-white p-6 rounded-xl shadow-sm border border-border">
            <h3 class="font-bold text-dark mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות - נשר" />

  <CTASection />
</BaseLayout>
