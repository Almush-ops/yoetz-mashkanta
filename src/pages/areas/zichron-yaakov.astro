---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { consultant, personSchema, localBusinessSchema, trustBadges } from '../../data/consultant';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: 'זכרון יעקב' },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'יועץ משכנתאות בזכרון יעקב',
  description: 'ייעוץ משכנתאות מקצועי לזכרון יעקב - ליווי ברכישת נכס, מחזור משכנתא, ופתרונות למשכנתאות בסכומים גבוהים. התמחות בנכסי יוקרה.',
  url: 'https://yoetz-mashkanta.co.il/areas/zichron-yaakov/',
  provider: { '@id': 'https://yoetz-mashkanta.co.il/#business' },
  areaServed: { '@type': 'City', name: 'זכרון יעקב' },
};

const faqItems = [
  {
    question: 'כמה עולה דירה ממוצעת בזכרון יעקב?',
    answer: 'מחירי דירות בזכרון יעקב גבוהים יחסית - 2.0-3.5 מיליון ש"ח ל-3-4 חדרים, תלוי במיקום ובגודל. בתים פרטיים יכולים להגיע ל-4-7 מיליון ש"ח ויותר.',
  },
  {
    question: 'האם יש אתגרים מיוחדים במשכנתא לזכרון?',
    answer: 'נכסים יקרים דורשים הון עצמי גבוה יותר ויכולת החזר משמעותית. יש מסלולים מיוחדים למשכנתאות גדולות, ואנחנו מתמחים בניהול עסקאות מורכבות אלו.',
  },
  {
    question: 'האם אתם מגיעים לזכרון יעקב?',
    answer: 'כן, אנו מגיעים לפגישות בזכרון יעקב (25 דקות מהמשרד בקריית ביאליק). אפשר גם לקיים פגישות בזום לנוחותכם. הפגישה הראשונה ללא עלות.',
  },
  {
    question: 'למה זכרון יעקב יקרה יחסית?',
    answer: 'זכרון יעקב היא עיירה ייחודית עם אופי כפרי, נופים מרהיבים לים ולעמק, יקבים ותרבות עשירה, קהילה איכותית, ומסורת היסטורית. הביקוש גבוה והיצע הקרקעות מוגבל.',
  },
  {
    question: 'מה ההבדל במשכנתא לנכס יקר?',
    answer: 'נכסים מעל 2.5 מיליון ש"ח דורשים בדרך כלל הון עצמי גבוה יותר (30-50%) והוכחת יכולת החזר חזקה. יש גם מסלולים מיוחדים לעצמאים ולבעלי הכנסות גבוהות.',
  },
  {
    question: 'כמה הון עצמי צריך לנכס בזכרון?',
    answer: 'לדירה ממוצעת (2.5 מיליון ש"ח) תצטרכו 625,000-1,250,000 ש"ח הון עצמי (25-50%), תלוי בסכום ובפרופיל הרוכש. לבתים פרטיים דרישות ההון גבוהות יותר.',
  },
];

const neighborhoods = [
  { name: 'מרכז זכרון (היסטורי)', price: '2.5-3.5M', desc: 'מבנים היסטוריים, אווירה ייחודית', type: 'אוהבי תרבות' },
  { name: 'שכונות חדשות', price: '2.2-3.0M', desc: 'בנייה מודרנית, נוף יפה', type: 'משפחות צעירות' },
  { name: 'אזורי הוילות', price: '4.0-7.0M+', desc: 'בתים פרטיים, מגרשים גדולים', type: 'משפחות מבוססות' },
  { name: 'שולי העיירה', price: '2.0-2.5M', desc: 'שקט, נוף, קרבה לטבע', type: 'זוגות ומשפחות' },
];
---

<BaseLayout
  title="יועץ משכנתאות בזכרון יעקב 2026 | נכסי יוקרה | איתי אנצל"
  description="יועץ משכנתאות בזכרון יעקב - ליווי מקצועי ברכישת נכסים יקרים ומורכבים. התמחות במשכנתאות בסכומים גבוהים. 169 לקוחות מרוצים. פגישה ראשונה ללא עלות."
>
  <SchemaOrg slot="schema" schema={[serviceSchema, personSchema, localBusinessSchema]} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">יועץ משכנתאות בזכרון יעקב</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        ייעוץ משכנתאות מקצועי לזכרון יעקב - התמחות בנכסי יוקרה ובעסקאות מורכבות. ליווי אישי ברכישת נכס באחת העיירות היפות בארץ.
      </p>
      <!-- E-E-A-T Trust Badges -->
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {trustBadges.rating}
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
          {trustBadges.clients}
        </span>
        <a href={consultant.hfcaUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm text-brand-100 bg-white/10 px-3 py-1.5 rounded-full hover:bg-white/20 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          {trustBadges.hfca}
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          <strong>זכרון יעקב היא אחת העיירות הייחודיות והיפות בישראל</strong> - שילוב של מסורת היסטורית, יקבים מפורסמים, נופים מרהיבים לים ולעמק יזרעאל, וקהילה איכותית. רכישת נכס בזכרון היא השקעה משמעותית שדורשת תכנון פיננסי מדוקדק.
        </p>
        <p>
          אני מלווה משפחות מזכרון יעקב והסביבה ברכישת נכסים ובמחזור משכנתאות. ההתמחות שלי בעסקאות בסכומים גבוהים ובמקרים מורכבים מאפשרת לי להביא פתרונות יצירתיים גם למצבים מאתגרים.
        </p>

        <h2 class="text-xl font-bold text-dark mt-8 mb-4">מחירי נכסים בזכרון יעקב 2026 - לפי אזורים</h2>
        <p>
          שוק הנדל"ן בזכרון יעקב פרמיום - מדירות ב-2 מיליון ש"ח ועד בתים פרטיים ב-7 מיליון ומעלה. הנה סקירה של האזורים העיקריים:
        </p>
      </div>
    </div>
  </section>

  <!-- Neighborhoods Table -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">אזורים בזכרון יעקב - מחירים וקהל יעד</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {neighborhoods.map((n) => (
          <div class="bg-white p-5 rounded-xl border border-border">
            <h3 class="font-bold text-dark text-lg mb-2">{n.name}</h3>
            <p class="text-brand-600 font-bold mb-2">{n.price} ש"ח</p>
            <p class="text-gray-600 text-sm mb-2">{n.desc}</p>
            <span class="inline-block text-xs bg-brand-50 text-brand-700 px-2 py-1 rounded">{n.type}</span>
          </div>
        ))}
      </div>
      <p class="text-sm text-gray-500 text-center mt-4">* המחירים הם אומדן לדירות 3-4 חדרים, מרץ 2026</p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">השירותים שלנו לתושבי זכרון יעקב</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <a href="/services/mortgage-consultation/" class="block bg-surface p-6 rounded-xl hover:shadow-md transition-shadow border border-border hover:border-brand-300">
          <h3 class="font-bold text-dark mb-2">ייעוץ משכנתא לנכס יוקרה</h3>
          <p class="text-gray-600 text-sm mb-3">התמחות במשכנתאות בסכומים גבוהים ובעסקאות מורכבות. ליווי מקצועי מהשלב הראשון.</p>
          <span class="text-brand-600 text-sm font-medium">למידע נוסף ←</span>
        </a>
        <a href="/services/mortgage-refinance/" class="block bg-surface p-6 rounded-xl hover:shadow-md transition-shadow border border-border hover:border-brand-300">
          <h3 class="font-bold text-dark mb-2">מחזור משכנתא</h3>
          <p class="text-gray-600 text-sm mb-3">בדיקת כדאיות מחזור ללא עלות. פוטנציאל חיסכון משמעותי במשכנתאות גדולות.</p>
          <span class="text-brand-600 text-sm font-medium">למידע נוסף ←</span>
        </a>
        <a href="/services/financial-planning/" class="block bg-surface p-6 rounded-xl hover:shadow-md transition-shadow border border-border hover:border-brand-300">
          <h3 class="font-bold text-dark mb-2">ייעוץ פיננסי</h3>
          <p class="text-gray-600 text-sm mb-3">תכנון פיננסי לרכישת נכס יקר - ניהול תזרים, אופטימיזציה מיסויית.</p>
          <span class="text-brand-600 text-sm font-medium">למידע נוסף ←</span>
        </a>
        <a href="/services/declined-applicants/" class="block bg-surface p-6 rounded-xl hover:shadow-md transition-shadow border border-border hover:border-brand-300">
          <h3 class="font-bold text-dark mb-2">פתרונות למקרים מורכבים</h3>
          <p class="text-gray-600 text-sm mb-3">עצמאים, הכנסות לא שכיר, נכסים ייחודיים - יש פתרונות.</p>
          <span class="text-brand-600 text-sm font-medium">למידע נוסף ←</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Zichron -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">למה לקנות נכס בזכרון יעקב?</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { title: 'יקבים ותרבות', desc: 'אווירה ייחודית וקסומה - יקבים, מסעדות, גלריות, ופסטיבלים.' },
          { title: 'נופים מרהיבים', desc: 'נוף לים התיכון ולעמק יזרעאל - מהיפים בארץ.' },
          { title: 'קהילה איכותית', desc: 'אוכלוסייה משכילה ומבוססת, בתי ספר מצוינים.' },
          { title: 'שמירה על ערך', desc: 'עליית מחירים יציבה לאורך שנים - השקעה בטוחה.' },
        ].map((item) => (
          <div class="bg-white p-6 rounded-xl shadow-sm border border-border">
            <h3 class="font-bold text-dark mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Guides -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">מדריכים רלוונטיים</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <a href="/guides/down-payment/" class="block bg-surface p-4 rounded-xl hover:shadow-md transition-shadow">
          <h3 class="font-bold text-dark mb-1">הון עצמי למשכנתא</h3>
          <p class="text-gray-600 text-sm">כמה צריך ומאיפה אפשר לגייס?</p>
        </a>
        <a href="/guides/mortgage-mix/" class="block bg-surface p-4 rounded-xl hover:shadow-md transition-shadow">
          <h3 class="font-bold text-dark mb-1">תמהיל משכנתא</h3>
          <p class="text-gray-600 text-sm">פריים, קל"צ, צמודה - מה הכי טוב?</p>
        </a>
        <a href="/guides/refinancing/" class="block bg-surface p-4 rounded-xl hover:shadow-md transition-shadow">
          <h3 class="font-bold text-dark mb-1">מחזור משכנתא</h3>
          <p class="text-gray-600 text-sm">מתי כדאי ואיך לעשות נכון</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Other Areas -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">אזורים נוספים באזור חיפה</h2>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/areas/haifa/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">חיפה</a>
        <a href="/areas/kiryat-bialik/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">קריית ביאליק</a>
        <a href="/areas/kiryat-motzkin/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">קריית מוצקין</a>
        <a href="/areas/kiryat-ata/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">קריית אתא</a>
        <a href="/areas/nesher/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">נשר</a>
        <a href="/areas/tirat-carmel/" class="bg-white px-4 py-2 rounded-lg border border-border hover:border-brand-300 transition-colors text-sm">טירת כרמל</a>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות - משכנתא בזכרון יעקב" />

  <CTASection
    title="מחפשים יועץ משכנתאות בזכרון יעקב?"
    subtitle="השאירו פרטים וקבלו ייעוץ ראשוני ללא עלות"
  />
</BaseLayout>
