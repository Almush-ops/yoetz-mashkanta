---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: 'זכרון יעקב' },
];

const faqItems = [
  {
    question: 'האם אתם מגיעים לזכרון יעקב?',
    answer: 'כן, אנו מגיעים לפגישות בזכרון יעקב. אפשר גם לקיים פגישות בזום לנוחותכם.',
  },
  {
    question: 'מה מיוחד בשוק הנדל"ן בזכרון?',
    answer: 'זכרון יעקב היא עיירה יוקרתית עם מחירי נדל"ן גבוהים יחסית, אך עם איכות חיים יוצאת דופן.',
  },
  {
    question: 'האם יש משכנתאות מיוחדות לנכסים יקרים?',
    answer: 'כן, יש מסלולים מיוחדים לנכסים בשווי גבוה. נעזור לכם למצוא את הפתרון המתאים.',
  },
];
---

<BaseLayout
  title="יועץ משכנתאות בזכרון יעקב | ייעוץ משכנתאות"
  description="יועץ משכנתאות בזכרון יעקב - ליווי מקצועי ברכישת נכס באזור היוקרתי. שירות אישי לתושבי זכרון יעקב והסביבה."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">יועץ משכנתאות בזכרון יעקב</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        ייעוץ משכנתאות מקצועי לזכרון יעקב והסביבה - ליווי ברכישת נכס באחת העיירות היפות בארץ.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          זכרון יעקב היא עיירה ציורית ויוקרתית, הידועה באווירה שלה, היקבים, והקהילה המיוחדת. רכישת נכס בזכרון דורשת תכנון פיננסי מדוקדק.
        </p>
        <p>
          תוכן מפורט על שוק הנדל"ן בזכרון יעקב והשירותים שלנו יתווסף כאן.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">למה זכרון יעקב?</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { title: 'איכות חיים', desc: 'אווירה ייחודית, תרבות, ואקלים מעולה' },
          { title: 'קהילה', desc: 'קהילה חמה ומגובשת' },
          { title: 'נוף', desc: 'נופים מרהיבים לים ולעמק' },
          { title: 'ערך נכסים', desc: 'שמירה על ערך ועליית מחירים לאורך זמן' },
        ].map((item) => (
          <div class="bg-white p-6 rounded-xl shadow-sm border border-border">
            <h3 class="font-bold text-dark mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות - זכרון יעקב" />

  <CTASection />
</BaseLayout>
