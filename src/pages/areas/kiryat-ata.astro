---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: 'קריית אתא' },
];

const faqItems = [
  {
    question: 'האם אתם פעילים בקריית אתא?',
    answer: 'כן, אנו מעניקים שירות מלא לתושבי קריית אתא ומגיעים לפגישות בעיר.',
  },
  {
    question: 'מה המצב בשוק הנדל"ן בקריית אתא?',
    answer: 'קריית אתא מציעה מחירים נגישים יחסית עם פוטנציאל עלייה. נשמח לעזור לכם להבין את השוק.',
  },
  {
    question: 'האם יש פרויקטים חדשים באזור?',
    answer: 'יש מספר פרויקטים חדשים בקריית אתא. נוכל לעזור לכם גם עם משכנתא לדירה מקבלן.',
  },
];
---

<BaseLayout
  title="יועץ משכנתאות בקריית אתא | ייעוץ משכנתאות"
  description="יועץ משכנתאות בקריית אתא - ליווי מקצועי ברכישת דירה ומחזור משכנתא. שירות אישי לתושבי קריית אתא."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 md:py-16 bg-gradient-to-br from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">יועץ משכנתאות בקריית אתא</h1>
      <p class="text-lg text-brand-100 max-w-2xl mx-auto">
        ייעוץ משכנתאות מקצועי לתושבי קריית אתא - בדרך לדירה במחיר הוגן.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          קריית אתא היא אחת הערים הגדולות בקריות, עם מגוון שכונות ואפשרויות מגורים במחירים נגישים. אנו מכירים את השוק המקומי ונעזור לכם למצוא את המשכנתא הנכונה.
        </p>
        <p>
          תוכן מפורט על שוק הנדל"ן בקריית אתא והשירותים שלנו יתווסף כאן.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">למה קריית אתא?</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { title: 'מחירים נגישים', desc: 'מחירי דירות נמוכים יחסית לאזור' },
          { title: 'פיתוח עירוני', desc: 'שדרוגי תשתיות ופרויקטים חדשים' },
          { title: 'נגישות', desc: 'קרבה לחיפה ולמפרץ' },
          { title: 'קהילה', desc: 'קהילות חזקות ושירותים טובים' },
        ].map((item) => (
          <div class="bg-white p-6 rounded-xl shadow-sm border border-border">
            <h3 class="font-bold text-dark mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faqItems} title="שאלות נפוצות - קריית אתא" />

  <CTASection />
</BaseLayout>
