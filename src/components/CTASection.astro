---
/* Call-to-Action section with gradient background and dual buttons. */

interface Props {
  title?: string;
  subtitle?: string;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
  backgroundImage?: string;
  phone?: string;
}

const {
  title = 'רוצים לדעת כמה תוכלו לחסוך?',
  subtitle = 'השאירו פרטים וקבלו ייעוץ חינם',
  primaryText = 'השאירו פרטים',
  primaryHref = '/contact/',
  secondaryText,
  secondaryHref,
  backgroundImage,
  phone,
} = Astro.props;
---

<section class="relative overflow-hidden">
  {/* Background image (optional) */}
  {backgroundImage && (
    <img
      src={backgroundImage}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
      width="1920"
      height="400"
    />
  )}
  <div class:list={[
    'absolute inset-0',
    backgroundImage
      ? 'bg-gradient-to-l from-brand-700/90 via-brand-600/85 to-brand-500/80'
      : 'bg-gradient-to-l from-brand-800 via-brand-700 to-brand-600',
  ]}></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 py-14 text-center text-white">
    <h2 class="text-2xl md:text-3xl font-bold mb-3">{title}</h2>
    <p class="text-brand-100 text-lg mb-6">{subtitle}</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href={primaryHref}
        class="inline-flex items-center justify-center px-7 py-3.5 bg-accent-500 text-white font-semibold rounded-lg hover:bg-accent-600 transition-colors shadow-lg text-lg"
      >
        {primaryText}
      </a>
      {secondaryText && secondaryHref && (
        <a
          href={secondaryHref}
          class="inline-flex items-center justify-center px-7 py-3.5 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors text-lg"
        >
          {secondaryText}
        </a>
      )}
      {phone && (
        <a
          href={`tel:${phone}`}
          class="inline-flex items-center justify-center px-7 py-3.5 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors text-lg"
        >
          <svg class="w-5 h-5 me-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {phone}
        </a>
      )}
    </div>
  </div>
</section>
