---
interface Props {
  title?: string;
}

const { title = 'פעילות מקצועית' } = Astro.props;
---

<section class="bg-white py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex flex-col lg:flex-row gap-12 items-center">
      <!-- Image side -->
      <div class="lg:w-1/2">
        <img
          src="/images/conference-1.webp"
          alt="איתי אנצל בכנס מקצועי - מימון בניה בהרחבות וקיבוצים"
          class="rounded-xl shadow-lg w-full"
          width="600"
          height="400"
          loading="lazy"
        />
        <p class="text-sm text-gray-500 mt-3 text-center">כנס מקצועי בנושא מימון בניה בהרחבות וקיבוצים, אוגוסט 2023</p>
      </div>

      <!-- Text side -->
      <div class="lg:w-1/2">
        <h2 class="text-2xl md:text-3xl font-bold text-dark mb-6">{title}</h2>

        <div class="space-y-6">
          <!-- HFCA Membership -->
          <div class="flex items-start gap-4 p-4 bg-surface rounded-xl">
            <div class="w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark mb-1">חבר התאחדות יועצי המשכנתאות (HFCA)</h3>
              <p class="text-gray-600 text-sm mb-2">חבר מאז 2017. ההתאחדות מאגדת את יועצי המשכנתאות המקצועיים בישראל ומבטיחה סטנדרטים מקצועיים גבוהים.</p>
              <a
                href="https://hfca.org.il/userprofile/?id=210"
                target="_blank"
                rel="noopener"
                class="text-sm text-brand-600 hover:text-brand-700 inline-flex items-center gap-1"
              >
                צפייה בפרופיל המאומת
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Continuous Learning -->
          <div class="flex items-start gap-4 p-4 bg-surface rounded-xl">
            <div class="w-12 h-12 bg-accent-100 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark mb-1">השתלמויות וכנסים מקצועיים</h3>
              <p class="text-gray-600 text-sm">השתתפות קבועה בכנסים מקצועיים, השתלמויות ועדכונים בתחום המשכנתאות והפיננסים. תמיד מעודכן בשינויי רגולציה ומוצרים חדשים.</p>
            </div>
          </div>

          <!-- Experience -->
          <div class="flex items-start gap-4 p-4 bg-surface rounded-xl">
            <div class="w-12 h-12 bg-yellow-100 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark mb-1">דירוג 9.68 מתוך 10</h3>
              <p class="text-gray-600 text-sm">169 לקוחות מרוצים העניקו דירוג גבוה. השירות האישי והמקצועי מדבר בעד עצמו.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
