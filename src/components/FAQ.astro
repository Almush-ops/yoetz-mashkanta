---
/* FAQ component with native <details> and Schema.org FAQPage JSON-LD. */

interface FAQItem {
  question: string;
  /** Supports HTML in answers (links, formatting) */
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title = 'שאלות נפוצות' } = Astro.props;

/* Strip HTML for schema (Google requires plain text) */
const stripHtml = (html: string) => html.replace(/<[^>]*>/g, '');

/* Schema.org FAQPage structured data for SEO */
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: stripHtml(item.answer),
    },
  })),
};
---

<section class="bg-surface py-16 md:py-20">
  <div class="max-w-3xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-dark text-center mb-10">{title}</h2>
    <div class="space-y-3">
      {items.map((item) => (
        <details class="group border border-border bg-white rounded-lg overflow-hidden">
          <summary class="flex items-center justify-between p-4 cursor-pointer hover:bg-gray-50 transition-colors">
            <span class="font-medium text-dark pe-4">{item.question}</span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-4 pb-4 text-gray-600 leading-relaxed border-t border-border pt-3">
            <Fragment set:html={item.answer} />
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- FAQPage structured data for SEO -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
