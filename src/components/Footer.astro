---
const currentYear = new Date().getFullYear();

const phone = '055-432-6608';
const email = 'info@yoetz-mashkanta.co.il';
const address = 'קרן היסוד 7, קריית ביאליק';

const services = [
  { name: 'ייעוץ משכנתא', href: '/services/mortgage-consultation/', icon: 'chat' },
  { name: 'מחזור משכנתא', href: '/services/mortgage-refinance/', icon: 'refresh' },
  { name: 'משכנתא לזוגות צעירים', href: '/services/young-couples/', icon: 'users' },
  { name: 'משכנתא למסורבים', href: '/services/declined-applicants/', icon: 'check' },
  { name: 'משכנתא הפוכה', href: '/services/reverse-mortgage/', icon: 'switch' },
  { name: 'משכנתא לשיפוץ', href: '/services/mortgage-renovation/', icon: 'wrench' },
  { name: 'איחוד הלוואות', href: '/services/debt-consolidation/', icon: 'merge' },
  { name: 'תכנון פיננסי', href: '/services/financial-planning/', icon: 'chart' },
];

const serviceIcons: Record<string, string> = {
  chat: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  refresh: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  users: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  check: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  switch: 'M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4',
  wrench: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  merge: 'M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1',
  chart: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
};

const tools = [
  { name: 'מחשבון משכנתא', href: '/tools/mortgage-calculator/' },
  { name: 'מחשבון כדאיות מחזור', href: '/tools/refinance-calculator/' },
  { name: 'בדיקת יכולת החזר', href: '/tools/eligibility-calculator/' },
];

const popularGuides = [
  { name: 'מדריך זוגות צעירים 2026', href: '/guides/young-couples/' },
  { name: 'ריביות משכנתא 2026', href: '/guides/interest-rates/' },
  { name: 'טעויות נפוצות במשכנתא', href: '/guides/common-mistakes/' },
];

const companyLinks = [
  { name: 'אודות', href: '/about/' },
  { name: 'המלצות לקוחות', href: '/testimonials/' },
  { name: 'סיפורי הצלחה', href: '/case-studies/' },
  { name: 'שאלות נפוצות', href: '/faq/' },
];

const areas = [
  { name: 'חיפה', href: '/areas/haifa/' },
  { name: 'קריית ביאליק', href: '/areas/kiryat-bialik/' },
  { name: 'קריית מוצקין', href: '/areas/kiryat-motzkin/' },
  { name: 'קריית אתא', href: '/areas/kiryat-ata/' },
  { name: 'נשר', href: '/areas/nesher/' },
  { name: 'טירת כרמל', href: '/areas/tirat-carmel/' },
  { name: 'זכרון יעקב', href: '/areas/zichron-yaakov/' },
];
---

<footer class="bg-brand-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Main Footer Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Column 1: Brand & Trust Signals -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-block mb-4 hover:opacity-90 transition-opacity">
          <img
            src="/images/logo.svg"
            alt="יועץ משכנתאות - איתי אנצל"
            class="h-12 w-auto brightness-0 invert"
            width="180"
            height="48"
          />
        </a>
        <p class="text-sm text-gray-400 mb-5 leading-relaxed">
          ייעוץ משכנתאות מקצועי ואישי בחיפה והקריות. ליווי צמוד מהשלב הראשון ועד קבלת המפתח.
        </p>

        <!-- Trust Signals Grid -->
        <div class="grid grid-cols-2 gap-3 mb-4">
          <div class="flex items-center gap-2 text-sm">
            <span class="text-accent-400 text-lg font-bold">7+</span>
            <span class="text-gray-400">שנות ניסיון</span>
          </div>
          <div class="flex items-center gap-2 text-sm">
            <span class="text-accent-400 text-lg font-bold">169</span>
            <span class="text-gray-400">לקוחות מרוצים</span>
          </div>
        </div>

        <!-- Rating -->
        <div class="flex items-center gap-2 mb-3">
          <div class="flex text-accent-400">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-sm text-white font-medium">9.68</span>
          <span class="text-sm text-gray-500">מתוך 10</span>
        </div>

        <!-- HFCA Badge -->
        <a
          href="https://hfca.org.il/userprofile/?id=210"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-xs text-gray-500 hover:text-gray-300 transition-colors"
        >
          <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          חבר התאחדות יועצי המשכנתאות מ-2017
        </a>
      </div>

      <!-- Column 2: Services -->
      <div>
        <h4 class="text-white text-sm font-semibold mb-4 flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
          שירותים
        </h4>
        <ul class="space-y-2 text-sm">
          {services.map((service) => (
            <li>
              <a href={service.href} class="hover:text-white transition-colors inline-flex items-center gap-2">
                <svg class="w-4 h-4 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={serviceIcons[service.icon]} />
                </svg>
                {service.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Tools & Guides -->
      <div>
        <h4 class="text-white text-sm font-semibold mb-4 flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
          כלים חינמיים
        </h4>
        <ul class="space-y-2 text-sm mb-6">
          {tools.map((tool) => (
            <li>
              <a href={tool.href} class="hover:text-white transition-colors inline-flex items-center gap-2 group">
                <svg class="w-4 h-4 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
                {tool.name}
              </a>
            </li>
          ))}
        </ul>

        <h4 class="text-white text-sm font-semibold mb-3 flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          מדריכים פופולריים
        </h4>
        <ul class="space-y-2 text-sm">
          {popularGuides.map((guide) => (
            <li>
              <a href={guide.href} class="hover:text-white transition-colors">{guide.name}</a>
            </li>
          ))}
          <li>
            <a href="/guides/" class="text-accent-400 hover:text-accent-300 transition-colors inline-flex items-center gap-1 text-sm font-medium">
              כל המדריכים
              <span>←</span>
            </a>
          </li>
        </ul>

      </div>

      <!-- Column 4: Contact -->
      <div>
        <h4 class="text-white text-sm font-semibold mb-4 flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          יצירת קשר
        </h4>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{address}</span>
          </li>
          <li>
            <a href={`tel:${phone}`} class="flex items-center gap-2 hover:text-white transition-colors">
              <svg class="w-5 h-5 flex-shrink-0 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${email}`} class="flex items-center gap-2 hover:text-white transition-colors">
              <svg class="w-5 h-5 flex-shrink-0 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {email}
            </a>
          </li>
          <li class="flex items-center gap-2 text-gray-400">
            <svg class="w-5 h-5 flex-shrink-0 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            א׳-ה׳ 09:00-18:00
          </li>
        </ul>

        <!-- CTA Button -->
        <a
          href="/contact/"
          class="mt-5 inline-flex items-center justify-center gap-2 w-full bg-accent-500 hover:bg-accent-600 text-white font-medium py-3 px-4 rounded-lg transition-all shadow-lg shadow-accent-500/20 hover:shadow-accent-500/30 group"
        >
          <span>ייעוץ ראשוני חינם</span>
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </a>

        <!-- About Us -->
        <h4 class="text-white text-sm font-semibold mb-3 mt-6 flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          אודותינו
        </h4>
        <ul class="space-y-2 text-sm">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Service Areas Strip -->
    <div class="border-t border-brand-800 mt-10 pt-6">
      <div class="flex flex-wrap items-center justify-center gap-x-1 gap-y-2 text-sm text-gray-500">
        <span class="text-gray-400 ml-2">אזורי שירות:</span>
        {areas.map((area, index) => (
          <>
            <a href={area.href} class="hover:text-white transition-colors">{area.name}</a>
            {index < areas.length - 1 && <span class="text-brand-700">•</span>}
          </>
        ))}
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-brand-800 mt-6 pt-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500">
        <p>&copy; {currentYear} יועץ משכנתאות - איתי אנצל. כל הזכויות שמורות.</p>
        <div class="flex flex-wrap justify-center gap-4 md:gap-6">
          <a href="/accessibility/" class="hover:text-white transition-colors">הצהרת נגישות</a>
          <a href="/privacy/" class="hover:text-white transition-colors">מדיניות פרטיות</a>
          <a href="/terms/" class="hover:text-white transition-colors">תנאי שימוש</a>
          <a href="/editorial/" class="hover:text-white transition-colors">מדיניות עריכה</a>
          <a href="/complaints/" class="hover:text-white transition-colors">מדיניות תלונות</a>
          <a href="/contact/" class="hover:text-white transition-colors">צור קשר</a>
        </div>
      </div>

      <!-- Legal Disclaimer -->
      <p class="mt-4 text-center text-xs text-gray-600">
        המידע באתר הינו כללי בלבד ואינו מהווה ייעוץ משפטי, פיננסי או אישי מחייב.
        הנתונים והחישובים מוצגים להמחשה בלבד ועשויים להשתנות.
        לקבלת ייעוץ מותאם אישית יש לפנות ליועץ המשכנתאות.
      </p>
    </div>
  </div>
</footer>
