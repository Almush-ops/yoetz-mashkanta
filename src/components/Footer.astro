---
const currentYear = new Date().getFullYear();

// Placeholder - will be updated when user provides
const phone = '050-0000000';
const email = 'info@yoetz-mashkanta.co.il';
const address = 'קרן היסוד 7, קריית ביאליק';
---

<footer class="bg-brand-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <h3 class="text-white text-xl font-bold mb-4">יועץ משכנתאות - איתי אנצל</h3>
        <p class="text-sm text-gray-400 mb-4 max-w-md">
          ייעוץ משכנתאות מקצועי ואישי בחיפה והקריות. מעל 7 שנות ניסיון, 169 לקוחות מרוצים, חבר התאחדות יועצי המשכנתאות.
        </p>
        <div class="flex items-center gap-2 text-accent-400">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span class="text-sm">דירוג 9.68 מתוך 10</span>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white text-sm font-semibold mb-4">שירותים</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/services/mortgage-consultation/" class="hover:text-white transition-colors">ייעוץ משכנתא</a></li>
          <li><a href="/services/mortgage-refinance/" class="hover:text-white transition-colors">מחזור משכנתא</a></li>
          <li><a href="/services/young-couples/" class="hover:text-white transition-colors">משכנתא לזוגות צעירים</a></li>
          <li><a href="/services/declined-applicants/" class="hover:text-white transition-colors">משכנתא למסורבים</a></li>
          <li><a href="/services/debt-consolidation/" class="hover:text-white transition-colors">איחוד הלוואות</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white text-sm font-semibold mb-4">יצירת קשר</h4>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{address}</span>
          </li>
          <li>
            <a href={`tel:${phone}`} class="flex items-center gap-2 hover:text-white transition-colors">
              <svg class="w-5 h-5 flex-shrink-0 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${email}`} class="flex items-center gap-2 hover:text-white transition-colors">
              <svg class="w-5 h-5 flex-shrink-0 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-brand-800 mt-10 pt-6 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500">
      <p>&copy; {currentYear} יועץ משכנתאות - איתי אנצל. כל הזכויות שמורות.</p>
      <div class="flex gap-6">
        <a href="/accessibility/" class="hover:text-white transition-colors">הצהרת נגישות</a>
        <a href="/privacy/" class="hover:text-white transition-colors">מדיניות פרטיות</a>
        <a href="/terms/" class="hover:text-white transition-colors">תנאי שימוש</a>
      </div>
    </div>

    <!-- E-E-A-T Link (minimal) -->
    <div class="mt-4 text-center text-xs text-gray-600">
      <a href="https://hfca.org.il/userprofile/?id=210" target="_blank" rel="noopener" class="hover:text-gray-400">חבר התאחדות יועצי המשכנתאות</a>
    </div>
  </div>
</footer>
