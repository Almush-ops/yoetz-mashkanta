---
/* Service card - icon, title, description, and optional link. */

interface Props {
  title: string;
  description: string;
  /** SVG path data (d attribute) for the icon */
  icon: string;
  href?: string;
}

const {
  title,
  description,
  icon,
  href,
} = Astro.props;
---

<div class:list={[
  'bg-white p-6 rounded-xl border border-gray-100 transition-all duration-300 hover:shadow-lg',
  href && 'group',
]}>
  {/* Icon */}
  <div class="w-14 h-14 rounded-xl bg-brand-50 group-hover:bg-brand-100 flex items-center justify-center mb-4 transition-colors duration-300">
    <svg class="w-7 h-7 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
    </svg>
  </div>

  {/* Title */}
  <h3 class="font-semibold text-dark text-lg mb-2">{title}</h3>

  {/* Description */}
  <p class="text-sm text-gray-500 leading-relaxed mb-4">{description}</p>

  {/* Optional link */}
  {href && (
    <a
      href={href}
      class="inline-flex items-center text-sm font-medium text-brand-600 hover:text-brand-700 transition-colors focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 rounded"
    >
      <span>פרטים נוספים</span>
      <svg class="w-4 h-4 ms-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </a>
  )}
</div>
