---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'ליווי אישי בכל שלב',
  subtitle = 'תמונות מפגישות אמיתיות עם לקוחות'
} = Astro.props;

const galleryImages = [
  {
    src: '/images/client-meeting-1.webp',
    alt: 'איתי אנצל בפגישת ייעוץ משכנתא עם זוג - חתימה על מסמכים',
    caption: 'פגישת ייעוץ וחתימה על מסמכים',
  },
  {
    src: '/images/bank-meeting-1.webp',
    alt: 'איתי אנצל מלווה לקוחות בסניף בנק שיכון ובינוי',
    caption: 'ליווי לקוחות בבנק',
  },
  {
    src: '/images/client-signing.webp',
    alt: 'לקוח חותם על משכנתא בליווי איתי אנצל',
    caption: 'רגע החתימה על המשכנתא',
  },
  {
    src: '/images/couple-meeting.webp',
    alt: 'איתי אנצל בפגישה עם זוג צעיר לגבי משכנתא',
    caption: 'ליווי זוגות צעירים',
  },
];
---

<section class="bg-surface py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-dark mb-3">{title}</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {galleryImages.map((image) => (
        <div class="group relative overflow-hidden rounded-xl shadow-md hover:shadow-xl transition-shadow">
          <img
            src={image.src}
            alt={image.alt}
            class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-300"
            loading="lazy"
            width="400"
            height="300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <p class="text-white text-sm font-medium">{image.caption}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Privacy note -->
    <p class="mt-8 text-center text-sm text-gray-500">
      * שמות הלקוחות שונו לשמירה על פרטיותם
    </p>
  </div>
</section>
