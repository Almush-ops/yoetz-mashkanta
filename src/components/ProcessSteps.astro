---
/* Process steps - numbered steps section for "how it works". */

interface Step {
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  steps: Step[];
  title?: string;
}

const { steps, title } = Astro.props;
---

<section class="bg-white py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    {title && (
      <h2 class="text-2xl md:text-3xl font-bold text-dark text-center mb-12">{title}</h2>
    )}

    <div class:list={[
      'grid gap-8',
      steps.length <= 3 ? 'md:grid-cols-3' : 'md:grid-cols-3 lg:grid-cols-4',
    ]}>
      {steps.map((step, i) => (
        <div class="relative text-center md:text-start">
          {/* Connector line between steps (desktop only) */}
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-6 start-[calc(50%+28px)] end-[calc(-50%+28px)] border-t-2 border-dashed border-gray-200"></div>
          )}

          {/* Step number circle or icon */}
          <div class="flex justify-center md:justify-start mb-4 relative z-10">
            {step.icon ? (
              <div class="w-12 h-12 rounded-full bg-brand-600 flex items-center justify-center shadow-md">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
                </svg>
              </div>
            ) : (
              <div class="w-12 h-12 rounded-full bg-brand-600 text-white flex items-center justify-center font-bold text-lg shadow-md">
                {i + 1}
              </div>
            )}
          </div>

          {/* Step content */}
          <h3 class="font-semibold text-dark mb-2">{step.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
