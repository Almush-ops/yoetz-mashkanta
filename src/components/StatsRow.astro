---
/* Stats row - row of statistics/numbers in a responsive grid. */

interface Stat {
  value: string;
  label: string;
  prefix?: string;
  suffix?: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<section class="bg-white py-8 md:py-12 border-y border-brand-100">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {stats.map((stat) => (
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-extrabold text-brand-600">
            {stat.prefix && <span>{stat.prefix}</span>}
            {stat.value}
            {stat.suffix && <span>{stat.suffix}</span>}
          </p>
          <p class="text-sm text-gray-500 mt-1">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
