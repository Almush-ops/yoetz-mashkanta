---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'product';
  canonicalUrl?: string;
  noindex?: boolean;
  lang?: string;
  dir?: string;
}

const {
  title,
  description = '',
  ogImage,
  ogType = 'website',
  canonicalUrl,
  noindex = false,
  lang = 'he',
  dir = 'rtl',
} = Astro.props;

const phone = '055-432-6608';
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      canonicalUrl={canonicalUrl}
      noindex={noindex}
    />
    <slot name="schema" />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-dark antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Sticky Phone Button (Mobile) -->
    <a
      href={`tel:${phone}`}
      class="fixed bottom-4 start-4 z-50 md:hidden flex items-center justify-center w-14 h-14 bg-accent-500 text-white rounded-full shadow-lg hover:bg-accent-600 transition-all active:scale-95"
      aria-label="התקשרו עכשיו"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
    </a>

    <!-- Accessibility Widget Button -->
    <button
      id="a11y-btn"
      class="fixed bottom-4 end-4 z-50 flex items-center justify-center w-12 h-12 bg-brand-700 text-white rounded-full shadow-lg hover:bg-brand-800 transition-all"
      aria-label="הגדרות נגישות"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
    </button>

    <!-- Accessibility Panel -->
    <div id="a11y-panel" class="fixed bottom-20 end-4 z-50 hidden bg-white rounded-xl shadow-2xl p-4 w-64 border border-gray-200">
      <h3 class="font-bold text-dark mb-3 text-sm">הגדרות נגישות</h3>
      <div class="space-y-2">
        <button data-a11y="font-increase" class="w-full text-start px-3 py-2 text-sm rounded-lg hover:bg-gray-100 transition-colors flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg>
          הגדלת גופן
        </button>
        <button data-a11y="font-decrease" class="w-full text-start px-3 py-2 text-sm rounded-lg hover:bg-gray-100 transition-colors flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" /></svg>
          הקטנת גופן
        </button>
        <button data-a11y="grayscale" class="w-full text-start px-3 py-2 text-sm rounded-lg hover:bg-gray-100 transition-colors flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          מצב גווני אפור
        </button>
        <button data-a11y="contrast" class="w-full text-start px-3 py-2 text-sm rounded-lg hover:bg-gray-100 transition-colors flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
          ניגודיות גבוהה
        </button>
        <button data-a11y="links" class="w-full text-start px-3 py-2 text-sm rounded-lg hover:bg-gray-100 transition-colors flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
          הדגשת קישורים
        </button>
        <button data-a11y="reset" class="w-full text-start px-3 py-2 text-sm rounded-lg bg-gray-100 hover:bg-gray-200 transition-colors flex items-center gap-2 mt-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
          איפוס
        </button>
      </div>
    </div>

    <script>
      // Accessibility widget
      const a11yBtn = document.getElementById('a11y-btn');
      const a11yPanel = document.getElementById('a11y-panel');
      let fontSize = 100;

      a11yBtn?.addEventListener('click', () => {
        a11yPanel?.classList.toggle('hidden');
      });

      // Close panel when clicking outside
      document.addEventListener('click', (e) => {
        if (!a11yBtn?.contains(e.target as Node) && !a11yPanel?.contains(e.target as Node)) {
          a11yPanel?.classList.add('hidden');
        }
      });

      // Handle accessibility actions
      document.querySelectorAll('[data-a11y]').forEach(btn => {
        btn.addEventListener('click', () => {
          const action = (btn as HTMLElement).dataset.a11y;
          const html = document.documentElement;

          switch (action) {
            case 'font-increase':
              fontSize = Math.min(fontSize + 10, 150);
              html.style.fontSize = fontSize + '%';
              break;
            case 'font-decrease':
              fontSize = Math.max(fontSize - 10, 80);
              html.style.fontSize = fontSize + '%';
              break;
            case 'grayscale':
              document.body.classList.toggle('a11y-grayscale');
              break;
            case 'contrast':
              document.body.classList.toggle('a11y-contrast');
              break;
            case 'links':
              document.body.classList.toggle('a11y-links');
              break;
            case 'reset':
              fontSize = 100;
              html.style.fontSize = '100%';
              document.body.classList.remove('a11y-grayscale', 'a11y-contrast', 'a11y-links');
              break;
          }
        });
      });
    </script>
  </body>
</html>
